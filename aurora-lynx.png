:root {
  --accent: #2563eb;
  --accent-soft: #2563eb1a;
  --blue: #2563eb;
  --green: #10b981;
  --ink: #111827;
  --muted: #64748b;
  --line: #dbe5ee;
  --soft: #f5f8fc;
  --panel: #ffffff;
  --panel-2: #f9fbff;
  --white: #ffffff;
  --good: #10b981;
  --ok: #f59e0b;
  --bad: #ef4444;
  --mascot-fur: #f6c978;
  --mascot-fur-deep: #d99136;
  --mascot-cheek: #fff4df;
  --mascot-ink: #243244;
  --mascot-nose: #334155;
  --shadow: 0 18px 50px rgba(17, 24, 39, 0.09);
  --shadow-soft: 0 10px 28px rgba(17, 24, 39, 0.06);
}

html[data-theme="dark"] {
  --ink: #e7edf7;
  --muted: #9aa8ba;
  --line: #243244;
  --soft: #0d1320;
  --panel: #121b2a;
  --panel-2: #172235;
  --white: #ffffff;
  --mascot-fur: #dca555;
  --mascot-fur-deep: #b7792c;
  --mascot-cheek: #2b3546;
  --mascot-ink: #f1f5f9;
  --mascot-nose: #f8fafc;
  --shadow: 0 18px 50px rgba(0, 0, 0, 0.38);
  --shadow-soft: 0 10px 28px rgba(0, 0, 0, 0.28);
}

* { box-sizing: border-box; }
html { background: var(--soft); color: var(--ink); font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
body { margin: 0; min-height: 100vh; }
button, input, select, textarea { font: inherit; }
a { color: inherit; text-decoration: none; }
button { color: inherit; }
button:focus-visible,
a:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible {
  outline: 3px solid color-mix(in srgb, var(--accent) 58%, #ffffff);
  outline-offset: 3px;
}
.app-shell { min-height: 100vh; padding-bottom: 88px; }
.topbar { align-items: center; background: color-mix(in srgb, var(--panel) 92%, transparent); border-bottom: 1px solid var(--line); display: flex; gap: 12px; justify-content: space-between; padding: 12px 16px; position: sticky; top: 0; z-index: 20; backdrop-filter: blur(18px); }
.brand { align-items: center; display: flex; gap: 10px; min-width: 0; }
.brand strong { display: block; font-size: 1rem; }
.brand small { color: var(--muted); display: block; font-size: 0.74rem; }
.logo { align-items: center; background: linear-gradient(145deg, var(--accent), var(--green)); border-radius: 10px; display: grid; height: 42px; place-items: center; width: 42px; box-shadow: 0 10px 26px color-mix(in srgb, var(--accent) 28%, transparent); }
.logo svg { fill: none; height: 29px; stroke: var(--white); stroke-linecap: round; stroke-linejoin: round; stroke-width: 2.4; width: 29px; }
.brand-logo { background: #05070d; border-radius: 13px; overflow: hidden; }
.brand-logo img { display: block; height: 100%; object-fit: contain; object-position: center; transform: none; width: 100%; }
.streak-pill { align-items: center; background: color-mix(in srgb, #fff7ed 86%, var(--panel)); border: 1px solid color-mix(in srgb, #fb923c 34%, var(--line)); border-radius: 999px; box-shadow: 0 8px 20px rgba(249, 115, 22, 0.14); color: #ea580c; display: inline-flex; flex: 0 0 auto; gap: 4px; min-height: 32px; padding: 4px 9px 4px 6px; }
.streak-pill strong { color: #9a3412; font-size: 0.92rem; line-height: 1; }
.streak-flame { height: 21px; width: 21px; }
.flame-main { fill: #f97316; }
.flame-core { fill: #fef3c7; }
html[data-theme="dark"] .streak-pill { background: color-mix(in srgb, #431407 52%, var(--panel)); border-color: color-mix(in srgb, #fb923c 42%, var(--line)); color: #fdba74; }
html[data-theme="dark"] .streak-pill strong { color: #ffedd5; }
.xp-pill {
  align-items: center;
  background: color-mix(in srgb, var(--accent) 12%, var(--panel));
  border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
  border-radius: 999px;
  color: var(--accent);
  display: inline-flex;
  flex: 0 0 auto;
  gap: 4px;
  min-height: 32px;
  padding: 4px 10px;
}

.xp-pill strong {
  color: var(--accent);
  font-size: 0.92rem;
  line-height: 1;
}

.xp-pill span {
  font-size: 0.72rem;
  font-weight: 950;
}

.xp-pill.gain {
  animation: xpPillGlow 900ms ease-out;
}
.mascot { display: inline-grid; flex: 0 0 auto; place-items: center; }
.mascot-face { background: #05070d; border-radius: 999px; display: block; height: 58px; object-fit: contain; object-position: center; overflow: hidden; width: 58px; }
.mascot-small .mascot-face { height: 42px; width: 42px; }
.mascot-head { fill: var(--mascot-fur); stroke: var(--mascot-ink); stroke-linejoin: round; stroke-width: 2.6; }
.mascot-tuft { fill: var(--mascot-fur-deep); stroke: var(--mascot-ink); stroke-linejoin: round; stroke-width: 2.4; }
.mascot-cheek { fill: var(--mascot-cheek); stroke: color-mix(in srgb, var(--mascot-ink) 22%, transparent); stroke-width: 1.6; }
.mascot-eye, .mascot-smile, .mascot-mark { fill: none; stroke: var(--mascot-ink); stroke-linecap: round; stroke-linejoin: round; stroke-width: 2.6; }
.mascot-nose { fill: var(--mascot-nose); stroke: var(--mascot-ink); stroke-linejoin: round; stroke-width: 1.5; }
.mascot-sparkle { fill: var(--green); stroke: var(--panel); stroke-linejoin: round; stroke-width: 1.2; }
.brand-mascot { background: linear-gradient(145deg, color-mix(in srgb, var(--accent) 16%, var(--panel)), color-mix(in srgb, var(--green) 16%, var(--panel))); border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line)); box-shadow: 0 10px 26px color-mix(in srgb, var(--accent) 16%, transparent); }
.logo.brand-mascot svg { fill: initial; height: 38px; stroke: initial; stroke-width: initial; width: 38px; }
.mascot-card, .mascot-card-head, .mascot-empty { align-items: center; display: flex; gap: 12px; }
.mascot-card { background: color-mix(in srgb, var(--accent) 8%, var(--panel)); border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--line)); border-radius: 14px; color: var(--muted); line-height: 1.45; padding: 12px; }
.mascot-card p { margin: 0; }
.mascot-card-head { margin-bottom: -2px; }
.mascot-empty { align-items: flex-start; }
.mascot-floating .mascot-face { animation: lynxIdle 6.4s ease-in-out infinite; transform-origin: center bottom; }
.mascot-floating .mascot-eye { animation: lynxBlink 7.2s ease-in-out infinite; transform-origin: center; }
.top-actions { align-items: center; display: flex; gap: 8px; }
.theme-icon-button { align-items: center; background: transparent; border: 0; color: var(--ink); cursor: pointer; display: inline-grid; font-size: 1.35rem; height: 38px; place-items: center; width: 38px; }
.theme-icon-button:hover { color: var(--accent); transform: translateY(-1px); }
.account-button { padding-right: 12px; }
.top-icon-button { background: var(--panel-2); border: 1px solid var(--line); border-radius: 8px; color: var(--muted); cursor: pointer; font-size: 0.78rem; font-weight: 800; min-height: 36px; padding: 0 10px; }
.top-icon-button:hover { border-color: color-mix(in srgb, var(--accent) 40%, var(--line)); color: var(--accent); }
.sync-state { align-items: center; color: var(--muted); display: none; font-size: 0.84rem; gap: 8px; }
.status-dot { background: var(--green); border-radius: 50%; display: inline-block; height: 9px; width: 9px; }
.main-content { margin: 0 auto; max-width: 1180px; padding: 22px 16px 36px; }
.section-heading { margin-bottom: 22px; }
.eyebrow, .section-heading span, .panel-header span, .price-card > span, .study-card > span, .focus-card > span, .grade-overview-card > span, .library-pack > span { color: var(--green); display: block; font-size: 0.76rem; font-weight: 900; letter-spacing: 0; text-transform: uppercase; }
.section-heading h1 { font-size: clamp(2rem, 8vw, 3.8rem); line-height: 1.02; margin: 8px 0 10px; max-width: 780px; }
.section-heading p { color: var(--muted); font-size: 1rem; line-height: 1.55; margin: 0; max-width: 680px; }
.panel, .focus-card, .stat-card, .price-card, .item-card, .subject-card, .goal-card, .mini-card, .grade-overview-card, .grade-row { background: var(--panel); border: 1px solid var(--line); border-radius: 10px; box-shadow: var(--shadow-soft); }
.panel, .price-card { padding: 16px; }
.panel-header { align-items: flex-start; display: flex; gap: 14px; justify-content: space-between; margin-bottom: 14px; }
.panel-header h2 { font-size: 1.16rem; line-height: 1.2; margin: 3px 0 0; }
.panel-header .icon { color: var(--accent); }
.panel-note { color: var(--muted); line-height: 1.55; margin: -4px 0 16px; }
.icon { fill: none; height: 20px; stroke: currentColor; stroke-linecap: round; stroke-linejoin: round; stroke-width: 2.2; width: 20px; }
.primary-button, .secondary-button, .icon-button { align-items: center; border: 0; cursor: pointer; display: inline-flex; font-weight: 850; gap: 8px; justify-content: center; min-height: 44px; }
.primary-button { background: var(--accent); border-radius: 9px; color: var(--white); padding: 0 16px; box-shadow: 0 12px 28px color-mix(in srgb, var(--accent) 26%, transparent); }
.secondary-button { background: var(--panel-2); border: 1px solid var(--line); border-radius: 9px; color: var(--ink); padding: 0 14px; }
.icon-button { background: var(--panel-2); border: 1px solid var(--line); border-radius: 9px; color: var(--accent); height: 40px; padding: 0; width: 40px; }
.icon-button:disabled { cursor: default; opacity: 0.45; }
.premium-hero { background: radial-gradient(circle at 90% 10%, color-mix(in srgb, var(--green) 18%, transparent), transparent 35%), linear-gradient(135deg, color-mix(in srgb, var(--accent) 13%, var(--panel)), var(--panel)); border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line)); border-radius: 14px; box-shadow: var(--shadow); display: grid; gap: 18px; margin-bottom: 14px; padding: 22px; }
.premium-hero h1 { font-size: clamp(2.2rem, 9vw, 4.6rem); line-height: 0.98; margin: 8px 0 12px; max-width: 760px; }
.premium-hero p { color: var(--muted); font-size: 1.02rem; line-height: 1.55; margin: 0; max-width: 540px; }
.hero-score { align-self: end; background: var(--panel); border: 1px solid var(--line); border-radius: 12px; box-shadow: var(--shadow-soft); min-width: 160px; padding: 16px; }
.hero-score span { color: var(--muted); font-size: 0.9rem; font-weight: 900; }
.hero-score strong { display: block; font-size: 3rem; line-height: 1; margin: 5px 0; }
.hero-score small { color: var(--green); font-weight: 900; }
.focus-grid, .work-grid, .pricing-grid, .bot-layout, .cards-top, .planner-layout, .grade-shell, .grades-forms { display: grid; gap: 14px; }
.focus-grid { grid-template-columns: 1fr; }
.focus-card { padding: 16px; }
.focus-card h2 { font-size: 1.18rem; line-height: 1.25; margin: 8px 0; }
.focus-card p { color: var(--muted); line-height: 1.5; margin: 0 0 14px; }
.primary-focus { background: linear-gradient(160deg, var(--panel), color-mix(in srgb, var(--accent) 9%, var(--panel))); border-color: color-mix(in srgb, var(--accent) 24%, var(--line)); }
.quiet-strip { display: grid; gap: 10px; margin-top: 14px; }
.quiet-strip a { background: var(--panel); border: 1px solid var(--line); border-radius: 9px; color: var(--muted); font-weight: 850; padding: 14px 16px; }
.list-stack, .goal-stack, .panel-stack, .subject-list, .plan-list, .agenda-list, .mini-card-list { display: grid; gap: 12px; }
.task-row, .exam-row, .plan-row, .agenda-list article { align-items: center; border: 1px solid var(--line); border-radius: 9px; display: flex; gap: 12px; padding: 12px; }
.task-row strong, .exam-row strong, .plan-row strong, .agenda-list strong { display: block; }
.task-row small, .exam-row small, .agenda-list small { color: var(--muted); display: block; margin-top: 3px; }
.badge { border-radius: 999px; display: inline-flex; flex: 0 0 auto; font-size: 0.76rem; font-weight: 850; padding: 6px 9px; }
.badge.danger { background: color-mix(in srgb, var(--bad) 14%, transparent); color: var(--bad); }
.badge.warning { background: color-mix(in srgb, var(--ok) 16%, transparent); color: #b45309; }
.badge.calm { background: color-mix(in srgb, var(--good) 16%, transparent); color: var(--good); }
.date-pill, .agenda-list span { background: var(--accent-soft); border-radius: 9px; color: var(--accent); flex: 0 0 auto; font-size: 0.76rem; font-weight: 900; padding: 9px 10px; text-align: center; }
.text-link { color: var(--accent); font-size: 0.88rem; font-weight: 850; }
label { color: var(--ink); display: grid; font-size: 0.86rem; font-weight: 850; gap: 7px; margin-bottom: 12px; }
input, select, textarea { background: var(--panel-2); border: 1px solid var(--line); border-radius: 9px; color: var(--ink); min-height: 44px; outline: none; padding: 10px 12px; width: 100%; }
textarea { line-height: 1.45; resize: vertical; }
input:focus, select:focus, textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 16%, transparent); }
.form-row { display: grid; gap: 12px; grid-template-columns: 1fr; }
.compact-form, .goal-inline-form { display: grid; gap: 10px; }
.item-card { align-items: center; display: flex; gap: 12px; padding: 14px; }
.item-card.completed { opacity: 0.66; }
.item-main { flex: 1; min-width: 0; }
.item-title-line { align-items: center; display: flex; flex-wrap: wrap; gap: 8px; }
.item-card p { color: var(--muted); line-height: 1.45; margin: 8px 0; }
.meta-line { color: var(--muted); display: flex; flex-wrap: wrap; font-size: 0.82rem; gap: 10px; }
.meta-line span { align-items: center; display: inline-flex; gap: 4px; }
.meta-line .icon { height: 15px; width: 15px; }
.result-box { background: var(--accent-soft); border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line)); border-radius: 9px; color: var(--ink); font-weight: 750; margin-top: 14px; padding: 12px; }
.empty-state { background: var(--panel-2); border: 1px dashed var(--line); border-radius: 9px; color: var(--muted); padding: 16px; }
.empty-state strong { color: var(--ink); display: block; margin-bottom: 5px; }
.empty-state p { line-height: 1.45; margin: 0; }

.grade-shell { grid-template-columns: 1fr; margin-bottom: 14px; }
.grade-overview-card { background: linear-gradient(160deg, var(--panel), color-mix(in srgb, var(--green) 10%, var(--panel))); padding: 18px; }
.grade-overview-card strong { display: block; font-size: 4rem; letter-spacing: 0; line-height: 1; margin: 8px 0; }
.grade-overview-card p { color: var(--muted); line-height: 1.5; margin: 12px 0 0; }
.plus-points { border-radius: 999px; display: inline-flex; font-weight: 900; padding: 8px 11px; }
.plus-points.positive { background: color-mix(in srgb, var(--good) 14%, transparent); color: var(--good); }
.plus-points.negative { background: color-mix(in srgb, var(--bad) 14%, transparent); color: var(--bad); }
.grade-subjects { display: grid; gap: 10px; }
.grade-row { align-items: center; display: flex; gap: 14px; justify-content: space-between; padding: 14px; }
.grade-row h3 { margin: 0; }
.grade-row p { color: var(--muted); margin: 4px 0 0; }
.grade-bubble { align-items: center; border-radius: 10px; display: grid; min-width: 76px; padding: 10px; text-align: center; }
.grade-bubble strong { font-size: 1.45rem; }
.grade-bubble span { font-size: 0.8rem; font-weight: 900; }
.grade-row.good .grade-bubble { background: color-mix(in srgb, var(--good) 14%, transparent); color: var(--good); }
.grade-row.ok .grade-bubble { background: color-mix(in srgb, var(--ok) 16%, transparent); color: #b45309; }
.grade-row.bad .grade-bubble { background: color-mix(in srgb, var(--bad) 14%, transparent); color: var(--bad); }
.planner-layout { grid-template-columns: 1fr; }
.calendar-panel { overflow: hidden; }
.calendar-header { align-items: center; gap: 12px; }
.calendar-header-actions { align-items: center; display: flex; gap: 8px; }
.round-add { background: var(--accent); border: 0; border-radius: 50%; box-shadow: 0 12px 28px color-mix(in srgb, var(--accent) 26%, transparent); color: var(--white); cursor: pointer; font-size: 1.45rem; font-weight: 700; height: 44px; line-height: 1; width: 44px; }
.weekdays, .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); }
.weekdays { color: var(--muted); font-size: 0.74rem; font-weight: 900; margin-bottom: 8px; text-align: center; }
.calendar-grid { gap: 6px; }
.calendar-cell { aspect-ratio: 1 / 1; background: var(--panel-2); border: 1px solid var(--line); border-radius: 8px; min-width: 0; overflow: hidden; padding: 7px; }
.calendar-cell strong { display: block; font-size: 0.86rem; margin-bottom: 4px; }
.calendar-cell span { background: var(--accent-soft); border-radius: 999px; color: var(--accent); display: block; font-size: 0.62rem; font-weight: 850; margin-top: 3px; overflow: hidden; padding: 3px 5px; text-overflow: ellipsis; white-space: nowrap; }
.calendar-cell.today { border-color: var(--accent); box-shadow: inset 0 0 0 2px color-mix(in srgb, var(--accent) 16%, transparent); }
.calendar-cell.empty { background: transparent; border-color: transparent; }
.event-form-wrap { display: none; margin-bottom: 14px; }
.event-form-wrap.show { display: block; }
.agenda-list article { align-items: flex-start; }
.goal-builder { margin-top: 14px; }
.goal-inline-form .wide { grid-column: 1 / -1; }
.subject-deck-grid { display: grid; gap: 12px; grid-template-columns: 1fr; }
.subject-deck { align-items: center; background: var(--panel-2); border: 1px solid var(--line); border-radius: 12px; color: var(--ink); cursor: pointer; display: grid; gap: 4px; grid-template-columns: 78px 1fr auto; min-height: 104px; padding: 14px; text-align: left; width: 100%; }
.subject-deck:hover { border-color: color-mix(in srgb, var(--accent) 38%, var(--line)); transform: translateY(-1px); }
.subject-deck span { font-size: 1.05rem; font-weight: 900; }
.subject-deck strong, .subject-deck small { color: var(--muted); display: block; grid-column: 2; }
.quizlet-stack { height: 66px; position: relative; width: 66px; }
.quizlet-stack i { background: var(--panel); border: 1px solid var(--line); border-radius: 9px; box-shadow: var(--shadow-soft); display: block; height: 48px; left: 5px; position: absolute; top: 9px; width: 58px; }
.quizlet-stack i:nth-child(1) { transform: rotate(-8deg) translate(-3px, 1px); }
.quizlet-stack i:nth-child(2) { transform: rotate(3deg) translate(1px, -2px); }
.quizlet-stack i:nth-child(3) { background: linear-gradient(135deg, var(--accent), var(--green)); transform: rotate(0deg); }
.status-deck-grid { display: grid; gap: 12px; grid-template-columns: repeat(3, minmax(0, 1fr)); margin-bottom: 14px; }
.status-deck { border: 1px solid var(--line); border-radius: 12px; min-height: 136px; overflow: hidden; padding: 14px; position: relative; }
.status-deck strong { display: block; font-size: 2.2rem; line-height: 1; margin-top: 40px; position: relative; z-index: 2; }
.status-deck span { font-weight: 900; position: relative; z-index: 2; }
.card-silhouette { border-radius: 10px; height: 74px; opacity: 0.9; position: absolute; right: 10px; top: 12px; transform: rotate(8deg); width: 58px; }
.status-deck.good { background: color-mix(in srgb, var(--good) 12%, var(--panel)); color: var(--good); }
.status-deck.ok { background: color-mix(in srgb, var(--ok) 13%, var(--panel)); color: #b45309; }
.status-deck.bad { background: color-mix(in srgb, var(--bad) 12%, var(--panel)); color: var(--bad); }
.status-deck.good .card-silhouette { background: var(--good); }
.status-deck.ok .card-silhouette { background: var(--ok); }
.status-deck.bad .card-silhouette { background: var(--bad); }

.cards-top { margin-bottom: 14px; }
.study-card { background: var(--panel-2); border: 1px solid var(--line); border-radius: 12px; min-height: 238px; padding: 18px; }
.study-card.good { border-color: color-mix(in srgb, var(--good) 34%, var(--line)); }
.study-card.ok { border-color: color-mix(in srgb, var(--ok) 34%, var(--line)); }
.study-card.bad { border-color: color-mix(in srgb, var(--bad) 34%, var(--line)); }
.study-card h3 { font-size: 1.35rem; line-height: 1.25; margin: 12px 0 0; }
details { margin-top: 20px; }
summary { color: var(--accent); cursor: pointer; font-weight: 850; }
details p { color: var(--muted); line-height: 1.5; margin-bottom: 0; }
.button-row { display: grid; gap: 10px; grid-template-columns: 1fr; margin-top: 12px; }
.subject-detail { margin-bottom: 14px; }
.mini-card-list { grid-template-columns: 1fr; }
.mini-card { padding: 14px; }
.mini-card span { border-radius: 999px; display: inline-flex; font-size: 0.76rem; font-weight: 900; margin-bottom: 10px; padding: 6px 9px; }
.mini-card.good span { background: color-mix(in srgb, var(--good) 14%, transparent); color: var(--good); }
.mini-card.ok span { background: color-mix(in srgb, var(--ok) 16%, transparent); color: #b45309; }
.mini-card.bad span { background: color-mix(in srgb, var(--bad) 14%, transparent); color: var(--bad); }
.mini-card h3 { font-size: 1rem; line-height: 1.35; margin: 0; }
.mini-card p { color: var(--muted); line-height: 1.45; }
.mini-card small { color: var(--muted); }
.database-panel { margin-top: 14px; }
.library-grid { display: grid; gap: 12px; grid-template-columns: 1fr; }
.library-pack { background: var(--panel-2); border: 1px solid var(--line); border-radius: 12px; padding: 14px; }
.library-pack h3 { margin: 5px 0 8px; }
.library-pack p { color: var(--muted); line-height: 1.45; margin: 0 0 12px; }
.library-pack small { color: var(--muted); display: block; margin: 8px 0 12px; }
.pack-meter { background: color-mix(in srgb, var(--muted) 16%, transparent); border-radius: 999px; height: 8px; overflow: hidden; }
.pack-meter i { background: linear-gradient(90deg, var(--accent), var(--green)); display: block; height: 100%; }
.bot-layout { grid-template-columns: 1fr; }
.check-list, .price-card ul { color: var(--muted); line-height: 1.7; margin: 0; padding-left: 20px; }
.usage-meter { margin-top: 18px; }
.usage-meter span { color: var(--muted); display: block; font-size: 0.86rem; font-weight: 750; margin-bottom: 8px; }
.usage-meter div { background: color-mix(in srgb, var(--muted) 16%, transparent); border-radius: 999px; height: 9px; overflow: hidden; }
.usage-meter i { background: var(--green); display: block; height: 100%; }
.chat-panel { display: grid; gap: 12px; }
.chat-log { display: flex; flex-direction: column; gap: 10px; max-height: 460px; min-height: 420px; overflow-y: auto; padding-right: 4px; }
.message { border-radius: 12px; max-width: 86%; padding: 12px 13px; }
.message p { line-height: 1.48; margin: 0; }
.message.bot { align-self: flex-start; background: transparent; color: var(--ink); max-width: min(100%, 820px); padding: 0; }
.message.user { align-self: flex-end; background: var(--accent); color: var(--white); }
.chat-form { align-items: end; display: grid; gap: 10px; }
.premium-grid { margin-bottom: 14px; }
.price-card h2 { margin: 4px 0 8px; }
.price-card strong { display: block; font-size: 2rem; margin-bottom: 14px; }
.price-card ul { margin-bottom: 18px; }
.price-card.featured { background: linear-gradient(160deg, color-mix(in srgb, var(--accent) 10%, var(--panel)), color-mix(in srgb, var(--green) 9%, var(--panel))); border-color: color-mix(in srgb, var(--accent) 25%, var(--line)); }
.customize-panel.locked { opacity: 0.72; }
.custom-grid { display: grid; gap: 12px; grid-template-columns: 1fr; }

.premium-intro {
  margin-bottom: 14px;
}

.premium-intro p {
  font-size: 1.05rem;
  font-weight: 850;
  line-height: 1.45;
  margin: 0 0 8px;
}

.premium-intro small {
  color: var(--muted);
  display: block;
  line-height: 1.45;
}

.three-plans {
  grid-template-columns: 1fr;
}

.plan-stack {
  display: grid;
  gap: 14px;
  grid-template-columns: 1fr !important;
}

.plan-card {
  border-radius: 16px;
  min-height: 100%;
  position: relative;
}

.plan-card h2 {
  font-size: 1.65rem;
}

.plan-card > strong {
  font-size: 1.9rem;
}

.plan-card.featured {
  border-color: color-mix(in srgb, var(--accent) 38%, var(--line));
  box-shadow: var(--shadow);
  transform: translateY(-2px);
}

.plan-card.pro-card {
  background: linear-gradient(160deg, var(--panel), color-mix(in srgb, var(--ink) 5%, var(--panel)));
  border-color: color-mix(in srgb, var(--ink) 14%, var(--line));
}

.plan-badge {
  background: var(--accent);
  border-radius: 999px;
  color: var(--white);
  font-size: 0.72rem;
  font-style: normal;
  font-weight: 950;
  padding: 6px 10px;
  position: absolute;
  right: 14px;
  top: 14px;
}

.pro-feature-panel.locked,
.locked-feature {
  opacity: 0.78;
}

.locked-upload {
  cursor: not-allowed;
  opacity: 0.75;
}

@media (min-width: 860px) {
  .three-plans {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}
.sr-only { height: 1px; margin: -1px; overflow: hidden; padding: 0; position: absolute; width: 1px; }
.bottom-nav { background: color-mix(in srgb, var(--panel) 94%, transparent); border-top: 1px solid var(--line); bottom: 0; display: grid; gap: 4px; grid-template-columns: repeat(6, 1fr); left: 0; padding: 8px 6px 10px; position: fixed; right: 0; z-index: 30; backdrop-filter: blur(18px); }
.bottom-nav a { align-items: center; border-radius: 10px; color: var(--muted); display: grid; font-size: 0.66rem; font-weight: 850; gap: 2px; justify-items: center; min-height: 54px; }
.bottom-nav a.active { background: var(--accent-soft); color: var(--accent); }
.nav-icon { font-size: 1.05rem; line-height: 1; }
@media (min-width: 680px) {
  .sync-state { display: flex; }
  .main-content { padding: 34px 22px 42px; }
  .premium-hero { align-items: end; grid-template-columns: 1fr auto; padding: 30px; }
  .focus-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .quiet-strip { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .work-grid, .bot-layout, .pricing-grid, .planner-layout { grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.2fr); }
  .grade-shell { grid-template-columns: minmax(260px, 0.75fr) minmax(0, 1.25fr); }
  .grades-forms, .cards-top { grid-template-columns: minmax(280px, 0.8fr) minmax(0, 1.2fr); }
  .form-row, .inline-form, .button-row, .custom-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .subject-deck-grid, .library-grid, .mini-card-list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .chat-form { grid-template-columns: 1fr auto; }
  .goal-inline-form { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .bottom-nav { border: 1px solid var(--line); border-radius: 14px; bottom: 18px; box-shadow: var(--shadow); left: 50%; max-width: 760px; padding: 8px; right: auto; transform: translateX(-50%); width: calc(100% - 32px); }
}

@media (min-width: 980px) {
  .app-shell { padding-bottom: 112px; }
  .focus-grid { grid-template-columns: 1.3fr repeat(3, minmax(0, 0.9fr)); }
  .work-grid { grid-template-columns: minmax(300px, 0.76fr) minmax(0, 1.24fr); }
  .subject-deck-grid, .library-grid, .mini-card-list { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .custom-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
}

@media (max-width: 420px) {
  .top-icon-button { font-size: 0.7rem; padding: 0 8px; }
  .brand small { display: none; }
  .brand { gap: 7px; }
  .brand-mascot { height: 38px; width: 38px; }
  .logo.brand-mascot svg { height: 34px; width: 34px; }
  .streak-pill { min-height: 30px; padding: 4px 8px 4px 5px; }
  .streak-flame { height: 19px; width: 19px; }
  .premium-hero { padding: 18px; }
  .hero-score strong { font-size: 2.5rem; }
  .calendar-cell { padding: 5px; }
  .calendar-cell span { font-size: 0.56rem; }
  .status-deck-grid { gap: 8px; }
  .status-deck { min-height: 120px; padding: 10px; }
  .status-deck strong { font-size: 1.8rem; }
}

@media (prefers-reduced-motion: reduce) {
  .mascot-floating .mascot-face,
  .mascot-floating .mascot-eye,
  .page-enter > *,
  .xp-toast,
  .xp-pill.gain,
  .tool-button.listening .icon {
    animation: none !important;
  }

  .xp-toast {
    opacity: 1;
    transform: none;
  }
}

/* Lynxly v187 premium study system */
:root {
  --space-1: 6px;
  --space-2: 10px;
  --space-3: 14px;
  --space-4: 18px;
  --space-5: 24px;
  --space-6: 32px;
  --radius-control: 14px;
  --radius-card: 24px;
  --radius-hero: 30px;
  --premium-bg: #070b16;
  --premium-surface: #111a2a;
  --premium-surface-soft: #162136;
  --premium-text: #f5f7ff;
  --premium-muted: #a8b3c7;
  --premium-line: rgba(148, 163, 184, 0.18);
  --premium-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
}

body:not(.is-locked) {
  --ink: var(--premium-text);
  --muted: var(--premium-muted);
  --line: var(--premium-line);
  --soft: var(--premium-bg);
  --panel: var(--premium-surface);
  --panel-2: var(--premium-surface-soft);
  --shadow: var(--premium-shadow);
  --shadow-soft: 0 16px 38px rgba(0, 0, 0, 0.2);
  background:
    radial-gradient(circle at 80% -12%, color-mix(in srgb, var(--accent) 20%, transparent), transparent 30rem),
    linear-gradient(180deg, #090e1b, var(--premium-bg) 68%);
  color: var(--premium-text);
}

body:not(.is-locked) .app-shell {
  background: transparent;
}

body:not(.is-locked) .main-content {
  max-width: 760px;
  padding: 24px 18px 132px;
}

body:not(.is-locked) .section-heading {
  margin-bottom: var(--space-5);
}

body:not(.is-locked) .section-heading h1,
body:not(.is-locked) .mistake-header h1,
body:not(.is-locked) .grade-page-header h1,
body:not(.is-locked) .ai-full-page > h1 {
  color: var(--premium-text);
  font-size: clamp(2rem, 8vw, 3.2rem);
  font-weight: 920;
  letter-spacing: 0;
  line-height: 1.04;
}

body:not(.is-locked) .panel,
body:not(.is-locked) .focus-card,
body:not(.is-locked) .stat-card,
body:not(.is-locked) .price-card,
body:not(.is-locked) .item-card,
body:not(.is-locked) .subject-card,
body:not(.is-locked) .goal-card,
body:not(.is-locked) .mini-card,
body:not(.is-locked) .grade-overview-card,
body:not(.is-locked) .grade-row,
body:not(.is-locked) .study-hub-card,
body:not(.is-locked) .ai-study-builder,
body:not(.is-locked) .planner-coach-card,
body:not(.is-locked) .mistake-coach-panel,
body:not(.is-locked) .learning-metric-grid article,
body:not(.is-locked) .level-card,
body:not(.is-locked) .challenge-card,
body:not(.is-locked) .team-goal-card,
body:not(.is-locked) .class-league-hero,
body:not(.is-locked) .notification-center {
  background: color-mix(in srgb, var(--premium-surface) 96%, var(--accent) 4%);
  border: 1px solid var(--premium-line);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-soft);
}

body:not(.is-locked) .panel,
body:not(.is-locked) .price-card {
  padding: var(--space-4);
}

body:not(.is-locked) .primary-button,
body:not(.is-locked) .secondary-button,
body:not(.is-locked) .icon-button {
  border-radius: var(--radius-control);
  min-height: 46px;
}

body:not(.is-locked) .primary-button {
  background: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 76%, #bda4ff));
  box-shadow: 0 14px 32px color-mix(in srgb, var(--accent) 24%, transparent);
}

body:not(.is-locked) .secondary-button,
body:not(.is-locked) .icon-button {
  background: rgba(255, 255, 255, 0.045);
  border-color: var(--premium-line);
  color: var(--premium-text);
}

body:not(.is-locked) input,
body:not(.is-locked) select,
body:not(.is-locked) textarea {
  background: rgba(255, 255, 255, 0.045);
  border-color: var(--premium-line);
  border-radius: var(--radius-control);
  color: var(--premium-text);
}

body:not(.is-locked) input::placeholder,
body:not(.is-locked) textarea::placeholder {
  color: #78869c;
}

body:not(.is-locked) .bottom-nav {
  background: rgba(17, 26, 42, 0.94);
  border: 1px solid var(--premium-line);
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.38);
}

body:not(.is-locked) .bottom-nav a {
  color: #91a0b6;
}

body:not(.is-locked) .bottom-nav a.active {
  color: color-mix(in srgb, var(--accent) 42%, #ffffff);
}

body:not(.is-locked) .empty-state {
  background: rgba(255, 255, 255, 0.035);
  border: 1px dashed color-mix(in srgb, var(--accent) 25%, var(--premium-line));
  border-radius: var(--radius-card);
  color: var(--premium-muted);
  padding: var(--space-5);
}

body:not(.is-locked) .study-hub-card,
body:not(.is-locked) .planner-coach-card,
body:not(.is-locked) .mistake-coach-panel {
  grid-template-columns: 1fr;
  padding: var(--space-5);
}

body:not(.is-locked) .study-hub-actions,
body:not(.is-locked) .mistake-coach-actions {
  justify-content: stretch;
  max-width: none;
}

body:not(.is-locked) .study-hub-actions > *,
body:not(.is-locked) .mistake-coach-actions > * {
  flex: 1 1 150px;
}

body:not(.is-locked) .cards-search-shell,
body:not(.is-locked) .settings-tabs,
body:not(.is-locked) .session-progress,
body:not(.is-locked) .test-setup-panel,
body:not(.is-locked) .test-list-question,
body:not(.is-locked) .mode-question-card,
body:not(.is-locked) .session-mini-status,
body:not(.is-locked) .ai-window {
  background: color-mix(in srgb, var(--premium-surface) 94%, var(--accent) 6%);
  border-color: var(--premium-line);
  border-radius: var(--radius-card);
}

.mistake-review-session {
  display: grid;
  gap: var(--space-4);
  margin: 0 auto;
  max-width: 680px;
}

.focused-session-progress {
  align-items: center;
  display: grid;
  gap: var(--space-2);
  grid-template-columns: auto minmax(0, 1fr);
}

.focused-session-progress > span {
  color: var(--premium-muted);
  font-size: 0.8rem;
  font-weight: 900;
}

.focused-session-progress > div {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 999px;
  height: 7px;
  overflow: hidden;
}

.focused-session-progress i {
  background: var(--accent);
  border-radius: inherit;
  display: block;
  height: 100%;
  transition: width 260ms ease;
}

.session-recommendation {
  color: var(--premium-muted);
  font-size: 0.86rem;
  line-height: 1.5;
  margin: 0;
}

.mistake-review-card {
  background:
    radial-gradient(circle at 90% 0%, color-mix(in srgb, var(--accent) 18%, transparent), transparent 42%),
    var(--premium-surface);
  border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--premium-line));
  border-radius: var(--radius-hero);
  box-shadow: var(--premium-shadow);
  display: grid;
  gap: var(--space-4);
  min-height: 390px;
  padding: clamp(22px, 6vw, 34px);
}

.mistake-review-card > span {
  color: color-mix(in srgb, var(--accent) 45%, #ffffff);
  font-size: 0.75rem;
  font-weight: 900;
  text-transform: uppercase;
}

.mistake-review-card h2 {
  color: var(--premium-text);
  font-size: clamp(1.45rem, 7vw, 2.2rem);
  line-height: 1.18;
  margin: 0;
}

.mistake-review-card form {
  align-content: end;
  display: grid;
  flex: 1;
}

.mistake-review-feedback,
.mistake-review-explanation {
  background: rgba(255, 255, 255, 0.045);
  border: 1px solid var(--premium-line);
  border-radius: 18px;
  padding: 16px;
}

.mistake-review-feedback.correct {
  border-color: color-mix(in srgb, var(--good) 42%, var(--premium-line));
}

.mistake-review-feedback.wrong {
  border-color: color-mix(in srgb, var(--bad) 42%, var(--premium-line));
}

.mistake-review-feedback p,
.mistake-review-explanation p {
  color: var(--premium-muted);
  line-height: 1.55;
  margin: 7px 0 0;
}

.mistake-review-explanation span,
.mistake-review-explanation strong {
  display: block;
}

.mistake-review-explanation span {
  color: var(--accent);
  font-size: 0.72rem;
  font-weight: 900;
  margin-bottom: 6px;
  text-transform: uppercase;
}

.mistake-review-actions,
.focused-summary .continue-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.mistake-review-actions > *,
.focused-summary .continue-actions > * {
  flex: 1 1 180px;
}

.text-action {
  background: transparent;
  border: 0;
  color: color-mix(in srgb, var(--accent) 45%, #ffffff);
  cursor: pointer;
  font-weight: 850;
  min-height: 44px;
  padding: 0;
  text-align: left;
}

.focused-summary {
  align-items: start;
  display: grid;
  gap: var(--space-4);
  padding: var(--space-5);
}

.srs-rating-grid .srs-rating {
  align-items: center;
  display: flex;
  gap: 7px;
  justify-content: center;
  min-height: 50px;
}

.srs-rating kbd {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 6px;
  color: inherit;
  font: inherit;
  font-size: 0.7rem;
  padding: 2px 6px;
}

.ai-file-status.generating {
  border-color: color-mix(in srgb, var(--accent) 45%, var(--premium-line));
}

.ai-file-status.generating::after {
  animation: aiStatusPulse 1.1s ease-in-out infinite;
  background: var(--accent);
  border-radius: 999px;
  content: "";
  height: 4px;
  margin-top: 7px;
  transform-origin: left;
  width: 100%;
}

@keyframes aiStatusPulse {
  0%, 100% { opacity: 0.25; transform: scaleX(0.2); }
  50% { opacity: 0.9; transform: scaleX(1); }
}

@media (min-width: 820px) {
  body:not(.is-locked) .main-content {
    max-width: 920px;
    padding-top: 34px;
  }

  body:not(.is-locked) .planner-layout,
  body:not(.is-locked) .grade-shell {
    gap: var(--space-5);
  }
}

@media (max-width: 520px) {
  body:not(.is-locked) .main-content {
    padding-inline: 14px;
  }

  .mistake-review-card {
    min-height: 360px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .focused-session-progress i,
  .ai-file-status.generating::after {
    animation: none;
    transition: none;
  }
}

@keyframes pageIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes softPulse {
  0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 24%, transparent); }
  100% { box-shadow: 0 0 0 10px transparent; }
}

@keyframes lynxIdle {
  0%, 86%, 100% { transform: translateY(0) scale(1); }
  90% { transform: translateY(-2px) scale(1.015); }
  94% { transform: translateY(0) scale(1); }
}

@keyframes lynxBlink {
  0%, 88%, 94%, 100% { stroke-width: 2.6; }
  91% { stroke-width: 4.3; }
}

.page-enter > * {
  animation: pageIn 260ms ease both;
}

.top-icon-button {
  align-items: center;
  display: inline-flex;
  gap: 7px;
}

.top-icon-button > span:first-child {
  align-items: center;
  background: var(--accent-soft);
  border-radius: 999px;
  color: var(--accent);
  display: inline-flex;
  font-size: 0.86rem;
  height: 22px;
  justify-content: center;
  width: 22px;
}

.home-surface {
  align-items: end;
  background:
    linear-gradient(135deg, color-mix(in srgb, var(--accent) 10%, var(--panel)), var(--panel) 52%, color-mix(in srgb, var(--green) 9%, var(--panel)));
  border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
  border-radius: 14px;
  box-shadow: var(--shadow);
  display: grid;
  gap: 18px;
  margin-bottom: 14px;
  padding: 22px;
}

.home-copy h1 {
  font-size: clamp(3rem, 18vw, 6.8rem);
  line-height: 0.92;
  margin: 6px 0 10px;
}

.home-copy p {
  color: var(--muted);
  line-height: 1.55;
  margin: 0;
  max-width: 520px;
}

.home-mini-score {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 12px;
  box-shadow: var(--shadow-soft);
  min-width: 170px;
  padding: 16px;
}

.home-mini-score span,
.account-card span,
.language-pill span {
  color: var(--green);
  display: block;
  font-size: 0.76rem;
  font-weight: 900;
  text-transform: uppercase;
}

.home-mini-score strong {
  display: block;
  font-size: 3rem;
  line-height: 1;
  margin: 5px 0;
}

.home-mini-score small,
.account-card small,
.language-pill small {
  color: var(--muted);
  display: block;
  line-height: 1.35;
}

.home-focus-grid,
.home-bottom-grid,
.grade-system-grid,
.photo-card-controls {
  display: grid;
  gap: 14px;
}

.latest-card,
.recommendation-card {
  min-height: 220px;
}

.latest-card {
  background: linear-gradient(160deg, var(--panel), color-mix(in srgb, var(--accent) 10%, var(--panel)));
}

.recommendation-card {
  background: linear-gradient(160deg, var(--panel), color-mix(in srgb, var(--green) 11%, var(--panel)));
}

.account-card {
  align-items: center;
  display: grid;
  gap: 12px;
  grid-template-columns: auto 1fr;
}

.account-card .secondary-button {
  grid-column: 1 / -1;
}

.account-avatar {
  align-items: center;
  background: var(--accent-soft);
  border-radius: 14px;
  color: var(--accent);
  display: grid;
  height: 54px;
  place-items: center;
  width: 54px;
}

.login-card .primary-button,
.notification-card .secondary-button {
  width: 100%;
}

.grade-system-panel {
  margin-bottom: 14px;
}

.language-pill {
  align-self: end;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 10px;
  min-height: 76px;
  padding: 12px;
}

.language-pill strong {
  display: block;
  font-size: 1.25rem;
  margin: 3px 0;
}

.pluspoints-card {
  min-height: 250px;
}

button:disabled,
select:disabled,
input:disabled,
textarea:disabled {
  cursor: not-allowed;
  opacity: 0.52;
}

.check-field {
  align-items: center;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 9px;
  display: flex;
  gap: 10px;
  min-height: 46px;
  padding: 10px 12px;
}

.check-field input {
  min-height: auto;
  width: auto;
}

.exam-builder {
  margin-top: 14px;
}

.calendar-cell .exam-dot,
.exam-agenda .date-pill {
  background: color-mix(in srgb, var(--bad) 14%, transparent);
  color: var(--bad);
}

.photo-card-panel {
  margin-bottom: 14px;
}

.upload-tile,
.tool-button {
  align-items: center;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 10px;
  color: var(--ink);
  cursor: pointer;
  display: inline-flex;
  font-weight: 850;
  gap: 9px;
  justify-content: center;
  min-height: 48px;
  padding: 0 14px;
}

.upload-tile input,
.tool-button input {
  height: 1px;
  opacity: 0;
  overflow: hidden;
  padding: 0;
  position: absolute;
  width: 1px;
}

.upload-tile:hover,
.tool-button:hover,
.subject-deck:hover,
.secondary-button:hover {
  border-color: color-mix(in srgb, var(--accent) 38%, var(--line));
}

.tool-button.listening {
  background: color-mix(in srgb, var(--bad) 12%, var(--panel));
  border-color: color-mix(in srgb, var(--bad) 42%, var(--line));
  color: var(--bad);
}

.tool-button.listening .icon {
  animation: voicePulse 1.1s ease-in-out infinite;
}

.publish-panel {
  align-items: center;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 12px;
  display: grid;
  gap: 12px;
  margin-bottom: 14px;
  padding: 14px;
}

.publish-panel strong {
  display: block;
}

.publish-panel p {
  color: var(--muted);
  line-height: 1.45;
  margin: 3px 0 0;
}

.flip-card {
  border: 1px solid var(--line);
  color: var(--ink);
  cursor: pointer;
  display: block;
  perspective: 1100px;
  text-align: left;
  width: 100%;
}

.flip-inner {
  min-height: 150px;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 420ms cubic-bezier(.2, .8, .2, 1);
}

.flip-card.flipped .flip-inner {
  transform: rotateY(180deg);
}

.flip-face {
  backface-visibility: hidden;
  display: grid;
  inset: 0;
  min-height: 150px;
  padding-top: 8px;
  position: absolute;
}

.flip-face h3 {
  align-self: center;
  margin: 0;
}

.flip-face small {
  align-self: end;
  color: var(--muted);
  font-weight: 850;
}

.flip-face.back {
  transform: rotateY(180deg);
}

.ai-chat-panel {
  padding: 0;
  overflow: hidden;
}

.ai-chat-panel .chat-log {
  padding: 16px 16px 0;
}

.ai-composer {
  background: color-mix(in srgb, var(--panel) 90%, var(--accent-soft));
  border-top: 1px solid var(--line);
  display: grid;
  gap: 10px;
  padding: 12px;
}

.ai-composer textarea {
  background: var(--panel);
  border-radius: 12px;
  min-height: 70px;
}

.composer-tools {
  align-items: center;
  display: grid;
  gap: 8px;
  grid-template-columns: auto auto 1fr;
}

.composer-tools .primary-button {
  justify-self: stretch;
}

.attachment-pill {
  align-items: center;
  background: var(--accent-soft);
  border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--line));
  border-radius: 999px;
  color: var(--accent);
  display: inline-flex;
  font-size: 0.84rem;
  font-weight: 850;
  gap: 7px;
  padding: 8px 10px;
  width: fit-content;
}

.round-add {
  animation: softPulse 1400ms ease-out 1;
}

@media (min-width: 680px) {
  .home-surface {
    grid-template-columns: 1fr auto;
    padding: 30px;
  }

  .home-focus-grid,
  .home-bottom-grid,
  .grade-system-grid,
  .photo-card-controls {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .latest-card {
    min-height: 250px;
  }

  .account-card {
    grid-template-columns: auto 1fr auto;
  }

  .account-card .secondary-button {
    grid-column: auto;
  }

  .publish-panel {
    grid-template-columns: 1fr auto;
  }
}

@media (min-width: 980px) {
  .home-focus-grid {
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.75fr);
  }
}

.is-locked .bottom-nav,
.is-locked .top-actions,
.is-locked .streak-pill {
  display: none;
}

.onboarding-screen {
  display: grid;
  gap: 20px;
  margin: 0 auto;
  max-width: 520px;
  min-height: calc(100vh - 120px);
  place-content: center;
}

.onboarding-logo {
  text-align: center;
}

.onboarding-logo .logo {
  margin: 0 auto 14px;
}

.onboarding-logo h1 {
  font-size: clamp(2.6rem, 14vw, 5rem);
  line-height: 0.95;
  margin: 0;
}

.onboarding-logo p {
  color: var(--muted);
  font-weight: 800;
  margin: 8px 0 0;
}

.onboarding-card {
  border-radius: 16px;
  padding: 18px;
}

.text-button {
  align-items: center;
  background: transparent;
  border: 0;
  color: color-mix(in srgb, var(--accent) 82%, var(--ink));
  cursor: pointer;
  display: inline-flex;
  font-weight: 900;
  justify-content: center;
  min-height: 44px;
  padding: 0 12px;
}

.value-onboarding {
  color: #f8fafc;
  max-width: none;
  min-height: 100vh;
  overflow: hidden;
  padding: 26px 16px;
  position: relative;
}

.value-onboarding::before {
  background:
    radial-gradient(circle at 18% 8%, rgba(124, 58, 237, 0.32), transparent 32%),
    radial-gradient(circle at 88% 28%, rgba(16, 185, 129, 0.18), transparent 28%),
    linear-gradient(180deg, #080b16 0%, #101729 56%, #080b16 100%);
  content: "";
  inset: 0;
  position: fixed;
  z-index: -2;
}

.onboarding-glow {
  background: radial-gradient(circle, rgba(124, 58, 237, 0.22), transparent 62%);
  filter: blur(10px);
  height: 320px;
  left: 50%;
  pointer-events: none;
  position: fixed;
  top: 8%;
  transform: translateX(-50%);
  width: min(620px, 92vw);
  z-index: -1;
}

.value-onboarding-shell {
  display: grid;
  gap: 16px;
  margin: 0 auto;
  max-width: 520px;
  width: 100%;
}

.value-onboarding-brand {
  align-items: center;
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-bottom: 4px;
}

.value-onboarding-brand img {
  background: #05070d;
  border-radius: 16px;
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.34);
  display: block;
  height: 48px;
  object-fit: contain;
  width: 48px;
}

.value-onboarding-brand strong {
  font-size: 1.28rem;
}

.onboarding-step-dots {
  align-items: center;
  display: flex;
  gap: 8px;
  justify-content: center;
}

.onboarding-step-dots i {
  background: rgba(148, 163, 184, 0.26);
  border-radius: 999px;
  display: block;
  height: 7px;
  transition: width 220ms ease, background 220ms ease;
  width: 20px;
}

.onboarding-step-dots i.active {
  background: linear-gradient(90deg, #8b5cf6, #22c55e);
  width: 34px;
}

.value-onboarding-card {
  background: linear-gradient(180deg, rgba(18, 27, 42, 0.92), rgba(15, 23, 42, 0.88));
  border: 1px solid rgba(148, 163, 184, 0.20);
  border-radius: 30px;
  box-shadow: 0 28px 80px rgba(0, 0, 0, 0.42);
  display: grid;
  gap: 16px;
  overflow: hidden;
  padding: clamp(22px, 6vw, 34px);
  position: relative;
}

.value-onboarding-card::after {
  background: radial-gradient(circle, rgba(124, 58, 237, 0.24), transparent 60%);
  border-radius: 999px;
  content: "";
  height: 190px;
  position: absolute;
  right: -94px;
  top: -94px;
  width: 190px;
}

.value-onboarding-card > * {
  position: relative;
  z-index: 1;
}

.value-onboarding-card h1 {
  color: #f8fafc;
  font-size: clamp(2rem, 9vw, 3.35rem);
  letter-spacing: 0;
  line-height: 1.02;
  margin: 0;
}

.value-onboarding-card p {
  color: #b8c3d4;
  font-size: 1rem;
  line-height: 1.55;
  margin: 0;
}

.onboarding-kicker {
  color: #34d399;
  font-size: 0.76rem;
  font-weight: 950;
  letter-spacing: 0;
  text-transform: uppercase;
}

.promise-card {
  min-height: 520px;
  place-content: end;
}

.promise-card .mascot-floating {
  justify-self: start;
}

.promise-card .mascot-face {
  border: 1px solid rgba(255, 255, 255, 0.14);
  box-shadow: 0 18px 42px rgba(0, 0, 0, 0.34);
  height: 78px;
  width: 78px;
}

.value-pill-grid,
.onboarding-create-list,
.preview-metric-grid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.value-pill-grid span,
.onboarding-create-list span {
  background: rgba(255, 255, 255, 0.07);
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 999px;
  color: #e2e8f0;
  font-size: 0.88rem;
  font-weight: 900;
  padding: 10px 12px;
  text-align: center;
}

.onboarding-actions.compact,
.continue-actions.compact {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.value-onboarding .primary-button {
  background: linear-gradient(135deg, #7c3aed, #22c55e);
  border-radius: 16px;
  box-shadow: 0 18px 42px rgba(124, 58, 237, 0.28);
  color: #fff;
  min-height: 52px;
}

.value-onboarding .secondary-button {
  background: rgba(255, 255, 255, 0.07);
  border-color: rgba(148, 163, 184, 0.22);
  border-radius: 16px;
  color: #f8fafc;
}

.value-onboarding .text-button {
  color: #c4b5fd;
}

.onboarding-choice-grid {
  display: grid;
  gap: 12px;
}

.onboarding-choice {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(148, 163, 184, 0.20);
  border-radius: 20px;
  color: #f8fafc;
  cursor: pointer;
  display: grid;
  gap: 5px;
  margin: 0;
  min-height: 74px;
  padding: 15px;
}

.onboarding-choice input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.onboarding-choice small {
  color: #aebbd0;
  font-weight: 800;
  line-height: 1.35;
}

.onboarding-choice.selected,
.onboarding-choice:has(input:checked) {
  background: rgba(124, 58, 237, 0.22);
  border-color: rgba(167, 139, 250, 0.72);
  box-shadow: inset 0 0 0 1px rgba(167, 139, 250, 0.22);
}

.value-onboarding label {
  color: #dbeafe;
}

.value-onboarding label small {
  color: #94a3b8;
  font-size: 0.74rem;
}

.value-onboarding input,
.value-onboarding textarea {
  background: rgba(255, 255, 255, 0.07);
  border-color: rgba(148, 163, 184, 0.23);
  border-radius: 16px;
  color: #f8fafc;
}

.value-onboarding input::placeholder,
.value-onboarding textarea::placeholder {
  color: rgba(226, 232, 240, 0.54);
}

.onboarding-upload-tile {
  align-items: center;
  background: rgba(34, 197, 94, 0.10);
  border: 1px dashed rgba(52, 211, 153, 0.52);
  border-radius: 20px;
  color: #d1fae5;
  cursor: pointer;
  display: flex;
  font-weight: 950;
  gap: 10px;
  justify-content: center;
  margin: 0;
  min-height: 84px;
}

.onboarding-upload-tile input {
  clip: rect(0 0 0 0);
  height: 1px;
  overflow: hidden;
  position: absolute;
  white-space: nowrap;
  width: 1px;
}

.onboarding-status {
  background: rgba(255, 255, 255, 0.07);
  border: 1px solid rgba(148, 163, 184, 0.16);
  border-radius: 16px;
  color: #cbd5e1 !important;
  padding: 12px;
}

.preview-metric-grid article {
  background: rgba(255, 255, 255, 0.07);
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 20px;
  min-height: 104px;
  padding: 16px;
}

.preview-metric-grid strong {
  color: #f8fafc;
  display: block;
  font-size: 2rem;
  line-height: 1;
  margin-bottom: 7px;
}

.preview-metric-grid span {
  color: #aebbd0;
  font-weight: 900;
}

.auth-choice-list {
  display: grid;
  gap: 10px;
}

.auth-choice-list button {
  justify-content: space-between;
  min-height: 58px;
}

.auth-choice-list small {
  color: #aebbd0;
  font-weight: 800;
}

.plus-trial-card {
  background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 18%, var(--panel)), color-mix(in srgb, var(--green) 12%, var(--panel)));
  border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
  border-radius: 24px;
  box-shadow: var(--shadow);
  display: grid;
  gap: 10px;
  margin-top: 14px;
  padding: 20px;
}

.plus-trial-card span,
.plan-annual,
.plan-beta {
  color: var(--muted);
  display: block;
  font-size: 0.82rem;
  font-weight: 900;
}

.plus-trial-card h2 {
  font-size: 1.55rem;
  margin: 0;
}

.plus-trial-card p {
  color: var(--muted);
  line-height: 1.5;
  margin: 0;
}

.plan-annual {
  background: color-mix(in srgb, var(--green) 12%, var(--panel-2));
  border: 1px solid color-mix(in srgb, var(--green) 22%, var(--line));
  border-radius: 999px;
  color: var(--green);
  display: inline-flex;
  margin: -4px 0 14px;
  padding: 7px 10px;
}

.plan-beta {
  background: color-mix(in srgb, var(--ok) 12%, var(--panel-2));
  border: 1px solid color-mix(in srgb, var(--ok) 22%, var(--line));
  border-radius: 14px;
  color: #b45309;
  line-height: 1.35;
  margin: -4px 0 14px;
  padding: 9px 11px;
}

@media (max-width: 420px) {
  .value-onboarding {
    padding: 16px 12px;
  }

  .value-pill-grid,
  .onboarding-create-list,
  .preview-metric-grid {
    grid-template-columns: 1fr;
  }

  .promise-card {
    min-height: 480px;
  }
}

.section-heading {
  margin-bottom: 14px;
}

.section-heading h1 {
  font-size: clamp(2.3rem, 10vw, 4rem);
  margin-bottom: 0;
}

.clean-home .home-copy h1 {
  margin-bottom: 0;
}

.grades-phone {
  background: #f8fafc;
  border: 1px solid var(--line);
  border-radius: 18px;
  box-shadow: var(--shadow);
  margin: 0 auto 14px;
  max-width: 520px;
  overflow: hidden;
}

html[data-theme="dark"] .grades-phone {
  background: var(--panel);
}

.grades-phone-bar {
  align-items: center;
  background: #ff7a1a;
  color: #fff;
  display: flex;
  justify-content: space-between;
  min-height: 54px;
  padding: 0 14px;
}

.grades-phone-bar strong {
  font-size: 1.12rem;
}

.small-add {
  background: #fff;
  box-shadow: none;
  color: #ff7a1a;
  height: 36px;
  width: 36px;
}

.grades-term {
  border-bottom: 1px solid #e5e7eb;
  color: #ef6c00;
  display: flex;
  font-size: 0.82rem;
  font-weight: 850;
  justify-content: space-between;
  padding: 8px 14px;
}

.pluspoints-list {
  min-height: 300px;
}

.pluspoints-list-row {
  align-items: flex-start;
  border-bottom: 1px solid #e5e7eb;
  display: grid;
  gap: 8px;
  grid-template-columns: 1fr auto auto;
  padding: 11px 14px;
}

.pluspoints-list-row strong {
  display: block;
  font-size: 0.95rem;
}

.pluspoints-list-row small {
  color: #64748b;
  display: block;
  font-size: 0.72rem;
  margin-top: 3px;
}

.pluspoints-list-row small span {
  margin-left: 10px;
}

.pluspoints-list-row > span {
  color: #374151;
  font-weight: 850;
}

.pluspoints-list-row em,
.pluspoints-total strong {
  border-radius: 999px;
  font-size: 0.78rem;
  font-style: normal;
  font-weight: 900;
  padding: 4px 7px;
}

.positive {
  background: color-mix(in srgb, var(--good) 15%, transparent);
  color: var(--good);
}

.negative {
  background: color-mix(in srgb, var(--bad) 15%, transparent);
  color: var(--bad);
}

.pluspoints-total {
  color: #64748b;
  font-size: 0.78rem;
  padding: 12px 14px;
  text-align: right;
}

.empty-grade-list {
  color: #64748b;
  padding: 22px 14px;
}

.grade-compact-tools {
  display: none;
  margin: 0 auto;
  max-width: 760px;
}

.grade-compact-tools.show {
  display: grid;
  gap: 14px;
}

.swiss-rule {
  background: var(--accent-soft);
  border-radius: 10px;
  color: var(--muted);
  font-size: 0.84rem;
  font-weight: 750;
  padding: 12px;
}

.calendar-only-panel {
  margin: 0 auto;
  max-width: 820px;
  position: relative;
}

.calendar-entry-form {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  box-shadow: var(--shadow);
  display: none;
  gap: 10px;
  margin-top: 14px;
  padding: 14px;
}

.calendar-entry-form.show {
  display: grid;
}

.calendar-month-stack {
  display: grid;
  gap: 18px;
}

.month-panel {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 12px;
}

.month-panel h3 {
  font-size: 1rem;
  margin: 0 0 12px;
}

.calendar-cell .homework-dot {
  background: color-mix(in srgb, var(--ok) 16%, transparent);
  color: #b45309;
}

.cards-search-panel {
  margin-bottom: 14px;
}

.search-box {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 999px;
  box-shadow: var(--shadow-soft);
  display: flex;
  gap: 8px;
  min-height: 52px;
  padding: 0 16px;
}

.search-box .icon {
  color: var(--muted);
  flex: 0 0 auto;
}

.search-box input {
  background: transparent;
  border: 0;
  box-shadow: none;
  min-height: 48px;
  padding: 0;
}

.card-stack-board {
  display: grid;
  gap: 14px;
  margin-bottom: 14px;
}

.quizlet-large-stack {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 16px;
  box-shadow: var(--shadow-soft);
  color: var(--ink);
  cursor: pointer;
  display: grid;
  gap: 5px;
  min-height: 230px;
  padding: 18px;
  text-align: left;
}

.quizlet-large-stack:hover {
  border-color: color-mix(in srgb, var(--accent) 34%, var(--line));
  transform: translateY(-2px);
}

.big-card-stack {
  height: 104px;
  margin-bottom: 10px;
  position: relative;
  width: 132px;
}

.big-card-stack i {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 14px;
  box-shadow: var(--shadow-soft);
  display: block;
  height: 82px;
  left: 10px;
  position: absolute;
  top: 12px;
  width: 116px;
}

.big-card-stack i:nth-child(1) { transform: rotate(-8deg) translate(-6px, 4px); }
.big-card-stack i:nth-child(2) { transform: rotate(4deg) translate(3px, -2px); }
.big-card-stack i:nth-child(3) { background: linear-gradient(145deg, var(--accent), var(--green)); transform: rotate(0); }

.quizlet-large-stack strong {
  font-size: 1.2rem;
}

.quizlet-large-stack span,
.quizlet-large-stack small {
  color: var(--muted);
}

.quizlet-large-stack em {
  color: var(--accent);
  font-style: normal;
  font-weight: 900;
  margin-top: 10px;
}

.card-results {
  margin-bottom: 84px;
}

.flashcard-study-area {
  margin-bottom: 14px;
}

.study-flashcard {
  background: transparent;
  border: 0;
  color: var(--ink);
  cursor: pointer;
  display: block;
  min-height: 250px;
  perspective: 1200px;
  position: relative;
  text-align: left;
  width: 100%;
}

.flip-hint {
  color: var(--muted);
  display: block;
  font-size: 0.78rem;
  font-weight: 900;
  margin-bottom: 8px;
  text-align: right;
}

.study-flashcard-inner {
  min-height: 230px;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 420ms cubic-bezier(.2, .8, .2, 1);
}

.study-flashcard.flipped .study-flashcard-inner {
  transform: rotateY(180deg);
}

.study-flashcard-face {
  backface-visibility: hidden;
  background: linear-gradient(145deg, var(--panel), color-mix(in srgb, var(--accent) 8%, var(--panel)));
  border: 1px solid var(--line);
  border-radius: 18px;
  box-shadow: var(--shadow-soft);
  display: grid;
  inset: 0;
  min-height: 230px;
  padding: 22px;
  position: absolute;
}

.study-flashcard-face.back {
  background: linear-gradient(145deg, var(--panel), color-mix(in srgb, var(--green) 10%, var(--panel)));
  transform: rotateY(180deg);
}

.study-flashcard-face small {
  color: var(--muted);
  font-weight: 900;
}

.study-flashcard-face h2 {
  align-self: center;
  font-size: clamp(1.5rem, 7vw, 3rem);
  line-height: 1.12;
  margin: 0;
  overflow-wrap: anywhere;
}

.floating-create-button {
  background: var(--accent);
  border: 0;
  border-radius: 50%;
  bottom: 96px;
  box-shadow: var(--shadow);
  color: #fff;
  cursor: pointer;
  font-size: 2rem;
  height: 58px;
  position: fixed;
  right: 18px;
  width: 58px;
  z-index: 32;
}

.create-card-sheet {
  background: color-mix(in srgb, var(--panel) 96%, transparent);
  border: 1px solid var(--line);
  border-radius: 18px 18px 0 0;
  bottom: 0;
  box-shadow: var(--shadow);
  display: none;
  left: 0;
  max-height: 72vh;
  overflow: auto;
  padding: 16px;
  position: fixed;
  right: 0;
  z-index: 40;
}

.create-card-sheet.show {
  display: block;
}

.create-card-sheet.standalone-create {
  border-radius: 18px;
  bottom: auto;
  display: block;
  left: auto;
  margin: 0 auto;
  max-height: none;
  max-width: 720px;
  overflow: visible;
  position: static;
  right: auto;
  transform: none;
  width: 100%;
}

.create-sheet-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
}

.create-sheet-header strong {
  font-size: 1.15rem;
}

.create-options {
  display: grid;
  gap: 10px;
  grid-template-columns: 1fr 1fr;
  margin-bottom: 12px;
}

.ai-minimal {
  display: grid;
  gap: 14px;
  margin: 0 auto;
  max-width: 840px;
}

.ai-searchbar {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 20px;
  box-shadow: var(--shadow);
  display: grid;
  gap: 8px;
  grid-template-columns: 1fr auto auto auto;
  padding: 10px;
}

.ai-searchbar textarea {
  background: transparent;
  border: 0;
  box-shadow: none;
  min-height: 50px;
  resize: none;
}

.ai-last-answer {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  color: var(--muted);
  line-height: 1.5;
  padding: 14px;
}

@media (min-width: 680px) {
  .calendar-entry-form {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .calendar-entry-form label:nth-of-type(6),
  .calendar-entry-form .primary-button {
    grid-column: 1 / -1;
  }

  .card-stack-board {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .create-card-sheet {
    border-radius: 18px;
    bottom: 96px;
    left: 50%;
    max-width: 620px;
    right: auto;
    transform: translateX(-50%);
    width: calc(100% - 32px);
  }
}

@media (max-width: 520px) {
  .ai-searchbar {
    grid-template-columns: 1fr auto auto;
  }

  .ai-searchbar .primary-button {
    grid-column: 1 / -1;
  }
}

.top-link-button {
  text-decoration: none;
}

.coach-sentence-card,
.study-session-page,
.settings-page {
  display: grid;
  gap: 14px;
  margin: 0 auto;
  max-width: 920px;
}

.account-page {
  max-width: 980px;
}

.settings-tabs {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 16px;
  box-shadow: var(--shadow-soft);
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  padding: 8px;
}

.settings-tab,
.progress-tab {
  background: transparent;
  border: 0;
  border-radius: 12px;
  color: var(--muted);
  cursor: pointer;
  font-weight: 950;
  min-height: 46px;
  padding: 0 12px;
  transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
}

.settings-tab:hover,
.progress-tab:hover {
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  color: var(--ink);
}

.settings-tab.active,
.progress-tab.active {
  background: var(--accent-soft);
  color: var(--accent);
}

.account-profile-card {
  align-items: start;
  display: grid;
  gap: 14px;
  grid-template-columns: auto 1fr;
}

.account-logo-wrap {
  background: #05070d;
  border-radius: 999px;
  box-shadow: var(--shadow-soft);
  height: 58px;
  overflow: hidden;
  width: 58px;
}

.account-logo-wrap .mascot,
.account-logo-wrap .mascot-face {
  height: 100%;
  width: 100%;
}

.account-logo-wrap .mascot-face {
  transform: none;
}

.account-profile-card h2 {
  font-size: clamp(1.6rem, 7vw, 2.6rem);
  line-height: 1;
  margin: 4px 0 8px;
}

.account-profile-card p {
  color: var(--muted);
  line-height: 1.45;
  margin: 0;
}

.account-detail-grid {
  display: grid;
  gap: 10px;
  grid-column: 1 / -1;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.account-detail-grid article,
.account-detail-grid button {
  appearance: none;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 14px;
  color: var(--ink);
  cursor: default;
  font: inherit;
  min-height: 82px;
  padding: 13px;
  text-align: left;
}

.account-detail-grid span,
.design-option small {
  color: var(--muted);
  display: block;
  font-size: 0.76rem;
  font-weight: 900;
  text-transform: uppercase;
}

.account-detail-grid strong {
  display: block;
  font-size: 1rem;
  margin-top: 8px;
  overflow-wrap: anywhere;
}

.account-detail-grid button.account-plan-open {
  cursor: pointer;
  position: relative;
  transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
}

.account-detail-grid button.account-plan-open:hover,
.account-detail-grid button.account-plan-open:focus-visible {
  border-color: color-mix(in srgb, var(--accent) 42%, var(--line));
  box-shadow: 0 14px 34px color-mix(in srgb, var(--accent) 14%, transparent);
  transform: translateY(-1px);
}

.account-detail-grid button.account-plan-open em {
  color: var(--accent);
  display: block;
  font-size: 0.78rem;
  font-style: normal;
  font-weight: 950;
  margin-top: 8px;
}

.design-toggle-button {
  align-items: center;
  background: linear-gradient(145deg, var(--panel), color-mix(in srgb, var(--accent) 9%, var(--panel)));
  border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--line));
  border-radius: 16px;
  box-shadow: var(--shadow-soft);
  color: var(--ink);
  cursor: pointer;
  display: flex;
  font-size: 1rem;
  font-weight: 950;
  gap: 10px;
  justify-content: center;
  min-height: 58px;
  padding: 0 18px;
}

.design-settings-panel {
  display: none;
}

.design-settings-panel.show {
  display: grid;
  gap: 14px;
}

.interactive-option-grid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.interactive-option-grid.two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.design-option {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 14px;
  color: var(--ink);
  cursor: pointer;
  display: grid;
  gap: 6px;
  min-height: 92px;
  padding: 12px;
  text-align: left;
}

.design-option:hover:not(:disabled),
.design-option.active {
  border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
  box-shadow: inset 0 0 0 2px color-mix(in srgb, var(--accent) 18%, transparent);
}

.design-option:disabled {
  cursor: not-allowed;
  opacity: 0.55;
}

.design-option i {
  background: var(--swatch);
  border-radius: 999px;
  box-shadow: 0 0 0 4px color-mix(in srgb, var(--swatch) 18%, transparent);
  display: block;
  height: 22px;
  width: 22px;
}

.danger-logout {
  align-items: center;
  background: color-mix(in srgb, var(--bad) 14%, var(--panel));
  border: 1px solid color-mix(in srgb, var(--bad) 35%, var(--line));
  border-radius: 16px;
  color: var(--bad);
  cursor: pointer;
  display: flex;
  font-weight: 950;
  gap: 10px;
  justify-content: center;
  min-height: 56px;
  padding: 0 18px;
}

.account-plan-panel {
  display: grid;
  gap: 14px;
}

.coach-sentence-card {
  background: linear-gradient(145deg, var(--panel), color-mix(in srgb, var(--accent) 10%, var(--panel)));
  border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--line));
  border-radius: 18px;
  box-shadow: var(--shadow);
  padding: 20px;
}

.coach-sentence-card span {
  color: var(--green);
  font-size: 0.78rem;
  font-weight: 950;
  text-transform: uppercase;
}

.coach-sentence-card strong {
  display: block;
  font-size: clamp(1.35rem, 6vw, 2.3rem);
  line-height: 1.12;
  margin-top: 8px;
}

.coach-action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 14px;
}

.cards-toolbar {
  margin: -6px 0 14px;
}

.dashboard-empty {
  display: grid;
  gap: 10px;
}

.mistake-add-form {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 16px;
  box-shadow: var(--shadow-soft);
  display: none;
  gap: 10px;
  padding: 14px;
}

.mistake-add-form.show {
  display: grid;
}

.session-progress {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  display: grid;
  gap: 6px;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  padding: 6px;
}

.session-progress span {
  border-radius: 10px;
  color: var(--muted);
  font-size: 0.76rem;
  font-weight: 900;
  padding: 10px 8px;
  text-align: center;
}

.session-progress span.active {
  background: var(--accent-soft);
  color: var(--accent);
}

.session-step {
  display: grid;
  gap: 12px;
}

.session-step h2 {
  font-size: clamp(1.7rem, 8vw, 3rem);
  line-height: 1;
  margin: 0;
}

.session-controls {
  display: grid;
  gap: 10px;
  grid-template-columns: 1fr 1fr;
}

.session-summary strong {
  display: block;
  font-size: 1.5rem;
  margin-bottom: 8px;
}

.settings-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.settings-grid article {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 14px;
}

.settings-grid span {
  color: var(--muted);
  display: block;
  font-size: 0.76rem;
  font-weight: 900;
  margin-bottom: 8px;
}

.settings-grid strong {
  display: block;
  font-size: 1.15rem;
}

.danger-action {
  color: var(--bad);
}

.ai-status-pill {
  border: 1px solid var(--line);
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 950;
  justify-self: start;
  padding: 7px 11px;
}

.ai-status-pill.offline {
  background: color-mix(in srgb, var(--ok) 14%, var(--panel));
  color: #b45309;
}

.ai-status-pill.online {
  background: color-mix(in srgb, var(--good) 14%, var(--panel));
  color: var(--good);
}

@media (max-width: 560px) {
  .top-actions {
    gap: 5px;
  }

  .theme-icon-button {
    height: 34px;
    width: 34px;
  }

  .top-icon-button {
    min-height: 34px;
    padding: 0 8px;
  }

  .top-icon-button span:last-child {
    display: none;
  }

  .session-progress {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .settings-grid {
    grid-template-columns: 1fr;
  }

  .account-detail-grid,
  .interactive-option-grid,
  .interactive-option-grid.two {
    grid-template-columns: 1fr;
  }

  .account-profile-card {
    grid-template-columns: 1fr;
  }
}

.home-page {
  display: grid;
  gap: 16px;
}

.home-page h1 {
  font-size: clamp(3rem, 18vw, 7rem);
  line-height: 0.9;
  margin: 0;
}

.home-metric-row {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.home-metric-row article {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  box-shadow: var(--shadow-soft);
  padding: 16px;
}

.home-metric-row span,
.subject-score-row span {
  color: var(--muted);
  display: block;
  font-size: 0.78rem;
  font-weight: 900;
  margin-bottom: 8px;
}

.home-metric-row strong,
.subject-score-row strong {
  display: block;
  font-size: clamp(1.8rem, 8vw, 3rem);
  line-height: 1;
}

.home-vertical-stack {
  display: grid;
  gap: 14px;
}

.home-vertical-stack .focus-card {
  min-height: 180px;
}

.grade-page {
  display: grid;
  gap: 14px;
  margin: 0 auto;
  max-width: 720px;
}

.grade-page-header {
  align-items: center;
  display: flex;
  gap: 12px;
  justify-content: space-between;
}

.grade-page-header h1 {
  font-size: clamp(2.7rem, 13vw, 5.5rem);
  line-height: 0.92;
  margin: 0;
}

.folder-detail-header {
  display: grid;
  grid-template-columns: auto 1fr auto;
}

.folder-detail-header h1 {
  font-size: clamp(1.55rem, var(--fit-title-size, 3rem), 3.7rem);
  justify-self: start;
  min-width: 0;
  overflow: hidden;
  overflow-wrap: normal;
  text-overflow: ellipsis;
  white-space: nowrap;
  word-break: keep-all;
}

.back-arrow-button {
  background: transparent;
  border-color: transparent;
  box-shadow: none;
  border-radius: 14px;
  color: var(--sleek-ink);
  font-size: 1.75rem;
  font-weight: 1000;
  height: 46px;
  line-height: 1;
  min-height: 46px;
  padding: 0;
  width: 46px;
}

.back-arrow-button:hover,
.back-arrow-button:focus-visible {
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  border-color: transparent;
  box-shadow: none;
}

.subject-add-form,
.grade-entry-form {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 16px;
  box-shadow: var(--shadow-soft);
  display: none;
  gap: 10px;
  padding: 14px;
}

.subject-add-form.show,
.grade-entry-form.show {
  display: grid;
}

.grade-entry-form input[type="number"],
.target-grade-form input[type="number"],
.what-if-form input[type="number"] {
  appearance: textfield;
  -moz-appearance: textfield;
}

.grade-entry-form input[type="number"]::-webkit-outer-spin-button,
.grade-entry-form input[type="number"]::-webkit-inner-spin-button,
.target-grade-form input[type="number"]::-webkit-outer-spin-button,
.target-grade-form input[type="number"]::-webkit-inner-spin-button,
.what-if-form input[type="number"]::-webkit-outer-spin-button,
.what-if-form input[type="number"]::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

.grade-mode-card,
.category-breakdown-card,
.what-if-card {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 16px;
  box-shadow: var(--shadow-soft);
  display: grid;
  gap: 12px;
  padding: 14px;
}

.grade-mode-tabs {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 14px;
  display: grid;
  gap: 6px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  padding: 5px;
}

.grade-mode-option,
.weight-quick {
  background: transparent;
  border: 0;
  border-radius: 10px;
  color: var(--muted);
  cursor: pointer;
  font-weight: 900;
  min-height: 40px;
  padding: 8px;
}

.grade-mode-option.active,
.grade-mode-option:hover,
.weight-quick:hover {
  background: var(--accent);
  color: var(--white);
}

.grade-mode-hint {
  color: var(--muted);
  font-size: 0.92rem;
  font-weight: 750;
  line-height: 1.45;
  margin: 0;
}

.category-editor,
.category-list {
  display: grid;
  gap: 10px;
}

.category-total {
  align-items: center;
  border: 1px solid var(--line);
  border-radius: 14px;
  display: flex;
  gap: 10px;
  justify-content: space-between;
  padding: 12px;
}

.category-total strong {
  font-size: 1.35rem;
}

.category-total span {
  color: var(--muted);
  font-size: 0.82rem;
  font-weight: 900;
}

.category-total.ok {
  background: color-mix(in srgb, var(--good) 10%, var(--panel));
  border-color: color-mix(in srgb, var(--good) 30%, var(--line));
}

.category-total.warn {
  background: color-mix(in srgb, var(--ok) 12%, var(--panel));
  border-color: color-mix(in srgb, var(--ok) 34%, var(--line));
}

.category-add-form,
.what-if-form {
  display: grid;
  gap: 10px;
}

.category-row {
  align-items: center;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 14px;
  display: grid;
  gap: 8px;
  grid-template-columns: 1fr 88px auto;
  padding: 8px;
}

.category-row input {
  min-width: 0;
}

.weight-quick-row {
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.weight-quick {
  background: var(--panel-2);
  border: 1px solid var(--line);
}

.category-breakdown-row {
  align-items: center;
  border-top: 1px solid var(--line);
  display: grid;
  gap: 10px;
  grid-template-columns: 1fr auto auto;
  padding: 12px 0 0;
}

.category-breakdown-row:first-of-type {
  border-top: 0;
  padding-top: 0;
}

.category-breakdown-row strong,
.category-breakdown-row small {
  display: block;
}

.category-breakdown-row small {
  color: var(--muted);
  margin-top: 3px;
}

.category-breakdown-row span,
.category-breakdown-row em {
  border-radius: 999px;
  font-style: normal;
  font-weight: 950;
  padding: 7px 10px;
}

.category-breakdown-row span {
  background: var(--accent-soft);
  color: var(--accent);
}

.category-breakdown-row em {
  background: var(--panel-2);
  color: var(--muted);
}

.category-progress-note {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 12px;
  color: var(--muted);
  font-size: 0.86rem;
  font-weight: 850;
  line-height: 1.45;
  margin: 0;
  padding: 10px 12px;
}

.category-progress-note.warning {
  background: color-mix(in srgb, var(--ok) 12%, var(--panel));
  border-color: color-mix(in srgb, var(--ok) 34%, var(--line));
  color: var(--ink);
}

.what-if-result {
  align-items: center;
  background: color-mix(in srgb, var(--accent) 10%, var(--panel));
  border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
  border-radius: 14px;
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  padding: 12px;
}

.what-if-result article {
  min-width: 0;
}

.what-if-result span {
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 900;
  text-transform: uppercase;
}

.what-if-result strong {
  font-size: 1.8rem;
  line-height: 1;
}

.what-if-result .primary-button {
  grid-column: 1 / -1;
}

.subject-combo {
  position: relative;
}

.subject-combo input {
  padding-right: 54px;
}

.subject-suggest-toggle {
  align-items: center;
  background: color-mix(in srgb, var(--accent) 10%, var(--panel));
  border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
  border-radius: 10px;
  color: var(--accent);
  cursor: pointer;
  display: inline-flex;
  font-size: 1.1rem;
  font-weight: 950;
  height: 34px;
  justify-content: center;
  position: absolute;
  right: 6px;
  top: 5px;
  width: 38px;
}

.subject-suggest-toggle:hover {
  background: var(--accent);
  color: var(--white);
}

.subject-suggestions {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  box-shadow: var(--shadow);
  display: none;
  gap: 6px;
  left: 0;
  max-height: 220px;
  overflow-y: auto;
  padding: 8px;
  position: absolute;
  right: 0;
  top: calc(100% + 8px);
  z-index: 12;
}

.subject-combo.open .subject-suggestions {
  display: grid;
}

.subject-suggestions button {
  background: transparent;
  border: 0;
  border-radius: 10px;
  color: var(--ink);
  cursor: pointer;
  font-weight: 850;
  min-height: 40px;
  padding: 0 12px;
  text-align: left;
}

.subject-suggestions button:hover,
.subject-suggestions button:focus-visible {
  background: var(--accent-soft);
  color: var(--accent);
}

.grade-folder-list {
  display: grid;
  gap: 10px;
}

.subject-folder-row {
  align-items: stretch;
  display: grid;
  gap: 8px;
  grid-template-columns: minmax(0, 1fr) auto;
}

.subject-folder-row .delete-subject {
  align-self: stretch;
  height: auto;
}

.grade-folder {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  box-shadow: var(--shadow-soft);
  color: var(--ink);
  cursor: pointer;
  display: grid;
  gap: 12px;
  grid-template-columns: auto 1fr auto auto;
  min-height: 82px;
  padding: 14px;
  text-align: left;
  width: 100%;
}

.grade-folder:hover {
  border-color: color-mix(in srgb, var(--accent) 34%, var(--line));
  transform: translateY(-1px);
}

.folder-icon {
  align-items: center;
  background: var(--accent-soft);
  border-radius: 12px;
  color: var(--accent);
  display: grid;
  height: 44px;
  place-items: center;
  width: 44px;
}

.grade-folder strong {
  display: block;
  font-size: 1.02rem;
}

.grade-folder small {
  color: var(--muted);
  display: block;
  margin-top: 3px;
}

.grade-folder em {
  color: var(--ink);
  font-style: normal;
  font-weight: 900;
}

.grade-folder b,
.subject-score-row strong.positive,
.subject-score-row strong.negative {
  border-radius: 999px;
  font-size: 0.86rem;
  padding: 6px 9px;
}

.subject-score-row {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.subject-score-row article {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  box-shadow: var(--shadow-soft);
  padding: 14px;
}

.grade-entry-list {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 16px;
  box-shadow: var(--shadow-soft);
  overflow: hidden;
}

.grade-entry-list article {
  align-items: center;
  border-bottom: 1px solid var(--line);
  display: flex;
  justify-content: space-between;
  padding: 14px;
}

.grade-entry-list article:last-child {
  border-bottom: 0;
}

.grade-entry-list strong {
  display: block;
}

.grade-entry-list small {
  color: var(--muted);
  display: block;
  margin-top: 3px;
}

.grade-entry-list span {
  font-size: 1.15rem;
  font-weight: 900;
}

.ai-full-page {
  display: grid;
  gap: 14px;
  min-height: calc(100vh - 180px);
}

.ai-full-page h1 {
  font-size: clamp(2.7rem, 12vw, 6rem);
  line-height: 0.95;
  margin: 0;
}

.ai-mascot-card {
  max-width: 720px;
}

.ai-full-input {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 18px;
  box-shadow: var(--shadow);
  display: grid;
  grid-template-rows: 1fr auto;
  min-height: min(62vh, 620px);
  overflow: hidden;
}

.ai-full-input textarea {
  background: transparent;
  border: 0;
  box-shadow: none;
  font-size: 1.05rem;
  line-height: 1.6;
  min-height: 340px;
  padding: 18px;
  resize: none;
}

.ai-input-tools {
  align-items: center;
  border-top: 1px solid var(--line);
  display: grid;
  gap: 8px;
  grid-template-columns: auto auto 1fr;
  padding: 12px;
}

.ai-input-tools .primary-button {
  justify-self: stretch;
}

.home-page h1 {
  text-align: center;
}

.home-vertical-stack {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.home-vertical-stack .focus-card h2 {
  font-size: clamp(1rem, 4vw, 1.25rem);
  overflow-wrap: anywhere;
}

.target-grade-card,
.partial-weight-card {
  cursor: pointer;
}

.target-grade-button,
.partial-weight-button {
  background: transparent;
  border: 0;
  color: var(--accent);
  cursor: pointer;
  display: block;
  font-size: clamp(1.8rem, 8vw, 3rem);
  font-weight: 900;
  line-height: 1;
  padding: 0;
  text-align: left;
  width: 100%;
}

.partial-weight-form {
  margin-top: -2px;
}

.target-grade-form {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 16px;
  box-shadow: var(--shadow-soft);
  display: none;
  gap: 10px;
  padding: 14px;
}

.target-grade-form.show {
  display: grid;
}

.toggle-field {
  align-items: center;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 12px;
  display: grid;
  gap: 2px 10px;
  grid-template-columns: auto 1fr;
  margin: 0;
  padding: 12px;
}

.toggle-field input {
  accent-color: var(--accent);
  min-height: auto;
  width: 20px;
}

.toggle-field span {
  font-weight: 950;
}

.toggle-field small {
  color: var(--muted);
  font-weight: 750;
  grid-column: 2;
  line-height: 1.35;
}

.grade-folder-toggle {
  margin-top: 2px;
}

.grade-entry-list .grade-swipe-row {
  align-items: stretch;
  display: block;
  overflow: hidden;
  padding: 0;
  position: relative;
  touch-action: pan-y;
  user-select: none;
}

.grade-row-main {
  align-items: center;
  background: transparent;
  border: 0;
  color: var(--ink);
  cursor: default;
  display: grid;
  gap: 12px;
  grid-template-columns: auto minmax(0, 1fr) auto;
  min-height: 72px;
  padding: 14px;
  text-align: left;
  transition: transform 180ms ease;
  width: 100%;
}

.grade-row-main.open-partial-folder,
.grade-row-main.edit-grade-entry {
  cursor: pointer;
}

.grade-row-main.open-partial-folder:hover,
.grade-row-main.edit-grade-entry:hover {
  background: var(--panel-2);
}

.grade-row-icon {
  align-items: center;
  background: var(--accent-soft);
  border-radius: 10px;
  color: var(--accent);
  display: grid;
  height: 38px;
  place-items: center;
  width: 38px;
}

.grade-row-main em {
  color: var(--ink);
  font-style: normal;
  font-weight: 950;
}

.partial-folder-metrics {
  align-items: flex-end;
  display: grid;
  gap: 3px;
  justify-items: end;
}

.partial-folder-metrics b {
  color: var(--ink);
  font-size: 1.05rem;
  font-weight: 950;
  line-height: 1;
}

.partial-folder-metrics small {
  background: color-mix(in srgb, var(--green) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--green) 26%, var(--line));
  border-radius: 999px;
  color: var(--green);
  font-size: 0.72rem;
  font-weight: 950;
  padding: 4px 7px;
}

.grade-row-actions {
  align-items: center;
  background: color-mix(in srgb, var(--bad) 92%, #7f1d1d);
  border: 0;
  border-radius: 18px;
  bottom: 0;
  display: flex;
  gap: 6px;
  height: auto;
  justify-content: center;
  padding: 0;
  position: absolute;
  right: 6px;
  top: 0;
  transform: translateX(120%);
  transition: transform 180ms ease;
  width: 72px;
}

.grade-swipe-row.show-actions .grade-row-main {
  transform: translateX(-90px);
}

.grade-swipe-row.show-actions .grade-row-actions {
  transform: translateX(0);
}

.grade-swipe-row.swiping .grade-row-main {
  transform: translateX(calc(var(--swipe-offset, 0px) * -1));
  transition: none;
}

.grade-swipe-row.swiping .grade-row-actions {
  transform: translateX(calc(120% - var(--swipe-offset, 0px)));
  transition: none;
}

.icon-action {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 10px;
  color: var(--muted);
  cursor: pointer;
  display: inline-flex;
  height: 38px;
  justify-content: center;
  width: 38px;
}

.icon-action:hover {
  color: var(--accent);
}

.delete-grade:hover {
  color: var(--bad);
}

.grade-row-actions .icon-action {
  background: transparent;
  border: 0;
  border-radius: 999px;
  color: var(--white);
  height: 42px;
  width: 42px;
}

.grade-row-actions .icon-action:hover,
.grade-row-actions .icon-action:focus-visible {
  background: rgba(255, 255, 255, 0.16);
  color: var(--white);
}

.partial-folder-row .grade-row-icon {
  background: color-mix(in srgb, var(--green) 15%, transparent);
  color: var(--green);
}

.partial-score-row strong {
  font-size: clamp(1.25rem, 6vw, 2.1rem);
}

.subject-score-row {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.ai-window {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 20px;
  box-shadow: var(--shadow);
  display: grid;
  grid-template-rows: minmax(260px, 1fr) auto auto;
  min-height: min(68vh, 680px);
  overflow: hidden;
}

.ai-output {
  align-content: end;
  display: flex;
  flex-direction: column;
  gap: 10px;
  overflow-y: auto;
  padding: 18px;
}

.ai-window .attachment-pill {
  margin: 0 14px 12px;
}

.ai-window .ai-full-input {
  border: 0;
  border-radius: 0;
  box-shadow: none;
  min-height: auto;
}

.ai-window .ai-full-input textarea {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 14px;
  font-size: 1rem;
  margin: 12px 12px 0;
  min-height: 78px;
  padding: 14px;
}

@media (max-width: 520px) {
  .home-metric-row {
    grid-template-columns: 1fr 1fr;
  }

  .subject-score-row {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .subject-score-row article {
    padding: 12px 10px;
  }

  .subject-score-row span {
    font-size: 0.68rem;
  }

  .subject-score-row strong,
  .target-grade-button {
    font-size: 1.35rem;
  }

  .grade-folder {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .grade-folder em,
  .grade-folder b {
    justify-self: start;
  }

  .ai-input-tools {
    grid-template-columns: auto auto;
  }

  .ai-input-tools .primary-button {
    grid-column: 1 / -1;
  }

  .grade-row-main {
    grid-template-columns: auto minmax(0, 1fr);
  }

  .grade-row-main em {
    grid-column: 2;
  }

.grade-row-actions {
    padding: 0 8px;
  }

  .icon-action {
    height: 34px;
    width: 34px;
  }

  .subject-folder-row {
    grid-template-columns: 1fr;
  }

  .subject-folder-row .delete-subject {
    min-height: 42px;
    width: 100%;
  }
}

.create-card-sheet.standalone-create {
  bottom: auto;
  left: auto;
  max-width: 720px;
  position: static;
  right: auto;
  transform: none;
  width: 100%;
}

.today-dashboard {
  max-width: 980px;
  margin: 0 auto;
}

.today-dashboard h1 {
  font-size: clamp(3.6rem, 18vw, 7.5rem);
  letter-spacing: 0;
}

.today-metrics article {
  min-height: 132px;
  padding: 22px;
}

.today-metrics strong {
  font-size: clamp(2.2rem, 10vw, 4rem);
}

.start-study-session {
  border-radius: 16px;
  font-size: 1.02rem;
  min-height: 58px;
  width: 100%;
}

.today-grid {
  display: grid;
  gap: 14px;
  grid-template-columns: 1fr;
}

.today-grid .focus-card {
  border-radius: 16px;
  min-height: 190px;
  padding: 20px;
}

.today-main-card {
  background: linear-gradient(145deg, var(--panel), color-mix(in srgb, var(--accent) 9%, var(--panel)));
}

.today-task-list {
  display: grid;
  gap: 10px;
  margin-top: 14px;
}

.today-task-list a {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 12px;
  display: block;
  padding: 12px;
}

.today-task-list strong,
.today-task-list small {
  display: block;
}

.today-task-list small,
.muted-text {
  color: var(--muted);
  line-height: 1.45;
}

.grade-coach-row,
.mistake-stats {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.grade-coach-row article,
.mistake-stats article {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  box-shadow: var(--shadow-soft);
  padding: 14px;
}

.grade-coach-row span,
.mistake-stats span {
  color: var(--muted);
  display: block;
  font-size: 0.75rem;
  font-weight: 900;
  margin-bottom: 8px;
}

.grade-coach-row strong,
.mistake-stats strong {
  display: block;
  font-size: clamp(1rem, 5vw, 1.5rem);
  line-height: 1.15;
  overflow-wrap: anywhere;
}

.grade-coach-row .secondary-button {
  grid-column: 1 / -1;
}

.card-study-view {
  margin: 0 auto;
  max-width: 720px;
}

.card-progress-strip,
.session-summary-grid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.card-progress-strip {
  margin: 8px 0 14px;
}

.card-progress-strip article,
.session-summary-grid article,
.session-summary-line,
.session-mini-status,
.session-progress-card,
.deck-option-card {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 18px;
  box-shadow: var(--shadow-soft);
}

.card-progress-strip article {
  min-height: 74px;
  padding: 14px;
}

.card-progress-strip .wide {
  grid-column: 1 / -1;
}

.card-progress-strip span,
.session-summary-grid span,
.session-summary-line span,
.session-mini-status span {
  color: var(--muted);
  display: block;
  font-size: 0.72rem;
  font-weight: 950;
  text-transform: uppercase;
}

.card-progress-strip strong,
.session-summary-grid strong,
.session-summary-line strong,
.session-mini-status strong {
  display: block;
  font-size: 1.2rem;
  line-height: 1.1;
  margin-top: 5px;
}

.deck-session-choice,
.session-summary-card {
  display: grid;
  gap: 14px;
}

.deck-option-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.deck-option-card {
  color: var(--text);
  cursor: pointer;
  display: grid;
  gap: 8px;
  min-height: 144px;
  padding: 16px;
  text-align: left;
  transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.deck-option-card:hover,
.deck-option-card:focus-visible {
  border-color: color-mix(in srgb, var(--accent) 48%, var(--line));
  box-shadow: var(--shadow);
  transform: translateY(-2px);
}

.deck-option-card:disabled {
  cursor: not-allowed;
  opacity: 0.55;
  transform: none;
}

.deck-option-card span,
.deck-option-card small {
  color: var(--muted);
  font-weight: 900;
}

.deck-option-card strong {
  font-size: 1.25rem;
}

.deck-option-card em {
  align-self: end;
  color: var(--accent);
  font-style: normal;
  font-weight: 950;
}

.learning-mode-grid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.learning-mode-card {
  align-items: center;
  background: color-mix(in srgb, var(--panel) 88%, var(--accent) 6%);
  border: 1px solid var(--line);
  border-radius: 16px;
  box-shadow: var(--shadow-soft);
  color: var(--sleek-ink);
  cursor: pointer;
  display: grid;
  gap: 10px;
  grid-template-columns: auto minmax(0, 1fr);
  min-height: 76px;
  padding: 12px 14px;
  position: relative;
  text-align: left;
  transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
}

.learning-mode-card.disabled {
  cursor: not-allowed;
  opacity: 0.55;
}

.learning-mode-card:hover,
.learning-mode-card:focus-visible {
  border-color: color-mix(in srgb, var(--accent) 46%, var(--line));
  box-shadow: 0 16px 34px color-mix(in srgb, var(--accent) 14%, transparent);
  transform: translateY(-1px);
}

.learning-mode-card span {
  color: var(--sleek-ink);
  font-size: 1.02rem;
  font-weight: 950;
  line-height: 1.05;
}

.learning-mode-card em {
  color: var(--accent);
  font-size: 0.74rem;
  font-style: normal;
  font-weight: 950;
  grid-column: 2;
  line-height: 1;
  text-transform: uppercase;
}

.learning-mode-card small {
  color: var(--muted);
  display: block;
  font-size: 0.76rem;
  font-weight: 900;
  grid-column: 2;
  line-height: 1.25;
}

.mode-symbol {
  align-items: center;
  background: color-mix(in srgb, var(--accent) 15%, var(--panel));
  border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
  border-radius: 14px;
  color: var(--accent);
  display: grid;
  grid-row: span 3;
  height: 46px;
  justify-items: center;
  position: relative;
  width: 46px;
}

.mode-symbol i,
.mode-symbol b {
  display: block;
  position: absolute;
}

.mode-symbol-cards i {
  background: var(--accent);
  border-radius: 5px;
  height: 20px;
  opacity: 0.9;
  transform: rotate(-7deg);
  width: 16px;
}

.mode-symbol-cards i + i {
  background: color-mix(in srgb, var(--good) 82%, var(--accent));
  transform: translate(8px, 3px) rotate(5deg);
}

.mode-symbol-cards b {
  background: var(--panel);
  border-radius: 999px;
  height: 4px;
  width: 4px;
}

.mode-symbol-write i {
  background: var(--accent);
  border-radius: 999px;
  height: 28px;
  transform: rotate(44deg);
  width: 7px;
}

.mode-symbol-write b {
  border-bottom: 3px solid color-mix(in srgb, var(--good) 80%, var(--accent));
  border-radius: 999px;
  bottom: 11px;
  height: 10px;
  width: 24px;
}

.mode-symbol-choice i {
  border: 4px solid var(--accent);
  border-radius: 50%;
  height: 24px;
  width: 24px;
}

.mode-symbol-choice b {
  background: var(--good);
  border-radius: 50%;
  height: 8px;
  right: 9px;
  top: 8px;
  width: 8px;
}

.mode-symbol-learn i {
  border: 4px solid var(--accent);
  border-radius: 50%;
  height: 24px;
  width: 24px;
}

.mode-symbol-learn b {
  background: var(--good);
  border-radius: 999px;
  bottom: 10px;
  height: 6px;
  right: 8px;
  transform: rotate(-25deg);
  width: 22px;
}

.mode-symbol-test i {
  background: var(--accent);
  border-radius: 6px;
  height: 26px;
  width: 22px;
}

.mode-symbol-test b {
  background: var(--panel);
  border-radius: 999px;
  height: 4px;
  transform: translateY(-2px);
  width: 12px;
  box-shadow: 0 8px 0 var(--panel);
}

.mode-symbol-match i {
  background: var(--accent);
  border-radius: 8px;
  height: 14px;
  left: 8px;
  top: 10px;
  width: 14px;
}

.mode-symbol-match i + i {
  background: var(--good);
  left: auto;
  right: 8px;
  top: auto;
  bottom: 10px;
}

.mode-symbol-match b {
  border-bottom: 3px dashed color-mix(in srgb, var(--accent) 68%, var(--good));
  height: 20px;
  transform: rotate(-28deg);
  width: 24px;
}

.mode-question-card,
.mode-feedback,
.wrong-answer-list article {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 20px;
  box-shadow: var(--shadow-soft);
  padding: 18px;
}

.mode-question-card {
  display: grid;
  gap: 8px;
  margin-bottom: 14px;
}

.mode-question-card small,
.mode-tag-row span,
.match-board span {
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 950;
  text-transform: uppercase;
}

.mode-question-card h2 {
  font-size: clamp(1.6rem, 7vw, 2.45rem);
  line-height: 1.05;
  margin: 0;
  overflow-wrap: anywhere;
}

.mode-question-card p {
  color: var(--muted);
  margin: 0;
}

.mode-answer-form {
  display: grid;
  gap: 12px;
}

.mode-answer-form input {
  min-height: 54px;
}

.choice-grid,
.match-board {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.choice-option,
.match-tile {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 16px;
  color: var(--sleek-ink);
  cursor: pointer;
  font-weight: 900;
  min-height: 56px;
  padding: 12px;
  text-align: left;
}

.choice-option:hover,
.choice-option:focus-visible,
.match-tile:hover,
.match-tile:focus-visible,
.match-tile.selected {
  border-color: color-mix(in srgb, var(--accent) 48%, var(--line));
  box-shadow: 0 10px 24px color-mix(in srgb, var(--accent) 12%, transparent);
}

.choice-option:disabled,
.match-tile:disabled {
  cursor: default;
  opacity: 0.55;
}

.match-stopwatch {
  align-items: center;
  background: linear-gradient(145deg, color-mix(in srgb, var(--accent) 13%, var(--panel)), var(--panel));
  border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
  border-radius: 18px;
  box-shadow: var(--shadow-soft);
  display: grid;
  gap: 2px;
  grid-template-columns: minmax(0, 1fr) auto;
  margin-bottom: 12px;
  padding: 14px 16px;
}

.match-stopwatch span,
.match-stopwatch small {
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 950;
  text-transform: uppercase;
}

.match-stopwatch strong {
  color: var(--accent);
  font-size: 2rem;
  grid-row: 1 / span 2;
  line-height: 1;
}

.match-untimed-status {
  align-items: center;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 15px;
  color: var(--muted);
  display: flex;
  font-size: 0.78rem;
  font-weight: 900;
  justify-content: space-between;
  margin-bottom: 12px;
  min-height: 48px;
  padding: 10px 13px;
}

.match-untimed-status strong {
  color: var(--ink);
  font-size: 1rem;
}

.match-grid-board {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.match-grid-tile {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 16px;
  color: var(--sleek-ink);
  cursor: pointer;
  display: flex;
  font-weight: 900;
  justify-content: center;
  min-height: 84px;
  overflow-wrap: anywhere;
  padding: 10px;
  text-align: center;
  transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease, background 160ms ease;
}

.match-grid-tile:hover,
.match-grid-tile:focus-visible,
.match-grid-tile.selected {
  border-color: color-mix(in srgb, var(--accent) 52%, var(--line));
  box-shadow: 0 10px 24px color-mix(in srgb, var(--accent) 12%, transparent);
  transform: translateY(-1px);
}

.match-grid-tile.wrong {
  animation: matchWrong 420ms ease;
  background: color-mix(in srgb, var(--bad) 20%, var(--panel));
  border-color: color-mix(in srgb, var(--bad) 66%, var(--line));
  color: color-mix(in srgb, var(--bad) 82%, var(--ink));
}

@keyframes matchWrong {
  0%, 100% { transform: translateX(0); }
  30% { transform: translateX(-3px); }
  70% { transform: translateX(3px); }
}

.test-setup-panel,
.test-setup-form,
.test-list-form,
.match-time-results {
  display: grid;
  gap: 14px;
}

.test-setup-form fieldset {
  border: 1px solid var(--line);
  border-radius: 18px;
  display: grid;
  gap: 10px;
  margin: 0;
  padding: 14px;
}

.test-setup-form legend {
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 950;
  padding: 0 8px;
  text-transform: uppercase;
}

.test-direction-option {
  align-items: center;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 14px;
  cursor: pointer;
  display: flex;
  gap: 10px;
  min-height: 46px;
  padding: 10px 12px;
}

.test-direction-option:has(input:checked) {
  border-color: color-mix(in srgb, var(--accent) 52%, var(--line));
  box-shadow: 0 10px 24px color-mix(in srgb, var(--accent) 12%, transparent);
}

.test-list-question {
  align-items: start;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 18px;
  box-shadow: var(--shadow-soft);
  display: grid;
  gap: 12px;
  grid-template-columns: 38px minmax(0, 1fr);
  padding: 14px;
}

.test-list-question > span {
  align-items: center;
  background: var(--accent-soft);
  border-radius: 999px;
  color: var(--accent);
  display: inline-flex;
  font-weight: 950;
  height: 34px;
  justify-content: center;
  width: 34px;
}

.test-list-question strong,
.test-list-question small {
  display: block;
}

.test-list-question small {
  color: var(--muted);
  margin: 4px 0 10px;
}

.test-choice-list {
  display: grid;
  gap: 8px;
}

.test-choice-list label {
  align-items: center;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 12px;
  cursor: pointer;
  display: flex;
  gap: 10px;
  min-height: 44px;
  padding: 9px 11px;
}

.test-submit-button {
  margin-top: 6px;
}

.test-result-chart {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 20px;
  box-shadow: var(--shadow-soft);
  display: grid;
  gap: 16px;
  grid-template-columns: auto minmax(0, 1fr);
  padding: 16px;
}

.pie-chart {
  align-items: center;
  background: conic-gradient(var(--good) 0 var(--correct), var(--bad) var(--correct) 100%);
  border-radius: 50%;
  color: var(--ink);
  display: grid;
  height: 116px;
  justify-items: center;
  line-height: 1;
  place-content: center;
  position: relative;
  width: 116px;
}

.pie-chart::after {
  background: var(--panel);
  border-radius: 50%;
  content: "";
  height: 72px;
  position: absolute;
  width: 72px;
}

.pie-chart strong,
.pie-chart span {
  position: relative;
  z-index: 1;
}

.pie-chart strong {
  font-size: 1.35rem;
}

.pie-chart span {
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 950;
  text-transform: uppercase;
}

.match-time-results table {
  border-collapse: separate;
  border-spacing: 0 8px;
  min-width: 410px;
  width: 100%;
}

.match-time-results {
  overflow-x: auto;
}

.match-time-results th {
  color: var(--muted);
  font-size: 0.72rem;
  text-align: left;
  text-transform: uppercase;
}

.match-time-results td {
  background: var(--panel);
  border-bottom: 1px solid var(--line);
  border-top: 1px solid var(--line);
  font-weight: 850;
  padding: 10px;
}

.match-time-results td:first-child {
  border-left: 1px solid var(--line);
  border-radius: 12px 0 0 12px;
}

.match-time-results td:last-child {
  border-radius: 0 12px 12px 0;
  border-right: 1px solid var(--line);
}

.match-time-results tr.you td {
  background: color-mix(in srgb, var(--accent) 14%, var(--panel));
  border-color: color-mix(in srgb, var(--accent) 38%, var(--line));
}

.mode-feedback {
  display: grid;
  gap: 10px;
  margin-top: 14px;
}

.mode-feedback.correct {
  background: color-mix(in srgb, var(--good) 12%, var(--panel));
  border-color: color-mix(in srgb, var(--good) 28%, var(--line));
}

.mode-feedback.wrong {
  background: color-mix(in srgb, var(--bad) 10%, var(--panel));
  border-color: color-mix(in srgb, var(--bad) 28%, var(--line));
}

.mode-tag-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
}

.mode-tag-row strong {
  color: var(--accent);
  font-weight: 950;
}

.match-board > div {
  display: grid;
  gap: 10px;
}

.wrong-answer-list {
  display: grid;
  gap: 10px;
}

.wrong-answer-list h2 {
  font-size: 1.05rem;
  margin: 0;
}

.wrong-answer-list article {
  box-shadow: none;
}

.wrong-answer-list p {
  color: var(--muted);
  margin: 6px 0;
}

@media (max-width: 720px) {
  input,
  select,
  textarea {
    font-size: 16px;
    touch-action: manipulation;
  }

  .choice-grid,
  .match-board,
  .continue-actions {
    grid-template-columns: 1fr;
  }

  .match-grid-board {
    gap: 7px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .match-grid-tile {
    border-radius: 13px;
    font-size: clamp(0.68rem, 3.1vw, 0.82rem);
    min-height: 68px;
    padding: 7px 5px;
  }

  .test-result-chart {
    grid-template-columns: 1fr;
    justify-items: center;
    text-align: center;
  }

  .learning-mode-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .learning-mode-card {
    gap: 7px;
    grid-template-columns: auto minmax(0, 1fr);
    min-height: 0;
    padding: 10px;
  }

  .learning-mode-card span {
    font-size: 0.9rem;
  }

  .learning-mode-card small {
    font-size: 0.66rem;
  }

  .learning-mode-card em {
    font-size: 0.66rem;
  }

  .mode-symbol {
    border-radius: 12px;
    height: 38px;
    width: 38px;
  }

  .session-mini-status {
    grid-template-columns: 1fr;
    text-align: left;
  }
}

.session-progress-card {
  align-items: center;
  display: grid;
  gap: 14px;
  grid-template-columns: auto 1fr;
  padding: 16px;
}

.session-progress-card h2 {
  font-size: clamp(1.35rem, 5vw, 2rem);
  line-height: 1.08;
  margin: 4px 0;
}

.session-progress-card p,
.panel-note {
  color: var(--muted);
  line-height: 1.45;
  margin: 0;
}

.session-progress-card.celebration {
  background: linear-gradient(145deg, color-mix(in srgb, var(--good) 13%, var(--panel)), var(--panel));
}

.session-mini-status {
  align-items: center;
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-bottom: 14px;
  padding: 12px;
  text-align: center;
}

.session-summary-line {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 14px 16px;
}

.continue-actions {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.continue-actions .primary-button,
.continue-actions .secondary-button {
  min-height: 48px;
}

.study-view-header,
.study-nav-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
}

.study-view-header strong,
.study-nav-row span {
  color: var(--muted);
  font-weight: 950;
}

.srs-rating-grid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 14px;
}

.srs-rating {
  border: 1px solid var(--line);
  border-radius: 14px;
  cursor: pointer;
  font-weight: 950;
  min-height: 58px;
}

.srs-rating.again { background: color-mix(in srgb, var(--bad) 12%, var(--panel)); color: var(--bad); }
.srs-rating.hard { background: color-mix(in srgb, var(--ok) 14%, var(--panel)); color: #b45309; }
.srs-rating.good { background: color-mix(in srgb, var(--good) 12%, var(--panel)); color: var(--good); }
.srs-rating.easy { background: color-mix(in srgb, var(--accent) 12%, var(--panel)); color: var(--accent); }

.mistake-page {
  display: grid;
  gap: 14px;
  margin: 0 auto;
  max-width: 880px;
}

.mistake-header {
  align-items: end;
  display: flex;
  gap: 12px;
  justify-content: space-between;
}

.mistake-header h1 {
  font-size: clamp(2.7rem, 12vw, 5.8rem);
  line-height: 0.95;
  margin: 0;
}

.mistake-title-block {
  display: grid;
  gap: 6px;
}

.mistake-title-row {
  align-items: center;
  display: flex;
  gap: 8px;
  min-width: 0;
}

.mistake-back-link {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  box-shadow: var(--shadow-soft);
  color: var(--sleek-ink, var(--ink));
  cursor: pointer;
  display: inline-flex;
  flex: 0 0 44px;
  font-size: 2.2rem;
  font-weight: 900;
  height: 44px;
  justify-content: center;
  line-height: 1;
  text-decoration: none;
}

.mistake-back-link:hover {
  border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
  color: var(--accent);
}

.mistake-back-link:focus-visible {
  outline: 3px solid color-mix(in srgb, var(--accent) 55%, transparent);
  outline-offset: 2px;
}

.deck-choice-title-row {
  align-items: center;
  display: flex;
  gap: 10px;
  min-width: 0;
}

.deck-choice-title-row h1 {
  margin-left: 0;
  min-width: 0;
}

.deck-choice-heading .mistake-back-link {
  flex: 0 0 44px;
}

.deck-session-choice .due-study-header {
  justify-content: flex-end;
}

.segmented-actions {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  display: grid;
  gap: 6px;
  grid-template-columns: repeat(3, 1fr);
  padding: 6px;
}

.segmented-actions button {
  background: transparent;
  border: 0;
  border-radius: 10px;
  color: var(--muted);
  cursor: pointer;
  font-weight: 900;
  min-height: 42px;
}

.segmented-actions button.active {
  background: var(--accent-soft);
  color: var(--accent);
}

.mistake-list {
  display: grid;
  gap: 12px;
}

.mistake-card {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 16px;
  box-shadow: var(--shadow-soft);
  padding: 16px;
}

.mistake-card.fixed {
  opacity: 0.72;
}

.mistake-card-top {
  align-items: center;
  color: var(--muted);
  display: flex;
  gap: 10px;
  justify-content: space-between;
}

.mistake-card h2 {
  font-size: 1.15rem;
  line-height: 1.3;
  margin: 12px 0;
}

.mistake-card dl {
  display: grid;
  gap: 10px;
  margin: 0 0 14px;
}

.mistake-card dt {
  color: var(--muted);
  font-size: 0.76rem;
  font-weight: 900;
}

.mistake-card dd {
  margin: 3px 0 0;
}

.ai-quick-actions,
.message-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 0 14px 12px;
}

.message-actions {
  padding: 10px 0 0;
}

.ai-quick-action,
.message-actions button {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--muted);
  cursor: pointer;
  font-size: 0.8rem;
  font-weight: 900;
  min-height: 34px;
  padding: 0 11px;
}

.message.bot .message-actions button {
  background: var(--panel);
}

@media (min-width: 760px) {
  .today-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .today-main-card {
    grid-row: span 2;
  }
}

@media (max-width: 520px) {
  .bottom-nav {
    gap: 2px;
    padding-inline: 4px;
  }

  .bottom-nav a {
    font-size: 0.58rem;
    min-height: 52px;
  }

  .nav-icon {
    font-size: 0.98rem;
  }

  .home-metric-row.today-metrics {
    grid-template-columns: 1fr;
  }

  .grade-coach-row {
    grid-template-columns: 1fr;
  }

  .deck-option-grid,
  .continue-actions {
    grid-template-columns: 1fr;
  }

  .deck-option-card {
    min-height: 116px;
  }

  .card-progress-strip,
  .session-summary-grid {
    grid-template-columns: 1fr;
  }

  .srs-rating-grid {
    grid-template-columns: 1fr 1fr;
  }

  .mistake-header {
    align-items: stretch;
    display: grid;
  }
}

/* Sleek Lynxly redesign based on the new mobile references. */
:root {
  --sleek-bg: #f6f9fd;
  --sleek-teal: #10998d;
  --sleek-ink: #111827;
  --sleek-muted: #66758a;
  --sleek-card-radius: 28px;
  --sleek-soft-shadow: 0 16px 36px rgba(17, 24, 39, 0.09);
  --sleek-deep-shadow: 0 24px 58px color-mix(in srgb, var(--accent) 20%, transparent);
}

html[data-theme="dark"] {
  --sleek-bg: #0d1320;
  --sleek-ink: var(--ink);
  --sleek-muted: var(--muted);
  --sleek-soft-shadow: 0 18px 42px rgba(0, 0, 0, 0.34);
}

html {
  background: color-mix(in srgb, var(--sleek-bg) 82%, var(--panel));
}

.app-shell {
  background: var(--sleek-bg);
}

.topbar {
  background: color-mix(in srgb, var(--sleek-bg) 86%, transparent);
  border-bottom: 0;
  padding: 18px 24px 0;
}

.brand > span:last-child {
  display: none;
}

.brand-logo,
.logo {
  border-radius: 14px;
  height: 44px;
  width: 44px;
}

.brand-logo {
  border-radius: 999px;
}

.top-actions {
  gap: 10px;
}

.theme-icon-button {
  background: color-mix(in srgb, var(--panel) 88%, transparent);
  border-radius: 999px;
  box-shadow: var(--shadow-soft);
  color: var(--muted);
}

.account-button {
  background: var(--panel);
  border: 0;
  border-radius: 999px;
  box-shadow: var(--shadow-soft);
  min-height: 40px;
  padding: 0 14px;
}

.main-content {
  max-width: 520px;
  padding: 72px 24px 112px;
}

.sleek-screen,
.grade-page,
.planner-page,
.cards-page,
.settings-page,
.mistake-page,
.session-page,
.bot-page {
  animation: sectionEnter 260ms ease both;
}

.sleek-page-header,
.grade-page-header,
.planner-page-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin: 4px 0 34px;
}

.sleek-page-header h1,
.grade-page-header h1,
.planner-page-header h1,
.home-page h1 {
  color: var(--sleek-ink);
  font-size: clamp(3.2rem, 17vw, 4.4rem);
  line-height: 0.95;
  margin: 0;
}

.grade-page-header.folder-detail-header {
  display: grid;
  gap: 10px;
  grid-template-columns: 46px minmax(0, 1fr) 52px;
}

.grade-page-header.folder-detail-header h1 {
  font-size: clamp(1.55rem, var(--fit-title-size, 3rem), 3.7rem);
  justify-self: start;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  word-break: keep-all;
}

.sleek-page-header p {
  color: var(--sleek-muted);
  font-size: 1.25rem;
  font-weight: 760;
  margin: 12px 0 0;
}

.sleek-header-actions {
  align-items: center;
  display: flex;
  gap: 12px;
}

.sleek-mini-pill,
.sleek-avatar {
  align-items: center;
  background: var(--panel);
  border: 1px solid color-mix(in srgb, var(--accent) 16%, var(--line));
  border-radius: 999px;
  box-shadow: var(--sleek-soft-shadow);
  color: var(--accent);
  display: inline-flex;
  font-size: 1.1rem;
  font-weight: 950;
  gap: 10px;
  min-height: 56px;
  padding: 0 18px;
}

.sleek-mini-pill i {
  background: #f59e0b;
  border-radius: 50%;
  display: block;
  height: 22px;
  width: 22px;
}

.streak-mini i {
  background: linear-gradient(160deg, #fbbf24, #f97316 58%, #ea580c);
  border-radius: 70% 70% 70% 18%;
  box-shadow: 0 0 0 5px rgba(249, 115, 22, 0.12);
  height: 22px;
  position: relative;
  transform: rotate(-45deg);
  width: 22px;
}

.streak-mini i::after {
  background: #fff7ed;
  border-radius: 60% 60% 60% 18%;
  content: "";
  height: 9px;
  left: 7px;
  position: absolute;
  top: 7px;
  width: 9px;
}

.sleek-avatar {
  background: color-mix(in srgb, var(--accent) 8%, var(--panel));
  border: 0;
  height: 62px;
  justify-content: center;
  overflow: hidden;
  padding: 0;
  width: 62px;
}

.sleek-avatar .mascot {
  border-radius: inherit;
  height: 100%;
  overflow: hidden;
  width: 100%;
}

.sleek-avatar .mascot-face {
  border-radius: 999px;
  height: 100%;
  transform: none;
  width: 100%;
}

.sleek-coach-card {
  background:
    radial-gradient(circle at 90% 12%, rgba(255, 255, 255, 0.16), transparent 28%),
    linear-gradient(150deg, var(--accent), color-mix(in srgb, var(--accent) 80%, #087f75));
  border: 0;
  border-radius: 34px;
  box-shadow: var(--sleek-deep-shadow);
  color: #fff;
  margin-bottom: 34px;
  padding: 28px 28px 30px;
}

.coach-label {
  align-items: center;
  display: inline-flex;
  font-size: 0.9rem;
  font-weight: 950;
  gap: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.coach-label i {
  background: rgba(255, 255, 255, 0.82);
  border-radius: 50%;
  display: block;
  height: 16px;
  width: 16px;
}

.sleek-coach-card h2 {
  font-size: clamp(2.1rem, 10vw, 3.2rem);
  line-height: 1.04;
  margin: 30px 0 18px;
}

.sleek-coach-card p {
  color: rgba(255, 255, 255, 0.82);
  font-size: 1.18rem;
  font-weight: 650;
  line-height: 1.5;
  margin: 0 0 28px;
}

.sleek-primary-cta {
  background: #fff;
  border-radius: 999px;
  box-shadow: 0 16px 30px rgba(2, 6, 23, 0.16);
  color: var(--accent);
  font-size: 1.04rem;
  justify-content: space-between;
  min-height: 68px;
  padding: 0 24px 0 28px;
  width: 100%;
}

.sleek-primary-cta i {
  background: var(--accent);
  border-radius: 50%;
  display: block;
  height: 24px;
  width: 24px;
}

.sleek-metrics {
  grid-template-columns: 1fr 1fr;
  margin-bottom: 32px;
}

.sleek-metrics article,
.grade-summary-card,
.sleek-next-item,
.grade-folder,
.calendar-only-panel,
.agenda-card,
.focus-card,
.panel {
  border-radius: var(--sleek-card-radius);
  box-shadow: var(--sleek-soft-shadow);
}

.sleek-metrics article {
  min-height: 132px;
  padding: 22px;
}

.sleek-metrics span,
.grade-summary-card span,
.grade-folder small,
.agenda-card small {
  color: var(--sleek-muted);
}

.sleek-metrics strong {
  color: var(--sleek-ink);
  display: block;
  font-size: 2.3rem;
  line-height: 1;
  margin-top: 12px;
}

.sleek-section-title {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin: 12px 0 16px;
}

.sleek-section-title h2 {
  font-size: clamp(1.7rem, 7vw, 2.25rem);
  line-height: 1;
  margin: 0;
}

.sleek-section-title a,
.sleek-section-title span {
  color: var(--accent);
  font-size: 1rem;
  font-weight: 900;
}

.sleek-next-list {
  display: grid;
  gap: 18px;
  margin-bottom: 28px;
}

.sleek-next-item {
  align-items: center;
  background: var(--panel);
  border: 1px solid color-mix(in srgb, var(--line) 80%, transparent);
  display: grid;
  gap: 18px;
  grid-template-columns: auto minmax(0, 1fr) auto;
  min-height: 92px;
  padding: 18px 20px;
}

.sleek-next-item strong {
  display: block;
  font-size: 1.22rem;
  line-height: 1.15;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sleek-next-item small,
.sleek-next-item em {
  color: var(--sleek-muted);
  font-size: 1rem;
  font-style: normal;
  font-weight: 760;
}

.next-dot {
  background: color-mix(in srgb, var(--accent) 10%, var(--panel));
  border-radius: 26px;
  display: grid;
  height: 66px;
  place-items: center;
  width: 66px;
}

.next-dot i {
  background: var(--accent);
  border-radius: 50%;
  display: block;
  height: 28px;
  width: 28px;
}

.next-dot.exam {
  background: color-mix(in srgb, var(--bad) 10%, var(--panel));
}

.next-dot.exam i {
  background: var(--bad);
}

.next-dot.homework {
  background: color-mix(in srgb, #0284c7 10%, var(--panel));
}

.next-dot.homework i {
  background: #0284c7;
}

.sleek-bottom-grid {
  grid-template-columns: 1fr 1fr;
}

.sleek-bottom-grid .focus-card {
  min-height: 178px;
  padding: 22px;
}

.grade-summary-card {
  background: var(--panel);
  border: 1px solid var(--line);
  margin-bottom: 34px;
  padding: 28px 28px 24px;
}

.grade-summary-top {
  align-items: start;
  display: flex;
  justify-content: space-between;
}

.grade-summary-top span {
  display: block;
  font-size: 0.9rem;
  font-weight: 950;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.grade-summary-top strong {
  color: var(--accent);
  display: block;
  font-size: clamp(4.2rem, 20vw, 6rem);
  line-height: 0.95;
  margin-top: 18px;
}

.grade-summary-top em {
  background: var(--accent-soft);
  border-radius: 999px;
  color: var(--accent);
  font-size: 0.82rem;
  font-style: normal;
  font-weight: 950;
  padding: 10px 16px;
  text-transform: uppercase;
}

.grade-summary-stats {
  border-top: 1px solid var(--line);
  display: grid;
  gap: 14px;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 28px;
  padding-top: 24px;
}

.grade-summary-stats article {
  min-width: 0;
}

.grade-summary-stats span {
  display: block;
  font-size: 0.78rem;
  font-weight: 950;
  margin-bottom: 10px;
  text-transform: uppercase;
}

.grade-summary-stats strong {
  color: var(--sleek-ink);
  font-size: 1.65rem;
  line-height: 1;
}

.grade-list-title {
  margin-bottom: 18px;
}

.grade-folder-list {
  gap: 18px;
}

.subject-folder-row {
  align-items: stretch;
  gap: 10px;
}

.grade-folder {
  background: var(--panel);
  border: 1px solid var(--line);
  grid-template-columns: auto minmax(0, 1fr) auto;
  min-height: 98px;
  padding: 18px 20px;
}

.folder-icon {
  background: color-mix(in srgb, var(--accent) 10%, var(--panel));
  border-radius: 24px;
  color: var(--accent);
  height: 64px;
  width: 64px;
}

.grade-folder strong {
  font-size: 1.28rem;
  line-height: 1.1;
}

.grade-folder em {
  color: var(--sleek-ink);
  font-size: 1.6rem;
  font-style: normal;
  font-weight: 950;
}

.grade-folder b {
  display: none;
}

.delete-subject {
  align-self: center;
  border-radius: 18px;
  min-height: 56px;
  width: 56px;
}

.subject-add-form.show,
.grade-entry-form.show,
.target-grade-form.show,
.calendar-entry-form.show {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 28px;
  box-shadow: var(--sleek-soft-shadow);
  padding: 22px;
}

.planner-page-header {
  margin-bottom: 42px;
}

.planner-list-button { display: none; }

.planner-header-add {
  flex: 0 0 auto;
  height: 64px;
  width: 64px;
}

.cards-page-header {
  margin-bottom: 24px;
}

.cards-header-add {
  flex: 0 0 auto;
  height: 64px;
  width: 64px;
}

.cards-search-shell {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 24px;
  box-shadow: var(--sleek-soft-shadow);
  display: grid;
  gap: 12px;
  grid-template-columns: auto 1fr;
  margin: 0 0 22px;
  min-height: 62px;
  padding: 0 18px;
}

.cards-search-shell .icon {
  color: var(--accent);
  height: 22px;
  width: 22px;
}

.cards-search-shell input {
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  color: var(--sleek-ink);
  font-size: 1rem;
  font-weight: 850;
  min-height: 58px;
  padding: 0;
}

.cards-search-shell input:focus {
  outline: none;
}

.cards-search-shell:focus-within {
  border-color: color-mix(in srgb, var(--accent) 44%, var(--line));
  box-shadow: 0 18px 40px color-mix(in srgb, var(--accent) 14%, transparent);
}

.card-search-results {
  display: grid;
  gap: 12px;
  margin-bottom: 22px;
}

.search-deck-row {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 22px;
  box-shadow: var(--shadow-soft);
  color: var(--sleek-ink);
  cursor: pointer;
  display: grid;
  gap: 12px;
  grid-template-columns: auto minmax(0, 1fr) auto;
  min-height: 82px;
  padding: 14px;
  text-align: left;
}

.search-deck-row:hover,
.search-deck-row:focus-visible {
  border-color: color-mix(in srgb, var(--accent) 42%, var(--line));
  transform: translateY(-1px);
}

.search-deck-row strong,
.search-deck-row small {
  display: block;
}

.search-deck-row strong {
  font-size: 1.05rem;
  line-height: 1.15;
}

.search-deck-row small,
.search-deck-row em {
  color: var(--muted);
  font-size: 0.82rem;
  font-style: normal;
  font-weight: 850;
}

.mini-deck-stack.database i {
  background: color-mix(in srgb, var(--accent) 18%, var(--panel));
}

.calendar-only-panel {
  background: transparent;
  border: 0;
  box-shadow: none;
  padding: 0;
}

.calendar-only-panel.form-mode {
  background: transparent;
}

.sleek-month-selector,
.form-only-header {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 24px;
  box-shadow: var(--sleek-soft-shadow);
  display: flex;
  justify-content: space-between;
  margin-bottom: 34px;
  min-height: 78px;
  padding: 0 18px;
}

.sleek-month-selector button {
  background: transparent;
  border: 0;
  color: var(--sleek-ink);
  cursor: pointer;
  font-size: 3rem;
  line-height: 1;
  width: 48px;
}

.sleek-month-selector strong {
  font-size: clamp(1.7rem, 7vw, 2.25rem);
  line-height: 1;
  text-align: center;
}

.form-only-header h2 {
  font-size: 1.7rem;
  line-height: 1;
  margin: 4px 0 0;
}

.form-only-header span {
  color: var(--accent);
  font-size: 0.78rem;
  font-weight: 950;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.month-panel {
  background: transparent;
  border: 0;
  box-shadow: none;
  padding: 0;
}

.month-panel h3 {
  display: none;
}

.weekdays {
  color: var(--sleek-muted);
  display: grid;
  font-size: 0.96rem;
  gap: 0;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 22px;
  text-transform: uppercase;
}

.calendar-grid {
  gap: 14px 8px;
}

.calendar-cell {
  aspect-ratio: auto;
  background: transparent;
  border: 0;
  border-radius: 999px;
  color: inherit;
  cursor: pointer;
  display: grid;
  font: inherit;
  min-height: 46px;
  overflow: visible;
  padding: 0;
  place-items: center;
}

.calendar-cell strong {
  align-items: center;
  border-radius: 999px;
  color: var(--sleek-ink);
  display: inline-flex;
  font-size: 1.45rem;
  font-weight: 780;
  height: 52px;
  justify-content: center;
  margin: 0;
  position: relative;
  width: 52px;
}

.calendar-cell.empty strong,
.calendar-cell.empty {
  color: color-mix(in srgb, var(--muted) 38%, transparent);
}

.calendar-cell span {
  background: var(--accent);
  border-radius: 999px;
  color: transparent;
  font-size: 0;
  height: 7px;
  margin-top: -6px;
  padding: 0;
  width: 7px;
}

.calendar-cell .exam-dot {
  background: var(--bad);
}

.calendar-cell .homework-dot {
  background: #0284c7;
}

.calendar-cell.today strong {
  background: var(--accent);
  box-shadow: 0 16px 34px color-mix(in srgb, var(--accent) 28%, transparent);
  color: #fff;
  font-weight: 950;
  height: 68px;
  width: 68px;
}

.calendar-cell.selected:not(.today) strong {
  background: color-mix(in srgb, var(--accent) 14%, var(--panel));
  box-shadow: inset 0 0 0 2px color-mix(in srgb, var(--accent) 24%, transparent);
  color: var(--accent);
  font-weight: 950;
}

.calendar-cell.today {
  box-shadow: none;
}

.planner-agenda {
  margin-top: 36px;
}

.planner-agenda-list {
  display: grid;
  gap: 18px;
}

.agenda-card {
  background: var(--panel);
  border: 1px solid var(--line);
  border-left: 7px solid var(--accent);
  display: flex;
  gap: 16px;
  justify-content: space-between;
  min-height: 92px;
  padding: 20px 22px;
}

.agenda-card.homework {
  border-left-color: #0284c7;
}

.agenda-card.exam {
  border-left-color: var(--accent);
}

.agenda-card strong {
  display: block;
  font-size: 1.25rem;
  line-height: 1.12;
  margin-bottom: 8px;
}

.agenda-card em {
  align-self: start;
  background: var(--accent-soft);
  border-radius: 10px;
  color: var(--accent);
  font-size: 0.82rem;
  font-style: normal;
  font-weight: 950;
  padding: 8px 10px;
  text-transform: uppercase;
}

.agenda-card.homework em {
  background: color-mix(in srgb, #0284c7 12%, var(--panel));
  color: #0284c7;
}

.planner-floating-add {
  background: var(--accent);
  bottom: 108px;
  font-size: 2.7rem;
  height: 74px;
  right: max(24px, calc((100vw - 520px) / 2 + 24px));
  width: 74px;
}

.bottom-nav {
  background: color-mix(in srgb, var(--panel) 94%, transparent);
  border: 1px solid color-mix(in srgb, var(--line) 88%, transparent);
  border-radius: 30px 30px 0 0;
  box-shadow: 0 -14px 40px rgba(17, 24, 39, 0.08);
  gap: 0;
  left: 50%;
  max-width: 520px;
  padding: 12px 12px 16px;
  right: auto;
  transform: translateX(-50%);
  width: 100%;
}

.bottom-nav a {
  border-radius: 20px;
  color: var(--sleek-muted);
  font-size: 0.84rem;
  min-height: 64px;
}

.bottom-nav a.active {
  background: transparent;
  color: var(--accent);
}

.bottom-nav a.active .nav-icon {
  background: var(--accent);
  color: #fff;
  transform: translateY(-2px);
}

.nav-icon {
  align-items: center;
  border-radius: 999px;
  display: inline-flex;
  font-size: 1.35rem;
  height: 30px;
  justify-content: center;
  min-width: 30px;
  transition: transform 180ms ease, background 180ms ease;
}

html[data-card-style="clean"] .panel,
html[data-card-style="clean"] .focus-card,
html[data-card-style="clean"] .grade-summary-card,
html[data-card-style="clean"] .grade-folder,
html[data-card-style="clean"] .sleek-next-item,
html[data-card-style="clean"] .agenda-card,
html[data-card-style="clean"] .sleek-month-selector {
  box-shadow: none;
}

@media (min-width: 760px) {
  body {
    background: #05070d;
    padding: 24px 0;
  }

  .app-shell {
    border: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
    border-radius: 56px;
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.28);
    margin: 0 auto;
    max-width: 520px;
    min-height: calc(100vh - 48px);
    overflow: hidden;
    position: relative;
  }

  .topbar {
    left: 50%;
    max-width: 520px;
    position: fixed;
    top: 24px;
    transform: translateX(-50%);
    width: 100%;
  }

  .main-content {
    min-height: calc(100vh - 48px);
  }

  .bottom-nav {
    bottom: 24px;
    border-radius: 30px;
  }
}

@media (max-width: 520px) {
  .topbar {
    padding: 14px 18px 0;
  }

  .main-content {
    padding: 58px 18px 108px;
  }

  .sleek-page-header,
  .grade-page-header,
  .planner-page-header {
    margin-bottom: 26px;
  }

  .sleek-page-header h1,
  .grade-page-header h1,
  .planner-page-header h1,
  .home-page h1 {
    font-size: clamp(2.7rem, 17vw, 3.7rem);
  }

  .grade-page-header.folder-detail-header h1 {
    font-size: clamp(1.55rem, var(--fit-title-size, 2.7rem), 3.05rem);
  }

  .sleek-header-actions {
    gap: 8px;
  }

  .sleek-mini-pill {
    min-height: 48px;
    padding: 0 14px;
  }

  .sleek-avatar {
    height: 52px;
    width: 52px;
  }

  .sleek-avatar .mascot-face {
    height: 100%;
    width: 100%;
  }

  .sleek-coach-card {
    border-radius: 28px;
    padding: 24px;
  }

  .sleek-metrics,
  .sleek-bottom-grid {
    grid-template-columns: 1fr 1fr;
  }

  .grade-summary-card {
    padding: 24px 22px;
  }

  .grade-summary-stats strong {
    font-size: 1.34rem;
  }

  .calendar-grid {
    gap: 12px 4px;
  }

  .calendar-cell strong {
    font-size: 1.22rem;
    height: 44px;
    width: 44px;
  }

  .calendar-cell.today strong {
    height: 58px;
    width: 58px;
  }
}

/* Fixes after the Sleek pass: one top header, cleaner cards, polished mistake bank. */
.topbar {
  border-bottom: 0;
  position: static;
  top: auto;
  z-index: 20;
}

.main-content {
  padding-top: 34px;
}

.streak-pill {
  background: color-mix(in srgb, #111827 76%, var(--panel));
  border-color: color-mix(in srgb, #fb923c 34%, var(--line));
  color: #fb923c;
  min-height: 38px;
  padding: 5px 11px 5px 7px;
}

.streak-pill strong {
  color: #facc15;
  font-size: 1rem;
}

.streak-flame {
  height: 24px;
  width: 24px;
}

.top-actions .theme-icon-button,
.top-actions .account-button {
  background: color-mix(in srgb, #111827 78%, var(--panel));
  color: #dbeafe;
}

html[data-theme="light"] .top-actions .theme-icon-button,
html[data-theme="light"] .top-actions .account-button {
  background: var(--panel);
  color: var(--muted);
}

.brand-logo {
  border: 0;
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
}

.cards-main-stacks {
  grid-template-columns: 1fr;
  margin-bottom: 28px;
}

.cards-main-stacks .quizlet-large-stack {
  min-height: 154px;
}

.cards-recent-title {
  margin-top: 8px;
}

.recent-card-list {
  background: transparent;
  border: 0;
  box-shadow: none;
  display: grid;
  gap: 14px;
  padding: 0;
}

.recent-card-row {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 22px;
  box-shadow: var(--sleek-soft-shadow);
  display: grid;
  gap: 4px 16px;
  grid-template-columns: minmax(0, 1fr) auto;
  min-height: 92px;
  padding: 18px 20px;
}

.recent-card-row span {
  background: var(--accent-soft);
  color: var(--accent);
  font-size: 0.78rem;
  font-weight: 950;
  width: fit-content;
}

.recent-card-row h3 {
  font-size: 1.18rem;
  grid-column: 1;
  margin: 4px 0 0;
}

.recent-card-row p {
  color: var(--muted);
  grid-column: 1;
  margin: 0;
}

.recent-card-row small {
  align-self: center;
  background: var(--panel-2);
  border-radius: 999px;
  color: var(--muted);
  font-weight: 900;
  grid-column: 2;
  grid-row: 1 / span 3;
  padding: 8px 10px;
}

.recent-deck-list {
  display: grid;
  gap: 14px;
  margin-bottom: 84px;
}

.recent-deck-row {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 24px;
  box-shadow: var(--sleek-soft-shadow);
  color: var(--ink);
  cursor: pointer;
  display: grid;
  gap: 16px;
  grid-template-columns: auto minmax(0, 1fr) auto;
  min-height: 104px;
  padding: 18px 20px;
  text-align: left;
  width: 100%;
}

.recent-deck-row:hover {
  border-color: color-mix(in srgb, var(--accent) 34%, var(--line));
  transform: translateY(-1px);
}

.mini-deck-stack {
  height: 58px;
  position: relative;
  width: 64px;
}

.mini-deck-stack i {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 12px;
  box-shadow: var(--shadow-soft);
  display: block;
  height: 44px;
  left: 8px;
  position: absolute;
  top: 8px;
  width: 46px;
}

.mini-deck-stack i:nth-child(1) { transform: rotate(-9deg) translate(-5px, 4px); }
.mini-deck-stack i:nth-child(2) { transform: rotate(5deg) translate(4px, -1px); }
.mini-deck-stack i:nth-child(3) { background: linear-gradient(145deg, var(--accent), var(--green)); transform: rotate(0); }

.recent-deck-row strong,
.recent-deck-row small {
  display: block;
}

.recent-deck-row strong {
  font-size: 1.18rem;
  line-height: 1.12;
}

.recent-deck-row small {
  color: var(--muted);
  font-weight: 760;
  margin-top: 5px;
}

.recent-deck-row em {
  align-items: center;
  background: var(--accent-soft);
  border-radius: 999px;
  color: var(--accent);
  display: inline-flex;
  font-style: normal;
  font-weight: 950;
  height: 42px;
  justify-content: center;
  min-width: 42px;
}

.mistake-page {
  max-width: 520px;
}

.mistake-header {
  align-items: start;
  display: grid;
  gap: 18px;
}

.mistake-header .eyebrow {
  color: var(--accent);
  font-size: 0.82rem;
}

.mistake-header h1 {
  color: var(--sleek-ink);
  font-size: clamp(3rem, 16vw, 4.3rem);
}

.mistake-header .coach-action-row {
  display: grid;
  grid-template-columns: 1fr;
}

.mistake-header .primary-button,
.mistake-header .secondary-button {
  border-radius: 999px;
  min-height: 58px;
}

.mistake-add-form.show {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 28px;
  box-shadow: var(--sleek-soft-shadow);
  padding: 22px;
}

.mistake-stats {
  grid-template-columns: 1fr 1fr;
}

.mistake-stats article {
  border-radius: 24px;
  min-height: 116px;
  padding: 20px;
}

.mistake-stats strong {
  color: var(--accent);
  font-size: 2.5rem;
}

.segmented-actions {
  border-radius: 999px;
  box-shadow: var(--sleek-soft-shadow);
  padding: 7px;
}

.segmented-actions button {
  border-radius: 999px;
}

.mistake-list {
  gap: 16px;
}

.mistake-card {
  border-radius: 26px;
  box-shadow: var(--sleek-soft-shadow);
  padding: 22px;
}

.mistake-card-top strong {
  background: var(--accent-soft);
  border-radius: 999px;
  color: var(--accent);
  padding: 8px 11px;
}

.mistake-card-top span {
  font-size: 0.78rem;
  font-weight: 850;
  text-align: right;
}

.mistake-card h2 {
  font-size: 1.35rem;
  margin: 18px 0;
}

.mistake-card dl {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 14px;
}

.mistake-card .primary-button,
.mistake-card .secondary-button {
  border-radius: 999px;
  width: 100%;
}

.bottom-nav {
  align-items: center;
  border-radius: 0;
  display: grid;
  grid-template-columns: repeat(6, 1fr);
}

.bottom-nav a {
  gap: 5px;
}

.nav-icon {
  background: transparent;
  color: currentColor;
  height: 30px;
  min-width: 30px;
  position: relative;
}

.nav-icon svg {
  fill: none;
  height: 30px;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 2.15;
  width: 30px;
}

.cards-nav-icon svg {
  height: 31px;
  width: 31px;
}

.bottom-nav a.active .nav-icon {
  background: transparent;
  color: var(--accent);
  transform: none;
}

.bottom-nav a.active .nav-icon::after {
  background: var(--accent);
  border-radius: 999px;
  bottom: -9px;
  content: "";
  height: 5px;
  left: 50%;
  position: absolute;
  transform: translateX(-50%);
  width: 5px;
}

.nav-badge {
  align-items: center;
  background: var(--bad);
  border: 2px solid var(--panel);
  border-radius: 999px;
  color: #fff;
  display: inline-flex;
  font-size: 0.72rem;
  font-weight: 950;
  height: 22px;
  justify-content: center;
  min-width: 22px;
  padding: 0 5px;
  position: absolute;
  right: -8px;
  top: -7px;
}

.nav-badge[hidden] {
  display: none;
}

.gamification-home-grid {
  margin-top: 16px;
}

.daily-quests-card,
.progress-teaser-card,
.level-card,
.challenge-card,
.team-goal-card,
.privacy-note-card,
.badge-chip,
.leaderboard-row {
  background: var(--panel);
  border: 1px solid var(--line);
  box-shadow: var(--shadow-soft);
}

.daily-quests-card,
.progress-teaser-card {
  border-radius: 28px;
  display: grid;
  gap: 14px;
  min-height: 190px;
  padding: 22px;
}

.progress-teaser-card {
  color: inherit;
}

.progress-teaser-card p {
  margin-bottom: 2px;
}

.progress-teaser-card em {
  color: var(--accent);
  font-style: normal;
  font-weight: 950;
  margin-top: 2px;
}

.quest-card-head,
.level-card-top,
.challenge-card,
.xp-meta,
.privacy-note-card {
  align-items: center;
  display: flex;
  gap: 14px;
  justify-content: space-between;
}

.quest-card-head h2,
.level-card h2,
.challenge-card h2,
.team-goal-card h2 {
  font-size: 1.22rem;
  line-height: 1.2;
  margin: 4px 0 0;
}

.quest-card-head strong {
  background: var(--accent-soft);
  border-radius: 999px;
  color: var(--accent);
  flex: 0 0 auto;
  font-size: 0.9rem;
  padding: 9px 12px;
}

.quest-list,
.leaderboard-list,
.record-list {
  display: grid;
  gap: 10px;
}

.quest-row {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 18px;
  color: inherit;
  display: grid;
  gap: 9px;
  padding: 12px;
}

.quest-row div {
  align-items: center;
  display: flex;
  justify-content: space-between;
  gap: 10px;
}

.quest-row small {
  color: var(--muted);
  font-weight: 900;
}

.quest-row.completed strong::after {
  color: var(--good);
  content: " ✓";
}

.quest-progress,
.xp-progress,
.team-goal-row i {
  background: color-mix(in srgb, var(--accent) 10%, var(--panel-2));
  border-radius: 999px;
  display: block;
  height: 9px;
  overflow: hidden;
  width: 100%;
}

.quest-progress i,
.xp-progress i,
.team-goal-row b {
  background: linear-gradient(90deg, var(--accent), var(--green));
  border-radius: inherit;
  display: block;
  height: 100%;
}

.xp-progress.large {
  height: 14px;
}

.progress-page {
  display: grid;
  gap: 18px;
  margin: 0 auto;
  max-width: 760px;
}

.progress-tabs {
  background: color-mix(in srgb, var(--panel) 92%, var(--soft));
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-bottom: 0;
}

.progress-personal,
.friends-progress {
  display: grid;
  gap: 16px;
}

.level-card {
  border-radius: 30px;
  display: grid;
  gap: 18px;
  padding: 24px;
}

.level-card span,
.challenge-card span {
  color: var(--green);
  display: block;
  font-size: 0.76rem;
  font-weight: 950;
  text-transform: uppercase;
}

.level-card p,
.challenge-card p {
  color: var(--muted);
  line-height: 1.45;
  margin: 6px 0 0;
}

.level-goal-row {
  align-items: center;
  display: grid;
  gap: 8px;
  grid-template-columns: 1fr auto 1fr;
}

.level-goal-row span,
.level-goal-row strong {
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 950;
  line-height: 1.2;
  text-transform: none;
}

.level-goal-row span:last-child {
  text-align: right;
}

.level-goal-row strong {
  background: color-mix(in srgb, var(--accent) 12%, var(--panel-2));
  border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
  border-radius: 999px;
  color: var(--accent);
  padding: 8px 10px;
  text-align: center;
  white-space: nowrap;
}

.level-card .mascot-face {
  height: 56px;
  width: 56px;
}

.xp-meta strong,
.xp-meta span {
  color: var(--muted);
  font-size: 0.9rem;
}

.xp-meta strong {
  color: var(--ink);
}

.progress-mascot-card {
  border-radius: 24px;
  padding: 15px;
}

.progress-stat-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.progress-stat-grid article {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 22px;
  box-shadow: var(--shadow-soft);
  min-height: 112px;
  padding: 17px;
}

.progress-stat-grid span,
.record-list span {
  color: var(--muted);
  display: block;
  font-size: 0.82rem;
  font-weight: 900;
}

.progress-stat-grid strong {
  display: block;
  font-size: 2rem;
  line-height: 1;
  margin: 9px 0 6px;
}

.progress-stat-grid small {
  color: var(--muted);
}

.personal-records-card {
  border-radius: 26px;
  padding: 22px;
}

.record-list {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.record-list span {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 13px;
}

.record-list strong {
  color: var(--ink);
  display: block;
  font-size: 1.25rem;
  margin-top: 4px;
}

.badge-grid {
  display: grid;
  gap: 10px;
}

.badge-chip {
  align-items: center;
  border-radius: 18px;
  display: flex;
  gap: 12px;
  padding: 13px;
}

.badge-chip > span {
  align-items: center;
  background: var(--accent-soft);
  border-radius: 14px;
  color: var(--accent);
  display: inline-flex;
  height: 42px;
  justify-content: center;
  width: 42px;
}

.badge-chip.locked {
  opacity: 0.58;
}

.badge-chip strong,
.leaderboard-row b {
  display: block;
}

.badge-chip small,
.leaderboard-row small {
  color: var(--muted);
  display: block;
  margin-top: 2px;
}

.challenge-card {
  border-radius: 30px;
  padding: 22px;
}

.leaderboard-tabs {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 999px;
  display: grid;
  gap: 5px;
  grid-template-columns: repeat(4, 1fr);
  padding: 6px;
}

.leaderboard-tab {
  background: transparent;
  border: 0;
  border-radius: 999px;
  color: var(--muted);
  cursor: pointer;
  font-size: 0.72rem;
  font-weight: 950;
  min-height: 38px;
  padding: 0 8px;
}

.leaderboard-tab.active {
  background: var(--accent);
  color: var(--white);
}

.leaderboard-mode-pill {
  align-items: center;
  background: color-mix(in srgb, var(--accent) 12%, var(--panel));
  border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
  border-radius: 999px;
  color: var(--accent);
  display: inline-flex;
  font-size: 0.78rem;
  font-weight: 950;
  justify-content: center;
  min-height: 38px;
  padding: 0 14px;
  width: fit-content;
}

.leaderboard-row {
  align-items: center;
  border-radius: 22px;
  display: grid;
  gap: 12px;
  grid-template-columns: 28px 44px 1fr auto;
  padding: 13px;
}

.leaderboard-row > strong {
  color: var(--muted);
  text-align: center;
}

.leaderboard-row.you {
  border-color: color-mix(in srgb, var(--accent) 34%, var(--line));
}

.leaderboard-row.private {
  background: color-mix(in srgb, var(--accent) 5%, var(--panel));
}

.friend-avatar {
  align-items: center;
  background: linear-gradient(145deg, var(--accent), var(--green));
  border-radius: 15px;
  color: var(--white);
  display: inline-flex;
  font-weight: 950;
  height: 44px;
  justify-content: center;
  width: 44px;
}

.leaderboard-row em {
  color: var(--accent);
  font-style: normal;
  font-weight: 950;
  text-align: right;
}

.team-goal-card {
  border-radius: 26px;
  display: grid;
  gap: 14px;
  padding: 20px;
}

.team-goal-row {
  display: grid;
  gap: 8px;
}

.team-goal-row span {
  color: var(--muted);
  font-weight: 900;
}

.team-goal-row strong {
  font-size: 1.1rem;
}

.privacy-note-card {
  border-radius: 20px;
  color: var(--muted);
  justify-content: flex-start;
  line-height: 1.45;
  padding: 14px;
}

.privacy-note-card .icon {
  color: var(--accent);
  flex: 0 0 auto;
}

.leaderboard-privacy-card {
  border-radius: 26px;
}

.xp-toast-layer {
  align-items: center;
  bottom: 92px;
  display: flex;
  flex-direction: column-reverse;
  gap: 4px;
  left: 50%;
  pointer-events: none;
  position: fixed;
  transform: translateX(-50%);
  width: 92px;
  z-index: 80;
}

.xp-toast {
  align-items: center;
  animation: xpBoltRise 1050ms ease forwards;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  color: var(--ink);
  display: grid;
  gap: 3px;
  grid-template-columns: 1fr;
  justify-items: center;
  min-height: 72px;
  padding: 0;
  position: relative;
  width: 72px;
}

.xp-toast strong {
  background: var(--panel);
  border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--line));
  border-radius: 999px;
  box-shadow: 0 10px 24px color-mix(in srgb, var(--accent) 20%, transparent);
  color: var(--accent);
  font-size: 0.86rem;
  font-weight: 1000;
  line-height: 1;
  padding: 7px 9px;
}

.xp-toast span {
  border: 0;
  clip: rect(0 0 0 0);
  height: 1px;
  margin: -1px;
  overflow: hidden;
  padding: 0;
  position: absolute;
  width: 1px;
}

.xp-toast i {
  background: linear-gradient(160deg, #fde047, #f59e0b);
  clip-path: polygon(47% 0, 88% 0, 62% 39%, 98% 39%, 35% 100%, 48% 56%, 12% 56%);
  filter: drop-shadow(0 8px 14px rgba(245, 158, 11, 0.34));
  height: 34px;
  width: 30px;
}

.xp-toast.level-up-toast {
  animation-duration: 1800ms;
  background: var(--panel);
  border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
  border-radius: 20px;
  box-shadow: var(--shadow);
  grid-template-columns: auto 1fr;
  justify-items: start;
  padding: 10px;
  width: min(260px, calc(100vw - 34px));
}

.xp-toast.level-up-toast strong {
  background: transparent;
  border: 0;
  box-shadow: none;
  color: var(--ink);
  font-size: 0.98rem;
  padding: 0;
}

.xp-toast.level-up-toast span {
  clip: auto;
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 900;
  height: auto;
  margin: 0;
  overflow: visible;
  position: static;
  width: auto;
}

.xp-toast.level-up-toast .mascot-face {
  height: 44px;
  width: 44px;
}

.xp-toast.level-up-toast div {
  display: grid;
  gap: 3px;
}

.class-league-page {
  display: grid;
  gap: 16px;
}

.class-league-hero {
  align-items: center;
  background: radial-gradient(circle at 92% 12%, color-mix(in srgb, var(--green) 18%, transparent), transparent 42%), linear-gradient(145deg, color-mix(in srgb, var(--accent) 13%, var(--panel)), var(--panel));
  border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
  border-radius: 30px;
  box-shadow: var(--shadow-soft);
  display: flex;
  gap: 16px;
  justify-content: space-between;
  padding: 24px;
}

.class-league-hero span,
.class-team-goal .panel-header span {
  color: var(--green);
  display: block;
  font-size: 0.76rem;
  font-weight: 950;
  text-transform: uppercase;
}

.class-league-hero h2 {
  font-size: clamp(2rem, 10vw, 3.4rem);
  line-height: 0.95;
  margin: 8px 0;
}

.class-league-hero p {
  color: var(--muted);
  font-weight: 850;
  margin: 0;
}

.league-badge-stack {
  align-items: center;
  display: grid;
  gap: 8px;
  justify-items: center;
}

.league-badge {
  align-items: center;
  background: transparent;
  border: 0;
  border-radius: 24px;
  color: #e0f2fe;
  display: inline-flex;
  flex: 0 0 auto;
  font-size: 0.82rem;
  height: 132px;
  justify-content: center;
  line-height: 1.25;
  max-width: none;
  min-height: 132px;
  overflow: hidden;
  padding: 0;
  position: relative;
  text-align: center;
  width: 132px;
}

.league-title-row {
  margin-top: 8px;
}

.league-symbol {
  align-items: center;
  background: color-mix(in srgb, var(--panel) 88%, #020617);
  border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line));
  border-radius: 999px;
  color: var(--accent);
  display: inline-flex;
  gap: 8px;
  justify-content: center;
  min-height: 42px;
  min-width: 42px;
  padding: 7px 10px;
  vertical-align: middle;
}

.league-image-symbol {
  background: #07111f;
  border-color: color-mix(in srgb, var(--accent) 26%, #1e293b);
  box-shadow: 0 10px 22px rgba(15, 23, 42, 0.14);
  padding: 4px;
}

.league-image-symbol img {
  border-radius: 999px;
  display: block;
  height: 30px;
  object-fit: cover;
  width: 30px;
}

.league-symbol svg {
  height: 24px;
  width: 24px;
}

.league-symbol svg path,
.league-symbol svg circle {
  fill: none;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 2;
}

.league-symbol small {
  color: var(--ink);
  font-size: 0.78rem;
  font-weight: 950;
  line-height: 1.05;
  max-width: 96px;
}

.league-symbol.league-snow {
  color: #60a5fa;
}

.league-symbol.league-forest {
  color: #22c55e;
}

.league-symbol.league-alpine {
  color: #38bdf8;
}

.league-symbol.league-shadow {
  color: #a78bfa;
}

.league-symbol.league-northern {
  color: #f59e0b;
}

.progress-teaser-card h2 .league-symbol,
.level-card .league-symbol,
.xp-meta .league-symbol {
  min-height: 34px;
  min-width: 34px;
  padding: 5px 8px;
}

.progress-teaser-card h2 .league-symbol svg,
.level-card .league-symbol svg,
.xp-meta .league-symbol svg {
  height: 20px;
  width: 20px;
}

.progress-teaser-card h2 {
  line-height: 1;
  margin: 2px 0 0;
}

.league-badge .league-symbol {
  background: transparent;
  border: 0;
  color: inherit;
  flex-direction: column;
  gap: 8px;
  height: 100%;
  inset: 0;
  min-height: 100%;
  min-width: 100%;
  padding: 0;
  position: absolute;
  width: 100%;
}

.league-badge .league-image-symbol {
  border-radius: 0;
  box-shadow: none;
  min-height: 0;
  padding: 0;
}

.league-badge .league-image-symbol img {
  border-radius: 22px;
  height: 100%;
  object-fit: contain;
  object-position: center;
  transform: none;
  width: 100%;
}

.league-badge-name {
  align-items: center;
  background: transparent;
  color: var(--ink);
  display: flex;
  font-size: 0.78rem;
  font-weight: 1000;
  justify-content: center;
  letter-spacing: 0;
  line-height: 1.12;
  max-width: 140px;
  min-height: 0;
  padding: 0 4px;
  position: static;
  text-align: center;
  text-transform: uppercase;
  width: auto;
}

.league-badge .league-symbol small {
  color: #e0f2fe;
  display: block;
  font-size: 0.78rem;
  line-height: 1.12;
  max-width: 116px;
}

.class-league-form {
  border-radius: 26px;
}

.class-tabs {
  grid-template-columns: repeat(5, 1fr);
}

.class-league-tab {
  background: transparent;
  border: 0;
  border-radius: 999px;
  color: var(--muted);
  cursor: pointer;
  font-size: 0.72rem;
  font-weight: 950;
  min-height: 44px;
  padding: 0 8px;
}

.class-league-tab.active {
  background: var(--accent);
  color: var(--white);
}

html[data-theme="dark"] .settings-tabs,
html[data-theme="dark"] .progress-tabs,
html[data-theme="dark"] .leaderboard-tabs,
html[data-theme="dark"] .class-tabs {
  background: color-mix(in srgb, var(--panel) 82%, #020617);
  border-color: color-mix(in srgb, var(--accent) 20%, var(--line));
}

html[data-theme="dark"] .settings-tab,
html[data-theme="dark"] .progress-tab,
html[data-theme="dark"] .leaderboard-tab,
html[data-theme="dark"] .class-league-tab {
  color: #b8c4d6;
}

html[data-theme="dark"] .settings-tab:hover,
html[data-theme="dark"] .progress-tab:hover,
html[data-theme="dark"] .leaderboard-tab:hover,
html[data-theme="dark"] .class-league-tab:hover {
  background: color-mix(in srgb, var(--accent) 16%, transparent);
  color: #f8fbff;
}

html[data-theme="dark"] .settings-tab.active,
html[data-theme="dark"] .progress-tab.active,
html[data-theme="dark"] .leaderboard-tab.active,
html[data-theme="dark"] .class-league-tab.active {
  background: var(--accent);
  box-shadow: 0 10px 24px color-mix(in srgb, var(--accent) 24%, transparent);
  color: var(--white);
}

.class-rank-row {
  grid-template-columns: 38px 44px 1fr auto;
  min-height: 70px;
  position: relative;
}

.league-rank-number {
  color: var(--muted);
  text-align: center;
}

.league-rank-medal {
  align-items: center;
  background: var(--medal-color);
  border: 2px solid var(--medal-edge);
  border-radius: 50%;
  box-shadow: inset 0 2px 3px rgba(255, 255, 255, 0.42), 0 4px 10px rgba(15, 23, 42, 0.2);
  color: var(--medal-number);
  display: inline-flex;
  height: 34px;
  justify-content: center;
  justify-self: center;
  position: relative;
  width: 34px;
  z-index: 1;
}

.league-rank-medal::before,
.league-rank-medal::after {
  background: var(--medal-ribbon);
  bottom: -8px;
  clip-path: polygon(0 0, 100% 0, 72% 100%, 50% 72%, 28% 100%);
  content: "";
  height: 15px;
  position: absolute;
  width: 12px;
  z-index: -1;
}

.league-rank-medal::before {
  left: 3px;
  transform: rotate(9deg);
}

.league-rank-medal::after {
  right: 3px;
  transform: rotate(-9deg);
}

.league-rank-medal span {
  font-size: 0.9rem;
  font-weight: 1000;
  line-height: 1;
}

.leaderboard-row > .league-rank-medal {
  color: var(--medal-number);
}

.league-rank-medal.medal-1 {
  --medal-color: #facc15;
  --medal-edge: #ca8a04;
  --medal-number: #713f12;
  --medal-ribbon: #eab308;
}

.league-rank-medal.medal-2 {
  --medal-color: #e2e8f0;
  --medal-edge: #94a3b8;
  --medal-number: #334155;
  --medal-ribbon: #94a3b8;
}

.league-rank-medal.medal-3 {
  --medal-color: #d97706;
  --medal-edge: #92400e;
  --medal-number: #fff7ed;
  --medal-ribbon: #b45309;
}

.class-rank-row.you {
  background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 10%, var(--panel)), var(--panel));
}

.class-rank-row::before {
  border-radius: 999px;
  content: "";
  height: calc(100% - 22px);
  left: 0;
  position: absolute;
  top: 11px;
  width: 4px;
}

.class-rank-row.result-podium::before {
  background: var(--good);
}

.class-rank-row.result-level-up::before {
  background: var(--accent);
}

.class-rank-row.result-stay::before {
  background: var(--muted);
  opacity: 0.45;
}

.class-rank-row.result-demote::before {
  background: var(--bad);
}

.class-podium-card {
  background: radial-gradient(circle at 50% 0%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 52%), var(--panel);
  border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--line));
  border-radius: 28px;
  box-shadow: var(--shadow-soft);
  display: grid;
  gap: 14px;
  padding: 20px;
}

.class-podium-card .panel-header strong {
  background: var(--accent-soft);
  border-radius: 999px;
  color: var(--accent);
  flex: 0 0 auto;
  font-size: 0.78rem;
  padding: 8px 10px;
}

.class-podium-card p {
  color: var(--muted);
  font-weight: 850;
  line-height: 1.45;
  margin: 0;
}

.class-podium {
  align-items: end;
  display: grid;
  gap: 0;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin: 2px auto 0;
  max-width: 520px;
  padding: 4px 4px 0;
  width: 100%;
}

.podium-place {
  align-items: end;
  background: transparent;
  border: 0;
  border-radius: 0;
  display: grid;
  gap: 8px;
  justify-items: center;
  min-height: 190px;
  padding: 0 3px;
  text-align: center;
}

.podium-trophy {
  display: block;
  filter: drop-shadow(0 9px 13px rgba(15, 23, 42, 0.18));
  height: 54px;
  margin-bottom: -2px;
  width: 54px;
}

.podium-trophy path {
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 4;
}

.podium-trophy .cup-main,
.podium-trophy .cup-base,
.podium-trophy .cup-stem {
  fill: currentColor;
  stroke: color-mix(in srgb, currentColor 72%, #111827);
}

.podium-trophy .cup-side {
  stroke: color-mix(in srgb, currentColor 82%, #111827);
}

.podium-trophy .cup-shine {
  opacity: 0.35;
  stroke: #fff;
}

.podium-block {
  align-items: center;
  background: linear-gradient(180deg, #f8fafc, #cbd5e1);
  border: 2px solid #94a3b8;
  border-bottom-width: 5px;
  border-radius: 5px 5px 0 0;
  box-shadow: inset 0 2px 0 rgba(255, 255, 255, 0.68), 0 14px 28px rgba(15, 23, 42, 0.12);
  color: #94a3b8;
  display: inline-flex;
  height: 86px;
  justify-content: center;
  width: 100%;
}

.podium-block span {
  font-size: clamp(2.2rem, 11vw, 4.6rem);
  font-weight: 1000;
  line-height: 1;
  text-shadow: 0 2px 0 rgba(255, 255, 255, 0.7);
}

.podium-name {
  display: grid;
  gap: 2px;
  min-height: 42px;
  order: 3;
}

.podium-name strong {
  font-size: 1rem;
}

.podium-name small {
  color: var(--muted);
  font-weight: 900;
}

.podium-place.place-1 {
  min-height: 232px;
  order: 2;
}

.podium-place.place-2 {
  min-height: 204px;
  order: 1;
}

.podium-place.place-3 {
  min-height: 192px;
  order: 3;
}

.podium-place.place-1 .podium-block {
  border-color: #d97706;
  color: #d59a15;
  height: 122px;
}

.podium-place.place-2 .podium-block {
  height: 92px;
}

.podium-place.place-3 .podium-block {
  border-color: #b45309;
  color: #b45309;
  height: 76px;
}

.podium-place.place-1 .podium-trophy {
  color: #d59a15;
  height: 64px;
  width: 64px;
}

.podium-place.place-2 .podium-trophy {
  color: #94a3b8;
}

.podium-place.place-3 .podium-trophy {
  color: #a16207;
}

.class-team-goal .panel-header {
  margin-bottom: 4px;
}

.class-team-goal .panel-header strong {
  background: var(--accent-soft);
  border-radius: 999px;
  color: var(--accent);
  padding: 8px 11px;
}

.class-team-goal p,
.league-reset-note span {
  color: var(--muted);
  line-height: 1.45;
  margin: 0;
}

.league-reset-note {
  background: var(--panel-2);
  border: 1px dashed color-mix(in srgb, var(--accent) 28%, var(--line));
  border-radius: 22px;
  display: grid;
  gap: 5px;
  padding: 16px;
}

@keyframes xpFloat {
  0% {
    opacity: 0;
    transform: translateY(16px) scale(0.96);
  }
  14% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  78% {
    opacity: 1;
    transform: translateY(-8px) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-26px) scale(0.98);
  }
}

@keyframes xpBoltRise {
  0% {
    opacity: 0;
    transform: translateY(10px) scale(0.92);
  }
  18% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  72% {
    opacity: 1;
    transform: translateY(-6px) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-14px) scale(0.98);
  }
}

@keyframes xpPillGlow {
  0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 36%, transparent); transform: scale(1); }
  35% { box-shadow: 0 0 0 9px color-mix(in srgb, var(--accent) 0%, transparent); transform: scale(1.06); }
  100% { box-shadow: none; transform: scale(1); }
}

@keyframes voicePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.12); }
}

@media (max-width: 520px) {
  .daily-quests-card,
  .progress-teaser-card,
  .level-card,
  .challenge-card {
    border-radius: 24px;
    min-height: auto;
    padding: 18px;
  }

  .leaderboard-tabs {
    border-radius: 24px;
    grid-template-columns: repeat(2, 1fr);
  }

  .leaderboard-row {
    grid-template-columns: 24px 40px 1fr;
  }

  .leaderboard-row em {
    grid-column: 3;
    text-align: left;
  }

  .level-goal-row {
    grid-template-columns: 1fr;
  }

  .level-goal-row span,
  .level-goal-row span:last-child,
  .level-goal-row strong {
    text-align: left;
    white-space: normal;
  }

  .class-podium {
    gap: 0;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .podium-place,
  .podium-place.place-1,
  .podium-place.place-2,
  .podium-place.place-3 {
    min-height: 164px;
    padding-inline: 1px;
  }

  .podium-trophy,
  .podium-place.place-1 .podium-trophy {
    height: 42px;
    width: 42px;
  }

  .podium-place.place-1 .podium-block {
    height: 92px;
  }

  .podium-place.place-2 .podium-block {
    height: 72px;
  }

  .podium-place.place-3 .podium-block {
    height: 62px;
  }

  .podium-name strong {
    font-size: 0.82rem;
  }

  .podium-name small {
    font-size: 0.7rem;
  }

  .record-list,
  .progress-stat-grid {
    grid-template-columns: 1fr 1fr;
  }

  .class-league-hero {
    align-items: start;
    display: grid;
    padding: 20px;
  }

  .league-badge {
    height: 132px;
    max-width: none;
    min-height: 132px;
    width: 132px;
  }

  .class-tabs {
    border-radius: 24px;
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 760px) {
  .topbar {
    left: auto;
    max-width: none;
    position: static;
    top: auto;
    transform: none;
    width: auto;
  }

  .bottom-nav {
    border-radius: 30px;
  }
}

@media (max-width: 520px) {
  .main-content {
    padding-top: 32px;
  }

  .cards-main-stacks .quizlet-large-stack {
    min-height: 140px;
  }

  .bottom-nav a {
    font-size: 0.62rem;
  }

  .nav-icon,
  .nav-icon svg {
    height: 27px;
    width: 27px;
  }
}

.grade-folder-list .subject-folder-row {
  border-radius: 28px;
  display: block;
  overflow: hidden;
  position: relative;
  touch-action: pan-y;
  user-select: none;
}

.grade-folder-list .subject-folder-row .grade-folder {
  position: relative;
  transition: border-color 180ms ease, transform 180ms ease;
  z-index: 1;
}

.grade-folder-list .subject-folder-row .grade-folder {
  grid-template-columns: minmax(0, 1fr) auto;
}

.grade-folder-list .subject-folder-row.grade-low .grade-folder {
  background: color-mix(in srgb, var(--bad) 16%, var(--panel));
  border-color: color-mix(in srgb, var(--bad) 42%, var(--line));
}

.grade-folder-list .subject-folder-row.grade-warning .grade-folder {
  background: color-mix(in srgb, #f97316 18%, var(--panel));
  border-color: color-mix(in srgb, #f97316 46%, var(--line));
}

.grade-folder-list .subject-folder-row.grade-ok .grade-folder {
  background: color-mix(in srgb, #facc15 18%, var(--panel));
  border-color: color-mix(in srgb, #eab308 44%, var(--line));
}

.grade-folder-list .subject-folder-row.grade-light-good .grade-folder {
  background: color-mix(in srgb, #84cc16 16%, var(--panel));
  border-color: color-mix(in srgb, #65a30d 42%, var(--line));
}

.grade-folder-list .subject-folder-row.grade-high .grade-folder {
  background: color-mix(in srgb, var(--good) 24%, var(--panel));
  border-color: color-mix(in srgb, var(--good) 52%, var(--line));
}

.grade-folder-list .subject-folder-row.grade-high .grade-folder em,
.grade-folder-list .subject-folder-row.grade-high .grade-folder strong {
  color: color-mix(in srgb, var(--good) 75%, var(--ink));
}

.grade-folder-list .subject-folder-row.grade-low .grade-folder em,
.grade-folder-list .subject-folder-row.grade-low .grade-folder strong {
  color: color-mix(in srgb, var(--bad) 78%, var(--ink));
}

.grade-folder-list .subject-folder-row.grade-warning .grade-folder em,
.grade-folder-list .subject-folder-row.grade-warning .grade-folder strong {
  color: color-mix(in srgb, #f97316 76%, var(--ink));
}

.grade-folder-list .subject-folder-row.grade-ok .grade-folder em,
.grade-folder-list .subject-folder-row.grade-ok .grade-folder strong {
  color: color-mix(in srgb, #ca8a04 72%, var(--ink));
}

.grade-folder-list .subject-folder-row.grade-light-good .grade-folder em,
.grade-folder-list .subject-folder-row.grade-light-good .grade-folder strong {
  color: color-mix(in srgb, #65a30d 74%, var(--ink));
}

.subject-row-actions {
  align-items: center;
  background: color-mix(in srgb, var(--bad) 92%, #7f1d1d);
  border: 0;
  border-radius: 28px;
  bottom: 0;
  display: flex;
  height: auto;
  justify-content: center;
  padding: 0;
  position: absolute;
  right: 6px;
  top: 0;
  transform: translateX(120%);
  transition: transform 180ms ease;
  width: 72px;
}

.grade-folder-list .subject-folder-row.show-actions .grade-folder {
  transform: translateX(-90px);
}

.grade-folder-list .subject-folder-row.show-actions .subject-row-actions {
  transform: translateX(0);
}

.grade-folder-list .subject-folder-row.swiping .grade-folder {
  transform: translateX(calc(var(--swipe-offset, 0px) * -1));
  transition: none;
}

.grade-folder-list .subject-folder-row.swiping .subject-row-actions {
  transform: translateX(calc(120% - var(--swipe-offset, 0px)));
  transition: none;
}

.grade-folder-list .subject-folder-row .delete-subject {
  align-self: center;
  background: transparent;
  border: 0;
  border-radius: 999px;
  color: var(--white);
  height: 50px;
  min-height: 50px;
  width: 50px;
}

.grade-folder-list .subject-folder-row .delete-subject:hover,
.grade-folder-list .subject-folder-row .delete-subject:focus-visible {
  background: rgba(255, 255, 255, 0.16);
  color: var(--white);
}

.ai-full-page.is-empty {
  align-content: center;
  gap: 18px;
  min-height: calc(100vh - 210px);
}

.ai-full-page.is-empty > h1 {
  display: none;
}

.ai-full-page.is-empty .ai-window {
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  display: grid;
  gap: 18px;
  min-height: auto;
  overflow: visible;
}

.ai-start-screen {
  display: grid;
  gap: 8px;
  justify-items: center;
  text-align: center;
}

.ai-start-screen h2 {
  color: var(--ink);
  font-size: clamp(1.85rem, 8vw, 3.2rem);
  line-height: 1.05;
  margin: 0;
}

.ai-start-screen p {
  color: var(--muted);
  font-weight: 750;
  line-height: 1.45;
  margin: 0;
  max-width: 560px;
}

.ai-full-input {
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  display: block;
  min-height: auto;
  overflow: visible;
}

.ai-window .ai-full-input {
  border: 0;
  border-radius: 0;
  box-shadow: none;
  min-height: auto;
}

.ai-search-shell {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 999px;
  box-shadow: 0 18px 45px rgba(15, 23, 42, 0.12);
  display: grid;
  gap: 6px;
  grid-template-columns: auto auto minmax(0, 1fr) auto;
  margin: 0 auto;
  max-width: 820px;
  min-height: 58px;
  padding: 6px 8px;
  position: relative;
  width: 100%;
}

html[data-theme="dark"] .ai-search-shell {
  box-shadow: 0 18px 45px rgba(0, 0, 0, 0.28);
}

.ai-search-shell textarea {
  background: transparent;
  border: 0;
  box-shadow: none;
  color: var(--ink);
  font-size: 1rem;
  line-height: 1.35;
  margin: 0;
  max-height: 110px;
  min-height: 26px;
  outline: 0;
  overflow-y: auto;
  padding: 10px 4px;
  resize: none;
}

.ai-window .ai-full-input textarea {
  background: transparent;
  border: 0;
  border-radius: 0;
  font-size: 1rem;
  margin: 0;
  min-height: 26px;
  padding: 10px 4px;
}

.ai-plus-button,
.ai-mic-button,
.ai-send-button {
  align-items: center;
  border: 0;
  border-radius: 999px;
  cursor: pointer;
  display: inline-grid;
  height: 44px;
  justify-items: center;
  min-height: 44px;
  padding: 0;
  place-items: center;
  width: 44px;
}

.ai-plus-button,
.ai-mic-button {
  background: transparent;
  color: var(--muted);
}

.ai-plus-button:hover,
.ai-mic-button:hover,
.ai-plus-button:focus-visible,
.ai-mic-button:focus-visible {
  background: var(--panel-2);
  color: var(--accent);
}

.ai-mic-button.listening {
  background: color-mix(in srgb, var(--bad) 14%, var(--panel));
  color: var(--bad);
}

.ai-mic-button.listening .icon {
  animation: voicePulse 1.1s ease-in-out infinite;
}

.ai-send-button {
  background: var(--ink);
  color: var(--panel);
}

html[data-theme="dark"] .ai-send-button {
  background: var(--white);
  color: #0f172a;
}

.ai-send-button:hover,
.ai-send-button:focus-visible {
  transform: translateY(-1px);
}

.ai-attach-wrap {
  position: relative;
}

.ai-attach-menu {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 18px;
  box-shadow: var(--shadow);
  display: none;
  gap: 8px;
  left: 0;
  min-width: 165px;
  padding: 8px;
  position: absolute;
  top: calc(100% + 10px);
  z-index: 12;
}

.ai-attach-wrap.open .ai-attach-menu {
  display: grid;
}

.ai-attach-option {
  align-items: center;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 14px;
  color: var(--ink);
  cursor: pointer;
  display: flex;
  font-size: 0.9rem;
  font-weight: 900;
  gap: 10px;
  margin: 0;
  min-height: 44px;
  padding: 0 12px;
}

.ai-attach-option:hover,
.ai-attach-option:focus-within {
  border-color: color-mix(in srgb, var(--accent) 40%, var(--line));
  color: var(--accent);
}

.ai-attach-option input {
  height: 1px;
  opacity: 0;
  overflow: hidden;
  padding: 0;
  position: absolute;
  width: 1px;
}

.ai-window .attachment-pill {
  justify-self: center;
  margin: 0;
  max-width: 820px;
  width: 100%;
}

.ai-quick-actions {
  justify-content: center;
  margin: 0 auto;
  max-width: 820px;
  padding: 0;
  width: 100%;
}

.ai-quick-action {
  min-height: 38px;
  padding: 0 14px;
}

.ai-full-page.has-chat .ai-window {
  gap: 12px;
}

.ai-full-page.has-chat .ai-output {
  min-height: 340px;
}

.ai-output {
  align-content: start;
  gap: 22px;
  line-height: 1.6;
  padding: 18px;
  scroll-behavior: smooth;
}

.chat-message-user {
  align-self: flex-end;
  background: var(--accent);
  border-radius: 18px 18px 6px 18px;
  box-shadow: 0 12px 26px color-mix(in srgb, var(--accent) 20%, transparent);
  color: var(--white);
  max-width: min(75%, 620px);
  padding: 10px 14px;
}

.chat-message-user p {
  line-height: 1.45;
  margin: 0;
  white-space: pre-wrap;
}

.chat-message-ai {
  align-self: stretch;
  color: var(--ink);
  max-width: 100%;
}

.ai-response {
  display: grid;
  gap: 16px;
  max-width: 820px;
}

.ai-response-header {
  align-items: center;
  color: var(--muted);
  display: flex;
  gap: 10px;
}

.ai-response-header strong {
  color: var(--ink);
  display: block;
  font-size: 0.95rem;
  font-weight: 950;
}

.ai-response-header small {
  color: var(--muted);
  display: block;
  font-size: 0.78rem;
  font-weight: 850;
}

.ai-avatar {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 999px;
  display: inline-flex;
  height: 34px;
  justify-content: center;
  overflow: hidden;
  width: 34px;
}

.ai-avatar .mascot {
  height: 34px;
  width: 34px;
}

.ai-avatar .mascot-face {
  height: 100%;
  object-fit: cover;
  width: 100%;
}

.ai-message-content {
  color: var(--ink);
  display: grid;
  font-size: clamp(1rem, 2.8vw, 1.06rem);
  gap: 20px;
  line-height: 1.65;
  max-width: 800px;
}

.ai-section {
  display: grid;
  gap: 10px;
  padding-left: 0;
}

.ai-section + .ai-section {
  margin-top: 10px;
}

.ai-section-title {
  color: var(--ink);
  font-size: clamp(1.04rem, 3.2vw, 1.16rem);
  font-weight: 900;
  line-height: 1.2;
  margin: 0;
}

.ai-heading-level-1,
.ai-heading-level-2 {
  font-size: clamp(1.22rem, 4vw, 1.42rem);
  margin-top: 8px;
}

.ai-section-step {
  border-top: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
  padding-top: 18px;
}

.ai-section-step:first-child {
  border-top: 0;
  padding-top: 0;
}

.ai-section-step .ai-section-title {
  align-items: center;
  display: flex;
  gap: 9px;
}

.ai-section-step .ai-section-title::first-letter {
  letter-spacing: 0;
}

.ai-section p {
  margin: 2px 0;
}

.ai-section-answer,
.ai-section-result {
  background: transparent;
  border: 0;
  border-radius: 0;
  padding: 0;
}

.ai-section-error {
  background: transparent;
  border-left: 3px solid var(--bad);
  padding-left: 12px;
}

.ai-final-answer,
.ai-section-answer p,
.ai-section-result p {
  font-size: clamp(1.14rem, 4vw, 1.48rem);
  font-weight: 950;
  line-height: 1.35;
}

.ai-step-list {
  counter-reset: aiStep;
  display: grid;
  gap: 12px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.ai-step {
  background: transparent;
  border: 0;
  border-radius: 0;
  counter-increment: aiStep;
  line-height: 1.55;
  min-height: 44px;
  padding: 2px 0 2px 38px;
  position: relative;
}

.ai-step::before {
  align-items: center;
  background: var(--accent-soft);
  border-radius: 999px;
  color: var(--accent);
  content: counter(aiStep);
  display: inline-flex;
  font-size: 0.8rem;
  font-weight: 950;
  height: 24px;
  justify-content: center;
  left: 0;
  position: absolute;
  top: 0;
  width: 24px;
}

.ai-bullet-list {
  display: grid;
  gap: 8px;
  margin: 0;
  padding-left: 22px;
}

.ai-message-content code,
.ai-equation {
  background: color-mix(in srgb, var(--accent) 9%, var(--panel-2));
  border: 1px solid color-mix(in srgb, var(--accent) 16%, var(--line));
  border-radius: 8px;
  color: var(--ink);
  display: inline-block;
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-size: 0.93em;
  max-width: 100%;
  overflow-x: auto;
  padding: 2px 6px;
  vertical-align: baseline;
  white-space: nowrap;
}

.ai-math-inline {
  color: inherit;
  display: inline-block;
  max-width: 100%;
  vertical-align: middle;
}

.ai-math-block {
  color: var(--ink);
  margin: 16px 0 18px;
  max-width: 100%;
  overflow-x: auto;
  padding: 6px 0;
  scrollbar-width: thin;
  text-align: center;
}

.ai-math-block .katex-display {
  margin: 0;
}

.ai-math-block .katex {
  color: inherit;
  font-size: clamp(1.08rem, 4vw, 1.25rem);
}

.ai-math-fallback {
  background: transparent;
  border-radius: 8px;
  font-family: Georgia, "Times New Roman", serif;
  line-height: 1.45;
  padding: 6px 8px;
}

.ai-frac {
  align-items: center;
  display: inline-flex;
  flex-direction: column;
  font-size: 0.96em;
  line-height: 1;
  margin: 0 0.12em;
  min-width: 1.05em;
  vertical-align: middle;
}

.ai-frac-top,
.ai-frac-bottom {
  display: block;
  padding: 0 0.16em;
}

.ai-frac-top {
  border-bottom: 1px solid currentColor;
  padding-bottom: 0.08em;
}

.ai-frac-bottom {
  padding-top: 0.08em;
}

.ai-math-symbol {
  display: inline-block;
  margin: 0 0.18em;
}

.ai-code-block {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 14px;
  margin: 0;
  max-width: 100%;
  overflow-x: auto;
  padding: 12px;
}

.ai-code-block code {
  background: transparent;
  border: 0;
  display: block;
  padding: 0;
  white-space: pre;
}

.ai-divider {
  border: 0;
  border-top: 1px solid var(--line);
  margin: 4px 0;
}

.ai-table-wrap {
  max-width: 100%;
  overflow-x: auto;
}

.ai-table {
  border-collapse: collapse;
  font-size: 0.92rem;
  min-width: 420px;
  width: 100%;
}

.ai-table th,
.ai-table td {
  border: 1px solid var(--line);
  padding: 9px 10px;
  text-align: left;
}

.ai-table th {
  background: var(--panel-2);
  font-weight: 950;
}

.ai-actions {
  border-top: 1px solid var(--line);
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 6px;
  padding-top: 18px;
}

.ai-actions button {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--muted);
  cursor: pointer;
  display: inline-flex;
  font-size: 0.82rem;
  font-weight: 900;
  gap: 7px;
  min-height: 44px;
  padding: 0 13px;
}

.ai-actions button:hover,
.ai-actions button:focus-visible {
  border-color: color-mix(in srgb, var(--accent) 42%, var(--line));
  color: var(--accent);
}

.ai-thinking {
  max-width: 820px;
}

.ai-thinking .ai-response-header {
  background: color-mix(in srgb, var(--panel) 92%, var(--accent-soft));
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 12px;
}

.thinking-dots {
  display: inline-flex;
  gap: 3px;
  margin-left: 3px;
}

.thinking-dots i {
  animation: thinkingDot 900ms ease-in-out infinite;
  background: currentColor;
  border-radius: 999px;
  display: block;
  height: 4px;
  opacity: 0.42;
  width: 4px;
}

.thinking-dots i:nth-child(2) {
  animation-delay: 150ms;
}

.thinking-dots i:nth-child(3) {
  animation-delay: 300ms;
}

@keyframes thinkingDot {
  0%, 100% { opacity: 0.35; transform: translateY(0); }
  50% { opacity: 1; transform: translateY(-2px); }
}

html[data-theme="dark"] .ai-section-answer,
html[data-theme="dark"] .ai-section-result {
  background: transparent;
}

html[data-theme="dark"] .ai-math-fallback {
  background: color-mix(in srgb, var(--accent) 10%, transparent);
}

html[data-theme="dark"] .chat-message-user {
  box-shadow: 0 12px 26px rgba(0, 0, 0, 0.26);
}

@media (max-width: 520px) {
  .ai-search-shell {
    border-radius: 24px;
    grid-template-columns: auto auto minmax(0, 1fr) auto;
    min-height: 54px;
    padding: 5px 6px;
  }

  .ai-plus-button,
  .ai-mic-button,
  .ai-send-button {
    height: 40px;
    min-height: 40px;
    width: 40px;
  }

  .ai-start-screen h2 {
    font-size: 2rem;
  }

  .ai-output {
    padding: 14px;
  }

  .chat-message-user {
    max-width: 82%;
  }

  .ai-section {
    padding-left: 0;
  }

  .ai-section-answer,
  .ai-section-result,
  .ai-section-error {
    padding: 0;
  }

  .ai-math-block {
    margin: 14px 0;
    padding: 4px 0;
  }

  .ai-actions button {
    flex: 1 1 140px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .thinking-dots i {
    animation: none;
  }

  .match-grid-tile.wrong {
    animation: none;
  }
}

/* Focus Home: one useful learning action, then calm secondary tools. */
.topbar {
  align-items: center;
  padding: 14px 20px 0;
}

.brand > span:last-child {
  display: block;
}

.brand-logo {
  border-radius: 14px;
  box-shadow: none;
  height: 42px;
  width: 42px;
}

.brand-logo img {
  object-fit: cover;
}

.top-actions {
  gap: 7px;
}

.top-actions .streak-pill {
  box-shadow: none;
  min-height: 40px;
}

.header-icon-button {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--muted);
  cursor: pointer;
  display: inline-flex;
  height: 42px;
  justify-content: center;
  min-height: 42px;
  padding: 0;
  position: relative;
  width: 42px;
}

.header-icon-button svg {
  fill: none;
  height: 20px;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 2;
  width: 20px;
}

.header-icon-button:hover {
  border-color: color-mix(in srgb, var(--accent) 38%, var(--line));
  color: var(--accent);
}

.notification-button b {
  align-items: center;
  background: var(--bad);
  border: 2px solid var(--panel);
  border-radius: 999px;
  color: #fff;
  display: inline-flex;
  font-size: 0.65rem;
  height: 19px;
  justify-content: center;
  min-width: 19px;
  padding: 0 4px;
  position: absolute;
  right: -4px;
  top: -4px;
}

.notification-button b[hidden] {
  display: none;
}

.top-actions .account-button {
  border: 1px solid var(--line);
  height: 42px;
  min-height: 42px;
  padding: 0;
  width: 42px;
}

.account-button > span:first-child {
  align-items: center;
  background: color-mix(in srgb, var(--accent) 12%, var(--panel));
  border-radius: 50%;
  color: var(--accent);
  display: inline-flex;
  font-weight: 950;
  height: 30px;
  justify-content: center;
  width: 30px;
}

.account-button > span:last-child {
  display: none;
}

.focus-home {
  display: grid;
  gap: 18px;
}

.home-welcome {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 4px;
  min-width: 0;
}

.home-welcome > div {
  min-width: 0;
}

.home-welcome > div > span {
  color: var(--muted);
  display: block;
  font-size: 0.78rem;
  font-weight: 850;
  margin-bottom: 7px;
  text-transform: uppercase;
}

.home-welcome h1,
.home-page.focus-home h1 {
  font-size: clamp(2.15rem, 10vw, 3rem);
  line-height: 1;
  margin: 0;
}

.home-welcome p {
  color: var(--muted);
  font-size: 1rem;
  margin: 9px 0 0;
}

.home-welcome .mascot-face {
  height: 50px;
  width: 50px;
}

.important-reminder {
  align-items: center;
  background: color-mix(in srgb, #fff7ed 62%, var(--panel));
  border: 1px solid color-mix(in srgb, #fb923c 28%, var(--line));
  border-radius: 22px;
  box-shadow: 0 12px 30px rgba(148, 88, 32, 0.08);
  display: grid;
  gap: 13px;
  grid-template-columns: 46px minmax(0, 1fr) auto;
  padding: 15px;
}

.important-reminder.reminder-overdue {
  background: color-mix(in srgb, var(--bad) 7%, var(--panel));
  border-color: color-mix(in srgb, var(--bad) 28%, var(--line));
}

.important-reminder.reminder-empty {
  background: color-mix(in srgb, var(--green) 6%, var(--panel));
  border-color: color-mix(in srgb, var(--green) 22%, var(--line));
}

.reminder-icon {
  align-items: center;
  background: var(--panel);
  border: 1px solid color-mix(in srgb, #f59e0b 22%, var(--line));
  border-radius: 14px;
  color: #c2410c;
  display: inline-flex;
  height: 46px;
  justify-content: center;
  width: 46px;
}

.reminder-copy {
  min-width: 0;
}

.reminder-copy > span {
  color: #c2410c;
  display: block;
  font-size: 0.72rem;
  font-weight: 950;
  text-transform: uppercase;
}

.reminder-copy h2 {
  font-size: 1.05rem;
  line-height: 1.2;
  margin: 4px 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reminder-copy p,
.reminder-copy small {
  color: var(--muted);
  display: block;
  font-size: 0.8rem;
  line-height: 1.35;
  margin: 0;
}

.reminder-copy small {
  margin-top: 3px;
}

.reminder-action {
  align-items: center;
  color: var(--ink);
  display: inline-flex;
  font-size: 0.8rem;
  font-weight: 900;
  gap: 4px;
  justify-content: flex-end;
  min-height: 44px;
  white-space: nowrap;
}

.reminder-action .icon {
  height: 17px;
  width: 17px;
}

.today-focus-card {
  background: var(--panel);
  border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
  border-radius: 30px;
  box-shadow: 0 22px 54px color-mix(in srgb, var(--accent) 10%, transparent);
  padding: 25px;
}

.today-focus-card.completed {
  background: color-mix(in srgb, var(--green) 7%, var(--panel));
  border-color: color-mix(in srgb, var(--green) 32%, var(--line));
}

.today-focus-head,
.today-focus-footer,
.today-focus-context {
  align-items: center;
  display: flex;
}

.today-focus-head,
.today-focus-footer {
  justify-content: space-between;
}

.today-focus-head > span {
  color: var(--accent);
  font-size: 0.76rem;
  font-weight: 1000;
  text-transform: uppercase;
}

.today-focus-head em {
  background: var(--accent-soft);
  border-radius: 999px;
  color: var(--accent);
  font-size: 0.76rem;
  font-style: normal;
  font-weight: 950;
  padding: 7px 10px;
}

.today-focus-card h2 {
  font-size: clamp(1.75rem, 8vw, 2.45rem);
  line-height: 1.08;
  margin: 23px 0 13px;
}

.today-focus-context {
  flex-wrap: wrap;
  gap: 7px;
}

.today-focus-context strong,
.today-focus-context span {
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 900;
  padding: 7px 10px;
}

.today-focus-context strong {
  background: color-mix(in srgb, var(--accent) 11%, var(--panel-2));
  color: var(--accent);
}

.today-focus-context span {
  background: var(--panel-2);
  color: var(--muted);
}

.today-focus-card > p {
  color: var(--muted);
  line-height: 1.55;
  margin: 17px 0;
}

.today-focus-progress {
  background: color-mix(in srgb, var(--accent) 10%, var(--panel-2));
  border-radius: 999px;
  height: 7px;
  overflow: hidden;
}

.today-focus-progress i {
  background: var(--accent);
  border-radius: inherit;
  display: block;
  height: 100%;
  transition: width 260ms ease;
}

.today-focus-footer {
  gap: 14px;
  margin-top: 20px;
}

.today-focus-footer > span {
  align-items: center;
  color: var(--muted);
  display: inline-flex;
  font-size: 0.82rem;
  font-weight: 850;
  gap: 6px;
}

.today-focus-footer > span .icon {
  height: 18px;
  width: 18px;
}

.today-focus-action,
.today-focus-more {
  border-radius: 14px;
  gap: 8px;
  min-height: 50px;
  padding-inline: 17px;
}

.today-focus-action .icon {
  height: 18px;
  width: 18px;
}

.home-habit-card {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 22px;
  display: grid;
  gap: 12px;
  grid-template-columns: 44px minmax(0, 1fr) 32px;
  padding: 16px;
}

.habit-flame {
  align-items: center;
  background: color-mix(in srgb, #f97316 10%, var(--panel-2));
  border-radius: 14px;
  display: inline-flex;
  height: 44px;
  justify-content: center;
  width: 44px;
}

.habit-flame svg {
  height: 27px;
  width: 27px;
}

.home-habit-card > div > span {
  color: var(--muted);
  display: block;
  font-size: 0.7rem;
  font-weight: 900;
  text-transform: uppercase;
}

.home-habit-card h2 {
  font-size: 1rem;
  margin: 3px 0;
}

.home-habit-card p {
  color: var(--muted);
  font-size: 0.8rem;
  line-height: 1.4;
  margin: 0;
}

.home-habit-card > a {
  align-items: center;
  color: var(--muted);
  display: inline-flex;
  height: 44px;
  justify-content: center;
  width: 32px;
}

.habit-week {
  grid-column: 1 / -1;
}

.habit-week > span {
  margin-bottom: 7px;
  text-transform: none !important;
}

.home-habit-progress {
  height: 6px;
}

.home-tools-section {
  margin-top: 5px;
}

.home-section-heading {
  align-items: end;
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
}

.home-section-heading span,
.home-section-heading small {
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 850;
}

.home-section-heading span {
  text-transform: uppercase;
}

.home-section-heading h2 {
  font-size: 1.35rem;
  margin: 3px 0 0;
}

.home-tool-grid {
  display: grid;
  gap: 9px;
}

.home-tool-card {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 18px;
  display: grid;
  gap: 12px;
  grid-template-columns: 42px minmax(0, 1fr) 22px;
  min-height: 68px;
  padding: 11px 14px;
}

.home-tool-card > span {
  align-items: center;
  background: var(--panel-2);
  border-radius: 13px;
  color: var(--accent);
  display: inline-flex;
  height: 42px;
  justify-content: center;
  width: 42px;
}

.home-tool-card strong,
.home-tool-card small {
  display: block;
}

.home-tool-card small {
  color: var(--muted);
  font-size: 0.78rem;
  margin-top: 3px;
}

.home-tool-card > .icon {
  color: var(--muted);
  height: 18px;
  width: 18px;
}

.home-tool-card:hover {
  border-color: color-mix(in srgb, var(--accent) 32%, var(--line));
  transform: translateY(-1px);
}

html[data-theme="dark"] .important-reminder {
  background: color-mix(in srgb, #7c2d12 16%, var(--panel));
}

html[data-theme="dark"] .reminder-copy > span,
html[data-theme="dark"] .reminder-icon {
  color: #fdba74;
}

@media (max-width: 520px) {
  .topbar {
    padding-inline: 16px;
  }

  .brand > span:last-child {
    display: none;
  }

  .top-actions {
    gap: 5px;
  }

  .top-actions .streak-pill {
    min-height: 38px;
    padding-inline: 6px 9px;
  }

  .header-icon-button,
  .top-actions .theme-icon-button,
  .top-actions .account-button {
    height: 40px;
    min-height: 40px;
    width: 40px;
  }

  .main-content {
    padding-top: 28px;
  }

  .important-reminder {
    align-items: start;
    grid-template-columns: 46px minmax(0, 1fr);
  }

  .reminder-action {
    grid-column: 2;
    justify-content: flex-start;
    min-height: 36px;
  }

  .today-focus-card {
    border-radius: 26px;
    padding: 21px;
  }

  .today-focus-footer {
    align-items: stretch;
    flex-direction: column;
  }

  .today-focus-action,
  .today-focus-more {
    justify-content: space-between;
    width: 100%;
  }

  .home-section-heading small {
    display: none;
  }
}

@media (prefers-reduced-motion: reduce) {
  .today-focus-progress i,
  .home-tool-card {
    transition: none;
  }
}

/* Light premium home, based on Lynxly's calm daily-focus concept. */
:root {
  --home-bg: #fafafd;
  --home-surface: #ffffff;
  --home-surface-soft: color-mix(in srgb, var(--accent) 5%, #ffffff);
  --home-text: #10162f;
  --home-muted: #6b7280;
  --home-line: #e8eaf2;
  --home-primary: var(--accent);
  --home-primary-dark: color-mix(in srgb, var(--accent) 78%, #000000);
  --home-primary-soft: color-mix(in srgb, var(--accent) 14%, #ffffff);
  --home-blue: #2563eb;
  --home-gold: #c8922e;
}

html[data-theme="light"],
html[data-theme="light"] body,
html[data-theme="light"] .app-shell {
  background: var(--home-bg);
  color: var(--home-text);
}

html[data-theme="light"] .topbar {
  background: color-mix(in srgb, var(--home-bg) 90%, transparent);
  border: 0;
  box-sizing: border-box;
  box-shadow: none;
  margin-inline: auto;
  max-width: 430px;
  padding: 16px 0;
  width: calc(100% - 36px);
}

.top-actions .theme-icon-button {
  display: none;
}

html[data-theme="light"] .brand-logo {
  background: transparent;
  border-radius: 12px;
  flex: 0 0 40px;
  height: 40px;
  width: 40px;
}

html[data-theme="light"] .brand {
  flex: 1 1 auto;
}

html[data-theme="light"] .brand strong {
  color: var(--home-text);
  font-size: 1.02rem;
  letter-spacing: 0;
}

html[data-theme="light"] .brand small {
  color: var(--home-muted);
  display: none;
}

html[data-theme="light"] .header-icon-button,
html[data-theme="light"] .top-actions .account-button,
html[data-theme="light"] .top-actions .streak-pill {
  background: var(--home-surface);
  border: 1px solid var(--home-line);
  box-shadow: 0 7px 20px rgba(15, 23, 42, 0.05);
}

html[data-theme="light"] .top-actions .streak-pill {
  color: #f97316;
  padding-inline: 7px 10px;
}

html[data-theme="light"] .top-actions .streak-pill strong {
  color: #9a3412;
}

.account-button > img {
  border-radius: 50%;
  display: block;
  height: 38px;
  object-fit: cover;
  width: 38px;
}

.focus-home {
  color: var(--home-text);
  gap: 16px;
  margin-inline: auto;
  max-width: 430px;
  width: 100%;
}

html[data-theme="light"] .main-content {
  padding: 22px 18px 124px;
}

.home-welcome {
  margin: 4px 0 6px;
}

.home-welcome h1,
.home-page.focus-home h1 {
  color: var(--home-text);
  font-size: clamp(2rem, 9vw, 2.45rem);
  font-weight: 820;
  letter-spacing: 0;
  line-height: 1.08;
}

.home-welcome h1 span {
  font-size: 0.78em;
}

.home-welcome p {
  color: var(--home-muted);
  font-size: 0.98rem;
  margin-top: 8px;
}

.important-reminder {
  background: var(--home-surface);
  border: 1px solid var(--home-line);
  border-radius: 22px;
  box-shadow: 0 12px 30px rgba(15, 23, 42, 0.055);
  gap: 12px;
  grid-template-columns: 44px minmax(0, 1fr) auto;
  min-height: 84px;
  padding: 13px 14px;
}

.important-reminder.reminder-overdue {
  background: #fffafa;
  border-color: color-mix(in srgb, var(--danger, #ef4444) 22%, var(--home-line));
}

.important-reminder.reminder-empty {
  background: var(--home-surface);
  border-color: var(--home-line);
}

.reminder-icon {
  background: #fff8e8;
  border: 0;
  border-radius: 14px;
  color: var(--home-gold);
  height: 44px;
  width: 44px;
}

.reminder-icon .icon {
  height: 21px;
  width: 21px;
}

.reminder-copy h2 {
  color: var(--home-text);
  font-size: 0.96rem;
  font-weight: 780;
  letter-spacing: 0;
  margin: 0 0 5px;
}

.reminder-copy p {
  color: var(--home-muted);
  font-size: 0.76rem;
  line-height: 1.35;
}

.reminder-action {
  color: var(--home-primary);
  font-size: 0.78rem;
  min-height: 44px;
}

.today-focus-card {
  align-items: center;
  background: linear-gradient(145deg, #ffffff 0%, color-mix(in srgb, var(--accent) 5%, #ffffff) 58%, color-mix(in srgb, var(--accent) 14%, #ffffff) 100%);
  border: 0;
  border-radius: 28px;
  box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
  display: grid;
  gap: 14px;
  grid-template-columns: minmax(0, 1fr) 92px;
  min-height: 310px;
  overflow: hidden;
  padding: 24px;
  position: relative;
}

.today-focus-card::after {
  background: color-mix(in srgb, var(--accent) 7%, transparent);
  border-radius: 50%;
  content: "";
  height: 160px;
  position: absolute;
  right: -76px;
  top: -60px;
  width: 160px;
}

.today-focus-card.completed {
  background: linear-gradient(145deg, #ffffff, #f0fdf4);
  border: 0;
}

.today-focus-copy {
  min-width: 0;
  position: relative;
  z-index: 1;
}

.today-focus-head {
  justify-content: flex-start;
}

.today-focus-head > span {
  background: var(--home-primary-soft);
  border-radius: 999px;
  color: var(--home-primary);
  display: inline-flex;
  font-size: 0.7rem;
  font-weight: 820;
  padding: 7px 10px;
  text-transform: none;
}

.today-focus-card h2 {
  color: var(--home-text);
  font-size: clamp(1.65rem, 7vw, 2rem);
  font-weight: 820;
  letter-spacing: 0;
  line-height: 1.12;
  margin: 17px 0 10px;
}

.today-focus-card .today-focus-copy > p {
  color: var(--home-muted);
  font-size: 0.84rem;
  line-height: 1.52;
  margin: 0 0 14px;
}

.today-focus-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-bottom: 13px;
}

.today-focus-meta span {
  align-items: center;
  background: rgba(255, 255, 255, 0.75);
  border: 1px solid color-mix(in srgb, var(--accent) 12%, transparent);
  border-radius: 999px;
  color: var(--home-muted);
  display: inline-flex;
  font-size: 0.7rem;
  font-weight: 720;
  gap: 4px;
  padding: 6px 8px;
}

.today-focus-meta .icon {
  height: 14px;
  width: 14px;
}

.today-focus-progress {
  background: color-mix(in srgb, var(--accent) 14%, transparent);
  height: 6px;
}

.today-focus-progress i {
  background: var(--home-primary);
}

.today-focus-footer {
  display: block;
  margin-top: 16px;
}

.today-focus-action,
.today-focus-more {
  background: var(--home-primary);
  border: 0;
  border-radius: 15px;
  box-shadow: 0 11px 22px color-mix(in srgb, var(--accent) 24%, transparent);
  color: #fff;
  justify-content: space-between;
  min-height: 50px;
  width: 100%;
}

.today-focus-action:hover,
.today-focus-more:hover {
  background: var(--home-primary-dark);
}

.today-focus-visual {
  align-items: center;
  display: flex;
  height: 154px;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.focus-card-back,
.focus-card-front {
  background: rgba(255, 255, 255, 0.82);
  border: 1px solid color-mix(in srgb, var(--accent) 14%, transparent);
  border-radius: 20px;
  box-shadow: 0 14px 28px color-mix(in srgb, var(--accent) 16%, transparent);
  height: 116px;
  position: absolute;
  width: 82px;
}

.focus-card-back {
  transform: rotate(8deg) translate(7px, -7px);
}

.focus-card-front {
  align-items: center;
  display: flex;
  flex-direction: column;
  gap: 8px;
  justify-content: center;
  transform: rotate(-3deg);
}

.focus-card-front .mascot-face {
  height: 48px;
  width: 48px;
}

.focus-card-front > .icon {
  color: var(--home-primary);
  height: 21px;
  width: 21px;
}

.home-habit-card {
  background: var(--home-surface);
  border: 0;
  border-radius: 24px;
  box-shadow: 0 14px 34px rgba(15, 23, 42, 0.06);
  gap: 12px;
  grid-template-columns: minmax(0, 1fr) auto;
  padding: 18px;
}

.habit-copy > span {
  color: var(--home-muted);
  display: block;
  font-size: 0.7rem;
  font-weight: 780;
  text-transform: none;
}

.home-habit-card .habit-copy {
  grid-column: 1 / -1;
  min-width: 0;
}

.habit-title-row {
  align-items: center;
  display: flex;
  gap: 12px;
  justify-content: space-between;
  min-width: 0;
}

.home-habit-card .habit-copy h2 {
  color: var(--home-text);
  flex: 1 1 auto;
  font-size: 1rem;
  margin: 4px 0 0;
  min-width: 0;
}

.habit-streak {
  align-items: center;
  color: var(--home-text);
  display: inline-flex;
  flex: 0 0 auto;
  gap: 6px;
  justify-content: end;
  min-height: 44px;
  white-space: nowrap;
}

@media (max-width: 360px) {
  .habit-title-row {
    gap: 8px;
  }

  .habit-streak strong {
    font-size: 0.7rem;
  }
}

.habit-streak > span {
  font-size: 1.35rem;
}

.habit-streak strong {
  font-size: 0.78rem;
  font-weight: 800;
  line-height: 1;
}

.habit-streak .streak-short {
  display: none;
}

.habit-week {
  display: grid;
  gap: 6px;
  grid-column: 1 / -1;
  grid-template-columns: repeat(7, 1fr);
  margin-top: 2px;
}

.habit-week > span {
  align-items: center;
  color: #9ca3af;
  display: grid;
  font-size: 0.67rem;
  gap: 5px;
  justify-items: center;
  margin: 0;
}

.habit-week b {
  font-weight: 700;
}

.habit-week i {
  align-items: center;
  background: #f2f3f7;
  border-radius: 50%;
  display: inline-flex;
  font-size: 0.7rem;
  font-style: normal;
  height: 26px;
  justify-content: center;
  width: 26px;
}

.habit-week .done {
  color: var(--home-primary);
}

.habit-week .done i {
  background: var(--home-primary-soft);
  color: var(--home-primary);
  font-weight: 900;
}

.home-tools-section {
  margin-top: 0;
}

.home-tool-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.home-tool-card {
  align-content: space-between;
  background: var(--home-surface);
  border: 0;
  border-radius: 22px;
  box-shadow: 0 12px 30px rgba(15, 23, 42, 0.055);
  display: grid;
  gap: 13px;
  grid-template-columns: 1fr;
  min-height: 145px;
  padding: 16px;
}

.home-tool-card > span {
  background: var(--home-primary-soft);
  border-radius: 13px;
  color: var(--home-primary);
  height: 40px;
  width: 40px;
}

.home-tool-card strong,
.home-tool-card b,
.home-tool-card small {
  display: block;
  letter-spacing: 0;
}

.home-tool-card strong {
  color: var(--home-text);
  font-size: 0.9rem;
}

.home-tool-card b {
  color: var(--home-text);
  font-size: 1.45rem;
  line-height: 1.1;
  margin-top: 7px;
}

.home-tool-card b.empty-value {
  font-size: 0.88rem;
  line-height: 1.25;
  margin-top: 10px;
}

.home-tool-card small {
  color: var(--home-muted);
  font-size: 0.72rem;
  line-height: 1.35;
  margin-top: 4px;
}

.home-tool-card.tool-tasks > span {
  background: #eaf2ff;
  color: var(--home-blue);
}

.home-tool-card.tool-coach > span {
  background: #fff6df;
  color: var(--home-gold);
}

.home-tool-card.tool-progress > span {
  background: #eafbf3;
  color: #15803d;
}

html[data-theme="light"] .bottom-nav {
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid rgba(232, 234, 242, 0.94);
  border-radius: 22px;
  bottom: 12px;
  box-shadow: 0 18px 45px rgba(15, 23, 42, 0.1);
  grid-template-columns: repeat(5, 1fr);
  left: 50%;
  max-width: 410px;
  padding: 7px 8px;
  right: auto;
  transform: translateX(-50%);
  width: calc(100% - 24px);
}

html[data-theme="light"] .bottom-nav a {
  background: transparent;
  border-radius: 14px;
  color: #8b93a7;
  font-size: 0.64rem;
  min-height: 54px;
}

html[data-theme="light"] .bottom-nav a.active {
  background: transparent;
  color: var(--home-primary);
}

html[data-theme="light"] .bottom-nav a.active .nav-icon {
  background: transparent;
  color: var(--home-primary);
}

html[data-theme="light"] .bottom-nav a.active .nav-icon::after {
  background: var(--home-primary);
  border-radius: 999px;
  bottom: -5px;
  content: "";
  height: 3px;
  left: 50%;
  position: absolute;
  transform: translateX(-50%);
  width: 14px;
}

@media (max-width: 520px) {
  html[data-theme="light"] .topbar {
    padding: 13px 0;
  }

  .brand > span:last-child {
    display: block;
  }

  .brand small {
    display: none;
  }

  .top-actions {
    gap: 4px;
  }

  .top-actions .streak-pill {
    min-height: 38px;
  }

  .header-icon-button,
  .top-actions .account-button {
    height: 40px;
    min-height: 40px;
    width: 40px;
  }

  .account-button > img {
    height: 36px;
    width: 36px;
  }

  html[data-theme="light"] .main-content {
    padding-top: 17px;
  }

  .important-reminder {
    align-items: center;
    grid-template-columns: 44px minmax(0, 1fr) auto;
  }

  .reminder-action {
    grid-column: auto;
    justify-content: flex-end;
    min-height: 44px;
  }

  .today-focus-card {
    grid-template-columns: minmax(0, 1fr) 78px;
    min-height: 300px;
    padding: 21px;
  }

  .focus-card-back,
  .focus-card-front {
    height: 105px;
    width: 72px;
  }
}

@media (max-width: 370px) {
  .brand strong {
    display: none;
  }

  .today-focus-card {
    grid-template-columns: 1fr;
  }

  .today-focus-visual {
    display: none;
  }

  .habit-streak .streak-full {
    display: none;
  }

  .habit-streak .streak-short {
    display: inline;
  }
}

html[data-theme="dark"] .focus-home .today-focus-card,
html[data-theme="dark"] .focus-home .important-reminder,
html[data-theme="dark"] .focus-home .home-habit-card,
html[data-theme="dark"] .focus-home .home-tool-card {
  box-shadow: 0 18px 45px rgba(0, 0, 0, 0.2);
}

/* Compact Home metrics and direct session navigation. */
body:not([data-route="dashboard"]) .topbar {
  display: none;
}

body[data-route="dashboard"] .topbar {
  display: none;
}

body[data-route="dashboard"] .main-content {
  padding-top: 26px;
}

.home-welcome {
  align-items: flex-start;
  gap: 16px;
}

.home-streak-pill {
  align-items: center;
  background: var(--home-surface);
  border: 1px solid var(--home-line);
  border-radius: 999px;
  box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
  color: var(--home-text);
  display: inline-flex;
  flex: 0 0 auto;
  font-size: 0.9rem;
  gap: 5px;
  min-height: 44px;
  padding: 0 13px;
}

.home-streak-pill > span {
  font-size: 1.15rem;
}

.home-streak-pill strong {
  font-size: 0.92rem;
}

.home-welcome-actions {
  align-items: center;
  display: flex;
  flex: 0 0 auto;
  gap: 8px;
}

.home-theme-toggle {
  align-items: center;
  background: var(--home-surface);
  border: 1px solid var(--home-line);
  border-radius: 50%;
  box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
  color: var(--home-text);
  cursor: pointer;
  display: inline-flex;
  flex: 0 0 44px;
  height: 44px;
  justify-content: center;
  padding: 0;
  width: 44px;
}

.home-theme-toggle .icon {
  height: 20px;
  width: 20px;
}

.home-theme-toggle:hover,
.home-theme-toggle:focus-visible {
  color: var(--home-primary);
}

.home-grade-section {
  background: var(--home-surface-soft);
  border-radius: 26px;
  padding: 18px;
}

.home-grade-section > h2 {
  color: var(--home-text);
  font-size: 1.15rem;
  margin: 0 0 13px;
}

.home-grade-metrics {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.home-grade-metrics > a {
  background: var(--home-surface);
  border: 1px solid var(--home-line);
  border-radius: 23px;
  box-shadow: 0 12px 30px rgba(15, 23, 42, 0.055);
  display: flex;
  flex-direction: column;
  min-height: 132px;
  padding: 17px;
}

.home-grade-metrics span,
.home-grade-metrics small {
  color: var(--home-muted);
  font-size: 0.73rem;
  font-weight: 700;
}

.home-grade-metrics strong {
  color: var(--home-text);
  font-size: 1.65rem;
  line-height: 1;
  margin: auto 0 10px;
}

.home-grade-metrics small {
  font-weight: 500;
}

.home-secondary-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.home-secondary-card {
  align-items: center;
  background: var(--home-surface);
  border: 0;
  border-radius: 23px;
  box-shadow: 0 12px 30px rgba(15, 23, 42, 0.055);
  display: grid;
  gap: 12px;
  grid-template-columns: 42px minmax(0, 1fr);
  min-height: 105px;
  padding: 15px;
}

.home-secondary-card > span {
  align-items: center;
  background: var(--home-primary-soft);
  border-radius: 13px;
  color: var(--home-primary);
  display: inline-flex;
  height: 42px;
  justify-content: center;
  width: 42px;
}

.home-secondary-card strong,
.home-secondary-card b,
.home-secondary-card small {
  display: block;
}

.home-secondary-card strong {
  color: var(--home-text);
  font-size: 0.88rem;
}

.home-secondary-card b {
  color: var(--home-text);
  font-size: 1.25rem;
  margin-top: 4px;
}

.home-secondary-card small {
  color: var(--home-muted);
  font-size: 0.68rem;
  margin-top: 2px;
}

.session-progress .session-step-tab {
  background: transparent;
  border: 0;
  border-radius: 10px;
  color: var(--muted);
  cursor: pointer;
  font-size: 0.76rem;
  font-weight: 900;
  min-height: 44px;
  padding: 9px 7px;
  text-align: center;
}

.session-progress .session-step-tab.active {
  background: var(--accent-soft);
  color: var(--accent);
}

.session-progress .session-step-tab:hover {
  background: color-mix(in srgb, var(--accent) 8%, var(--panel));
}

@media (max-width: 370px) {
  .home-grade-section {
    padding: 14px;
  }

  .home-grade-metrics > a {
    min-height: 118px;
    padding: 14px;
  }

  .home-secondary-card {
    grid-template-columns: 1fr;
    min-height: 122px;
  }
}

.restored-habit-card .habit-week > span {
  display: flex;
  flex-direction: column;
  gap: 6px;
  justify-content: flex-start;
}

.restored-habit-card .habit-week i {
  flex: 0 0 26px;
}

.account-profile-card {
  display: grid;
  gap: 18px;
  grid-template-columns: minmax(0, 1fr);
  padding: 20px;
}

.account-profile-head {
  align-items: flex-start;
  display: grid;
  gap: 16px;
  grid-template-columns: 64px minmax(0, 1fr);
  min-width: 0;
}

.account-profile-head > div:last-child {
  min-width: 0;
}

.account-profile-head h2 {
  overflow-wrap: anywhere;
}

.account-profile-head p {
  max-width: 30rem;
  overflow-wrap: normal;
  word-break: normal;
}

.account-profile-card .account-detail-grid,
.account-profile-card .account-learning-links {
  grid-column: 1;
}

.account-learning-links {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  width: 100%;
}

.account-learning-links .secondary-button {
  min-width: 0;
  white-space: normal;
}

html[data-theme="dark"] {
  --home-bg: #090f1c;
  --home-surface: #121b2a;
  --home-surface-soft: #171f32;
  --home-text: #f8fafc;
  --home-muted: #a8b3c5;
  --home-line: #2a374b;
  --home-primary-soft: color-mix(in srgb, var(--accent) 24%, #121b2a);
}

html[data-theme="dark"] body[data-route="dashboard"],
html[data-theme="dark"] body[data-route="dashboard"] .app-shell {
  background: var(--home-bg);
  color: var(--home-text);
}

html[data-theme="dark"] body[data-route="dashboard"] .topbar {
  background: color-mix(in srgb, var(--home-bg) 92%, transparent);
  border-color: transparent;
}

html[data-theme="dark"] .today-focus-card {
  background: linear-gradient(145deg, #151e2e 0%, color-mix(in srgb, var(--accent) 7%, #1b2035) 58%, color-mix(in srgb, var(--accent) 20%, #171f32) 100%);
  box-shadow: 0 18px 45px rgba(0, 0, 0, 0.28);
}

html[data-theme="dark"] .today-focus-card::after {
  background: color-mix(in srgb, var(--accent) 12%, transparent);
}

html[data-theme="dark"] .focus-card-back,
html[data-theme="dark"] .focus-card-front,
html[data-theme="dark"] .today-focus-meta span {
  background: rgba(18, 27, 42, 0.9);
  border-color: var(--home-line);
}

html[data-theme="dark"] .restored-habit-card .habit-week i {
  background: #202b3d;
  color: var(--home-muted);
}

html[data-theme="dark"] .restored-habit-card .habit-week .done i {
  background: var(--home-primary-soft);
  color: color-mix(in srgb, var(--accent) 72%, #ffffff);
}

html[data-theme="dark"] .home-grade-metrics > a,
html[data-theme="dark"] .home-secondary-card,
html[data-theme="dark"] .home-habit-card,
html[data-theme="dark"] .home-streak-pill {
  box-shadow: 0 14px 34px rgba(0, 0, 0, 0.22);
}

@media (max-width: 420px) {
  .account-learning-links {
    grid-template-columns: 1fr;
  }

  .account-profile-head {
    grid-template-columns: 58px minmax(0, 1fr);
  }
}

/* Five equally spaced main destinations in both themes. */
.bottom-nav,
html[data-theme="light"] .bottom-nav {
  grid-template-columns: repeat(5, minmax(0, 1fr));
}

.bottom-nav a {
  min-width: 0;
  width: 100%;
}

@media (max-width: 520px) {
  .bottom-nav {
    padding-left: 8px;
    padding-right: 8px;
  }

  .bottom-nav .nav-icon,
  .bottom-nav .nav-icon svg {
    height: 29px;
    width: 29px;
  }
}

/* Calm, task-first Lynxly home. */
.home-brand-header {
  align-items: center;
  display: flex;
  gap: 12px;
  justify-content: space-between;
  min-width: 0;
}

.home-brand {
  align-items: center;
  color: var(--home-text);
  display: inline-flex;
  flex: 0 1 auto;
  font-size: 1rem;
  gap: 9px;
  min-width: 0;
}

.home-brand img {
  border-radius: 11px;
  display: block;
  height: 38px;
  object-fit: cover;
  width: 38px;
}

.home-brand strong {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-header-actions {
  align-items: center;
  display: flex;
  flex: 0 0 auto;
  gap: 6px;
}

.home-brand-header .home-streak-pill,
.home-brand-header .home-theme-toggle,
.home-header-icon,
.home-profile-avatar {
  background: var(--home-surface);
  border: 1px solid var(--home-line);
  box-shadow: 0 7px 20px rgba(15, 23, 42, 0.055);
  height: 40px;
  min-height: 40px;
}

.home-brand-header .home-streak-pill {
  padding: 0 10px;
}

.home-brand-header .home-theme-toggle,
.home-header-icon,
.home-profile-avatar {
  align-items: center;
  border-radius: 50%;
  color: var(--home-muted);
  display: inline-flex;
  justify-content: center;
  padding: 0;
  position: relative;
  width: 40px;
}

.home-brand-header .home-theme-toggle {
  flex-basis: 40px;
}

.home-header-icon .icon {
  height: 19px;
  width: 19px;
}

.home-notification-button b {
  align-items: center;
  background: var(--danger);
  border: 2px solid var(--home-surface);
  border-radius: 999px;
  color: #fff;
  display: inline-flex;
  font-size: 0.58rem;
  height: 18px;
  justify-content: center;
  min-width: 18px;
  padding: 0 3px;
  position: absolute;
  right: -3px;
  top: -4px;
}

.home-profile-avatar img {
  border-radius: 50%;
  display: block;
  height: 34px;
  object-fit: cover;
  width: 34px;
}

.home-greeting {
  margin-top: 8px;
}

.home-page.focus-home .home-greeting h1 {
  font-size: clamp(2rem, 9vw, 2.4rem);
}

.focus-home .important-reminder {
  background: var(--home-surface);
  border: 1px solid var(--home-line);
  border-radius: 22px;
  box-shadow: 0 12px 30px rgba(15, 23, 42, 0.055);
  min-height: 82px;
}

.focus-home .important-reminder.reminder-overdue {
  background: var(--home-surface);
  border-color: color-mix(in srgb, var(--danger) 18%, var(--home-line));
}

.focus-home .important-reminder.reminder-empty {
  background: var(--home-surface);
  border-color: var(--home-line);
}

.focus-home .reminder-copy > span {
  align-items: center;
  color: var(--home-gold);
  display: flex;
  gap: 6px;
}

.focus-home .reminder-overdue .reminder-copy > span {
  color: var(--danger);
}

.subject-color-dot {
  background: currentColor;
  border-radius: 50%;
  display: inline-block;
  height: 7px;
  width: 7px;
}

.focus-home .reminder-action {
  color: var(--home-primary);
}

.focus-home .today-focus-card {
  min-height: 300px;
}

.today-focus-reason {
  color: var(--home-muted) !important;
  font-size: 0.74rem !important;
  line-height: 1.42 !important;
  margin: 0 0 13px !important;
}

.home-quick-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.home-quick-card {
  align-items: start;
  background: var(--home-surface);
  border: 1px solid color-mix(in srgb, var(--home-line) 88%, transparent);
  border-radius: 22px;
  box-shadow: 0 12px 30px rgba(15, 23, 42, 0.055);
  display: grid;
  gap: 11px;
  grid-template-columns: 40px minmax(0, 1fr);
  min-height: 124px;
  padding: 15px;
}

.home-quick-card > span {
  align-items: center;
  background: var(--home-primary-soft);
  border-radius: 13px;
  color: var(--home-primary);
  display: inline-flex;
  height: 40px;
  justify-content: center;
  width: 40px;
}

.home-quick-card > span .icon {
  height: 20px;
  width: 20px;
}

.home-quick-card strong,
.home-quick-card b,
.home-quick-card small {
  display: block;
}

.home-quick-card strong {
  color: var(--home-text);
  font-size: 0.87rem;
}

.home-quick-card b {
  color: var(--home-text);
  font-size: 1.14rem;
  line-height: 1.16;
  margin-top: 7px;
  overflow-wrap: anywhere;
}

.home-quick-card small {
  color: var(--home-muted);
  font-size: 0.68rem;
  line-height: 1.35;
  margin-top: 4px;
}

.home-quick-card:hover,
.home-quick-card:focus-visible {
  border-color: color-mix(in srgb, var(--home-primary) 30%, var(--home-line));
  transform: translateY(-1px);
}

html[data-theme="dark"] .home-brand-header .home-streak-pill,
html[data-theme="dark"] .home-brand-header .home-theme-toggle,
html[data-theme="dark"] .home-header-icon,
html[data-theme="dark"] .home-profile-avatar,
html[data-theme="dark"] .home-quick-card {
  box-shadow: 0 12px 28px rgba(0, 0, 0, 0.2);
}

@media (max-width: 340px) {
  .home-brand strong {
    display: none;
  }

}

@media (max-width: 390px) {

  .home-header-actions {
    gap: 5px;
  }

  .home-brand-header .home-streak-pill {
    padding-inline: 8px;
  }

  .home-quick-card {
    grid-template-columns: 36px minmax(0, 1fr);
    min-height: 118px;
    padding: 13px;
  }

  .home-quick-card > span {
    height: 36px;
    width: 36px;
  }
}

/* Home header and calm reminder center. */
.home-page.focus-home .home-brand-header {
  margin-bottom: 22px;
}

.home-page.focus-home .home-brand-header .home-streak-pill {
  align-items: center;
  display: inline-flex;
  gap: 5px;
  min-width: 58px;
  text-decoration: none;
}

.home-page.focus-home .home-greeting {
  display: block;
  margin-top: 0;
}

html[data-theme="light"] .focus-home .important-reminder,
html[data-theme="light"] .notification-center-item {
  border-color: #e8eaf2 !important;
}

html[data-theme="light"] .focus-home .important-reminder.reminder-overdue,
html[data-theme="light"] .notification-center-item.urgent {
  border-color: #f5d6d6 !important;
}

html[data-theme="dark"] .focus-home .important-reminder,
html[data-theme="dark"] .notification-center-item {
  border-color: #2a374b !important;
}

.notification-center-backdrop {
  align-items: flex-start;
  background: rgba(15, 23, 42, 0.28);
  display: flex;
  inset: 0;
  justify-content: center;
  padding: max(72px, 8vh) 16px 110px;
  position: fixed;
  z-index: 120;
}

.notification-center {
  background: var(--home-surface, var(--panel));
  border: 1px solid var(--home-line, var(--line));
  border-radius: 26px;
  box-shadow: 0 24px 70px rgba(15, 23, 42, 0.2);
  color: var(--home-text, var(--ink));
  max-height: min(690px, calc(100vh - 150px));
  max-width: 430px;
  overflow: auto;
  padding: 20px;
  width: 100%;
}

.notification-center-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 15px;
}

.notification-center-header span {
  color: var(--home-primary, var(--accent));
  display: block;
  font-size: 0.68rem;
  font-weight: 900;
  text-transform: uppercase;
}

.notification-center-header h2 {
  color: var(--home-text, var(--ink));
  font-size: 1.45rem;
  margin: 3px 0 0;
}

.notification-center-list {
  display: grid;
  gap: 9px;
}

.notification-center-item {
  align-items: center;
  background: var(--home-bg, var(--panel-2));
  border: 1px solid var(--home-line, var(--line));
  border-radius: 18px;
  color: var(--home-text, var(--ink));
  display: grid;
  gap: 11px;
  grid-template-columns: 40px minmax(0, 1fr) 20px;
  min-height: 76px;
  padding: 11px 12px;
}

.notification-center-item.urgent {
  border-color: color-mix(in srgb, var(--danger) 28%, var(--home-line, var(--line)));
}

.notification-item-icon {
  align-items: center;
  background: var(--home-primary-soft, var(--accent-soft));
  border-radius: 13px;
  color: var(--home-primary, var(--accent));
  display: inline-flex;
  height: 40px;
  justify-content: center;
  width: 40px;
}

.notification-center-item.urgent .notification-item-icon {
  background: color-mix(in srgb, var(--danger) 10%, var(--home-surface, var(--panel)));
  color: var(--danger);
}

.notification-center-item small,
.notification-center-item strong,
.notification-center-item p {
  display: block;
}

.notification-center-item small {
  color: var(--home-muted, var(--muted));
  font-size: 0.65rem;
  font-weight: 850;
  text-transform: uppercase;
}

.notification-center-item strong {
  font-size: 0.86rem;
  line-height: 1.3;
  margin-top: 2px;
}

.notification-center-item p {
  color: var(--home-muted, var(--muted));
  font-size: 0.72rem;
  line-height: 1.4;
  margin: 3px 0 0;
}

.notification-center-item > .icon {
  color: var(--home-muted, var(--muted));
  height: 18px;
  width: 18px;
}

.notification-center-empty {
  align-items: center;
  background: var(--home-bg, var(--panel-2));
  border: 1px dashed var(--home-line, var(--line));
  border-radius: 20px;
  display: flex;
  gap: 13px;
  min-height: 104px;
  padding: 16px;
}

.notification-center-empty p {
  color: var(--home-muted, var(--muted));
  margin: 4px 0 0;
}

/* Study Card types keep card creation useful across every subject. */
.study-card-type-grid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 14px;
}

.study-card-type {
  align-items: flex-start;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 18px;
  color: var(--ink);
  display: grid;
  gap: 6px;
  min-height: 126px;
  padding: 14px;
  text-align: left;
}

.study-card-type .icon {
  color: var(--accent);
  height: 24px;
  width: 24px;
}

.study-card-type strong {
  font-size: 0.88rem;
}

.study-card-type small {
  color: var(--muted);
  font-size: 0.7rem;
  line-height: 1.4;
}

.study-card-type.active {
  background: var(--accent-soft);
  border-color: color-mix(in srgb, var(--accent) 48%, var(--line));
  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 20%, transparent);
}

.study-card-form {
  margin-top: 14px;
}

.study-card-form-heading span {
  color: var(--accent);
  font-size: 0.72rem;
  font-weight: 900;
  text-transform: uppercase;
}

.study-card-form-heading p {
  color: var(--muted);
  font-size: 0.76rem;
  line-height: 1.45;
  margin: 5px 0 0;
}

@media (max-width: 360px) {
  .study-card-type-grid {
    grid-template-columns: 1fr;
  }

  .study-card-type {
    min-height: 104px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .notification-center-backdrop,
  .notification-center {
    animation: none !important;
    transition: none !important;
  }
}

@media (prefers-reduced-motion: reduce) {
  .home-quick-card {
    transform: none !important;
  }
}

.today-focus-card.no-visual {
  grid-template-columns: minmax(0, 1fr);
}

.density-compact {
  gap: 12px;
}

.density-compact .today-focus-card {
  min-height: 260px;
  padding: 20px;
}

.density-compact .home-habit-card,
.density-compact .home-quick-card {
  padding: 13px;
}

.exam-extra-fields {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.exam-extra-fields.hidden {
  display: none;
}

.form-span-full {
  grid-column: 1 / -1;
}

.premium-toggle-preview {
  background: color-mix(in srgb, var(--accent) 7%, var(--panel));
  border-color: color-mix(in srgb, var(--accent) 22%, var(--line));
}

.smart-plan-preview {
  background: var(--panel);
  border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
  border-radius: 24px;
  box-shadow: var(--shadow);
  display: grid;
  gap: 16px;
  padding: 19px;
}

.smart-plan-preview.locked {
  background: color-mix(in srgb, var(--accent) 5%, var(--panel));
}

.smart-plan-preview-head {
  align-items: flex-start;
  display: flex;
  gap: 14px;
  justify-content: space-between;
}

.smart-plan-preview-head > div {
  min-width: 0;
}

.smart-plan-preview-head span {
  color: var(--accent);
  display: block;
  font-size: 0.72rem;
  font-weight: 900;
  text-transform: uppercase;
}

.smart-plan-preview-head h2 {
  font-size: 1.2rem;
  line-height: 1.25;
  margin: 5px 0;
}

.smart-plan-preview-head p,
.smart-plan-copy,
.smart-plan-upgrade p {
  color: var(--muted);
  line-height: 1.5;
  margin: 0;
}

/* v181 polish: Home owns the header; the old global topbar has been removed from HTML. */
body .main-content {
  padding-top: 22px;
}

.home-brand-header {
  margin-bottom: 10px;
}

.notification-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 0 0 12px;
}

.notification-actions .secondary-button {
  flex: 1 1 130px;
  min-height: 44px;
}

.notification-group {
  display: grid;
  gap: 8px;
}

.notification-group + .notification-group {
  margin-top: 16px;
}

.notification-group h3 {
  color: var(--muted);
  font-size: 0.74rem;
  font-weight: 900;
  letter-spacing: 0.04em;
  margin: 0;
  text-transform: uppercase;
}

.notification-center-item {
  min-height: 64px;
}

.home-quick-card b.empty-value {
  font-size: 1rem;
  line-height: 1.18;
}

.exam-basic-field.hidden,
.exam-extra-fields.hidden {
  display: none;
}

.exam-extra-fields {
  background: color-mix(in srgb, var(--accent) 4%, var(--panel));
  border: 1px solid color-mix(in srgb, var(--accent) 14%, var(--line));
  border-radius: 20px;
  padding: 0;
}

.exam-extra-fields summary {
  color: var(--ink);
  cursor: pointer;
  font-weight: 900;
  list-style: none;
  min-height: 44px;
  padding: 14px 16px;
}

.exam-extra-fields summary::-webkit-details-marker {
  display: none;
}

.exam-extra-fields summary::after {
  content: "+";
  float: right;
}

.exam-extra-fields[open] summary::after {
  content: "-";
}

.advanced-field-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  padding: 0 16px 16px;
}

.study-card-form-actions,
.study-card-after-actions {
  display: grid;
  gap: 10px;
  grid-column: 1 / -1;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.study-card-after-actions {
  margin-top: 10px;
}

.request-notifications-button {
  margin-top: 12px;
  width: 100%;
}

@media (max-width: 520px) {
  .advanced-field-grid,
  .study-card-form-actions,
  .study-card-after-actions {
    grid-template-columns: 1fr;
  }
}

.smart-plan-preview-head > .icon {
  color: var(--accent);
  flex: 0 0 23px;
  height: 23px;
  width: 23px;
}

.smart-plan-days {
  display: grid;
  gap: 8px;
}

.smart-plan-days article {
  align-items: center;
  background: var(--panel-2);
  border-radius: 14px;
  display: grid;
  gap: 10px;
  grid-template-columns: 48px minmax(0, 1fr);
  min-height: 48px;
  padding: 9px 12px;
}

.smart-plan-days b {
  color: var(--accent);
  font-size: 0.75rem;
}

.smart-plan-days span {
  font-size: 0.82rem;
  line-height: 1.35;
}

.smart-plan-upgrade {
  align-items: center;
  display: grid;
  gap: 12px;
  grid-template-columns: minmax(0, 1fr) auto;
}

.smart-plan-upgrade strong {
  color: var(--ink);
}

.smart-plan-active-label {
  background: color-mix(in srgb, var(--green) 10%, var(--panel));
  border-radius: 14px;
  color: var(--green);
  padding: 13px;
}

.study-preferences-card {
  display: grid;
  gap: 18px;
}

.preferences-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.study-preferences-card fieldset {
  border: 0;
  border-top: 1px solid var(--line);
  margin: 0;
  min-width: 0;
  padding: 16px 0 0;
}

.study-preferences-card legend {
  color: var(--muted);
  font-size: 0.74rem;
  font-weight: 900;
  padding: 0 8px 0 0;
  text-transform: uppercase;
}

.preference-toggle-grid {
  display: grid;
  gap: 9px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.preference-toggle-grid .toggle-field,
.study-preferences-card .toggle-field {
  min-height: 52px;
}

[data-reduced-motion="true"] .page-enter,
[data-reduced-motion="true"] .mascot-face,
[data-reduced-motion="true"] .xp-toast,
[data-reduced-motion="true"] .home-quick-card,
[data-reduced-motion="true"] .today-focus-progress i {
  animation: none !important;
  transition: none !important;
}

@media (max-width: 520px) {
  .exam-extra-fields,
  .preferences-grid {
    grid-template-columns: 1fr;
  }

  .smart-plan-upgrade {
    align-items: stretch;
    grid-template-columns: 1fr;
  }

  .smart-plan-upgrade .primary-button {
    width: 100%;
  }
}

.home-greeting {
  align-items: flex-start;
  display: grid;
  gap: 12px;
  grid-template-columns: minmax(0, 1fr) auto;
}

.home-greeting .home-welcome-actions {
  margin-top: 1px;
}

.home-greeting .home-streak-pill strong {
  font-size: 0.76rem;
  white-space: nowrap;
}

.onboarding-actions,
.school-settings-card .button-row {
  display: grid;
  gap: 10px;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
}

.school-settings-card {
  display: grid;
  gap: 18px;
}

.school-settings-summary {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.school-settings-summary article {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 14px;
}

.school-settings-summary span {
  color: var(--muted);
  display: block;
  font-size: 0.72rem;
  font-weight: 900;
  margin-bottom: 6px;
  text-transform: uppercase;
}

.school-settings-summary strong {
  color: var(--ink);
  font-size: 0.95rem;
  line-height: 1.25;
}

.toggle-field.is-muted {
  opacity: 0.72;
}

.quick-pluspoints > span {
  background: color-mix(in srgb, var(--green) 16%, var(--primary-soft));
  color: var(--green);
  font-size: 1.35rem;
  font-weight: 1000;
}

.pluspoints-explainer {
  background: color-mix(in srgb, var(--accent) 6%, var(--panel));
  border: 1px solid color-mix(in srgb, var(--accent) 14%, var(--line));
  border-radius: 18px;
  color: var(--muted);
  font-size: 0.9rem;
  grid-column: 1 / -1;
  line-height: 1.45;
  margin: 2px 0 0;
  padding: 13px 14px;
}

.pluspoints-explainer strong {
  color: var(--ink);
}

@media (max-width: 390px) {
  .home-page.focus-home .home-greeting h1 {
    font-size: clamp(1.65rem, 8vw, 2rem);
  }

  .home-greeting .home-welcome-actions {
    gap: 5px;
  }

  .home-greeting .home-streak-pill {
    padding-inline: 9px;
  }

  .home-greeting .home-streak-pill strong {
    font-size: 0.68rem;
  }
}

@media (max-width: 520px) {
  .onboarding-actions,
  .school-settings-card .button-row,
  .school-settings-summary {
    grid-template-columns: 1fr;
  }
}

/* Connected study-coach workflow: Today mission, Study hub, AI builder, mistakes and progress. */
.mission-insight-grid {
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin: 14px 0;
}

.mission-insight-grid article {
  background: rgba(255, 255, 255, 0.68);
  border: 1px solid color-mix(in srgb, var(--home-primary, var(--accent)) 10%, transparent);
  border-radius: 16px;
  min-width: 0;
  padding: 10px;
}

.mission-insight-grid span,
.mission-insight-grid small {
  color: var(--home-muted, var(--muted));
  display: block;
  font-size: 0.66rem;
  font-weight: 760;
  line-height: 1.25;
}

.mission-insight-grid strong {
  color: var(--home-text, var(--ink));
  display: block;
  font-size: 1rem;
  line-height: 1.15;
  margin: 3px 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.study-hub-card,
.ai-study-builder,
.planner-coach-card,
.mistake-coach-panel {
  background: linear-gradient(145deg, var(--panel), color-mix(in srgb, var(--accent) 6%, var(--panel)));
  border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
  border-radius: 24px;
  box-shadow: var(--shadow);
  display: grid;
  gap: 16px;
  padding: 18px;
}

.study-hub-card,
.planner-coach-card,
.mistake-coach-panel {
  align-items: center;
  grid-template-columns: minmax(0, 1fr) auto;
}

.study-hub-card span,
.ai-builder-head span,
.planner-coach-card span,
.mistake-coach-panel span {
  color: var(--accent);
  display: block;
  font-size: 0.72rem;
  font-weight: 900;
  text-transform: uppercase;
}

.study-hub-card h2,
.ai-builder-head h2,
.planner-coach-card h2,
.mistake-coach-panel h2 {
  color: var(--ink);
  font-size: clamp(1.2rem, 5vw, 1.7rem);
  line-height: 1.15;
  margin: 5px 0 7px;
}

.study-hub-card p,
.ai-builder-head p,
.planner-coach-card p,
.mistake-coach-panel p {
  color: var(--muted);
  font-size: 0.84rem;
  line-height: 1.5;
  margin: 0;
}

.study-hub-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-top: 12px;
}

.study-hub-metrics em {
  background: var(--accent-soft);
  border-radius: 999px;
  color: var(--accent);
  font-size: 0.68rem;
  font-style: normal;
  font-weight: 840;
  padding: 6px 9px;
}

.study-hub-actions,
.mistake-coach-actions,
.ai-builder-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 9px;
}

.study-hub-actions {
  justify-content: end;
  max-width: 180px;
}

.first-study-path {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 24px;
  box-shadow: var(--shadow-soft);
  display: grid;
  gap: 12px;
  grid-template-columns: auto minmax(0, 1fr);
  margin-top: 14px;
  padding: 16px;
}

.first-study-path strong {
  color: var(--ink);
  display: block;
  font-size: 1rem;
}

.first-study-path p {
  color: var(--muted);
  font-size: 0.82rem;
  line-height: 1.45;
  margin: 4px 0 0;
}

.first-study-path .primary-button {
  grid-column: 1 / -1;
  min-height: 44px;
}

.study-hub-actions .primary-button,
.study-hub-actions .secondary-button,
.planner-coach-card .primary-button,
.mistake-coach-actions .primary-button,
.mistake-coach-actions .secondary-button,
.ai-builder-actions .primary-button,
.ai-builder-actions .secondary-button {
  min-height: 44px;
}

.ai-study-builder {
  margin-bottom: 14px;
}

.ai-builder-head {
  align-items: flex-start;
  display: flex;
  gap: 16px;
  justify-content: space-between;
}

.ai-builder-head > .icon {
  color: var(--accent);
  flex: 0 0 auto;
  height: 26px;
  width: 26px;
}

.ai-study-builder textarea {
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 18px;
  color: var(--ink);
  font: inherit;
  min-height: 112px;
  padding: 14px;
  resize: vertical;
  width: 100%;
}

.ai-notes-file-button {
  cursor: pointer;
  overflow: hidden;
  position: relative;
}

.ai-notes-file-button input {
  height: 1px;
  opacity: 0;
  pointer-events: none;
  position: absolute;
  width: 1px;
}

.ai-file-status {
  background: color-mix(in srgb, var(--accent) 7%, var(--panel-2));
  border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
  border-radius: 18px;
  display: grid;
  gap: 4px;
  padding: 12px 14px;
}

.ai-file-status strong {
  color: var(--ink);
  font-size: 0.92rem;
}

.ai-file-status span,
.ai-file-status p {
  color: var(--muted);
  font-size: 0.78rem;
  line-height: 1.4;
  margin: 0;
}

.ai-privacy-note,
.local-auth-note {
  align-items: flex-start;
  background: color-mix(in srgb, var(--accent) 8%, var(--panel-2));
  border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
  border-radius: 16px;
  color: var(--muted);
  display: flex;
  gap: 10px;
  line-height: 1.45;
  margin: 0;
  padding: 12px 14px;
}

.ai-privacy-note p,
.local-auth-note {
  font-size: 0.84rem;
  margin: 0;
}

.ai-privacy-note .icon {
  color: var(--accent);
  flex: 0 0 auto;
}

.ai-status-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 4px;
}

.ai-status-actions .secondary-button {
  min-height: 38px;
}

.ai-file-status.blocked,
.ai-file-status.error {
  background: color-mix(in srgb, var(--gold) 10%, var(--panel-2));
  border-color: color-mix(in srgb, var(--gold) 28%, var(--line));
}

.mistake-coach-panel {
  margin-bottom: 14px;
}

.mistake-explanation-panel {
  background: color-mix(in srgb, var(--accent) 6%, var(--panel-2));
  border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
  border-radius: 16px;
  margin: 12px 0;
  padding: 12px;
}

.mistake-explanation-panel strong {
  color: var(--ink);
  display: block;
  font-size: 0.94rem;
}

.mistake-explanation-panel p {
  color: var(--muted);
  font-size: 0.82rem;
  line-height: 1.45;
  margin: 5px 0 0;
}

.mistake-explanation-panel small {
  color: var(--accent);
  display: block;
  font-size: 0.76rem;
  font-weight: 850;
  margin-top: 8px;
}

.mistake-action-grid {
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin: 12px 0;
}

.mistake-action-grid .secondary-button {
  min-height: 44px;
  padding-inline: 10px;
}

.learning-metric-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.learning-metric-grid article {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 20px;
  box-shadow: var(--shadow-soft);
  min-height: 118px;
  padding: 15px;
}

.learning-metric-grid span,
.learning-metric-grid small {
  color: var(--muted);
  display: block;
  font-size: 0.72rem;
  font-weight: 800;
}

.learning-metric-grid strong {
  color: var(--ink);
  display: block;
  font-size: 1.55rem;
  line-height: 1;
  margin: 12px 0 8px;
}

.weak-topic-review-panel {
  display: grid;
  gap: 10px;
}

.weak-topic-review {
  align-items: center;
  background: var(--panel-2);
  border: 1px solid var(--line);
  border-radius: 16px;
  color: var(--ink);
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  min-height: 52px;
  padding: 12px;
  text-align: left;
}

.weak-topic-review span {
  color: var(--muted);
  font-size: 0.76rem;
  font-weight: 800;
}

.study-flashcard {
  touch-action: none;
  transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
}

.study-flashcard.swipe-left {
  border-color: color-mix(in srgb, var(--bad) 50%, var(--line));
  box-shadow: 0 18px 38px color-mix(in srgb, var(--bad) 20%, transparent);
  transform: translateX(-14px) rotate(-2deg);
}

.study-flashcard.swipe-right {
  border-color: color-mix(in srgb, var(--good) 50%, var(--line));
  box-shadow: 0 18px 38px color-mix(in srgb, var(--good) 18%, transparent);
  transform: translateX(14px) rotate(2deg);
}

.study-flashcard.swipe-up {
  border-color: color-mix(in srgb, var(--ok) 50%, var(--line));
  box-shadow: 0 18px 38px color-mix(in srgb, var(--ok) 18%, transparent);
  transform: translateY(-12px);
}

.study-flashcard.swipe-down {
  border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
  box-shadow: 0 18px 38px color-mix(in srgb, var(--accent) 18%, transparent);
  transform: translateY(12px);
}

.bottom-nav {
  grid-template-columns: repeat(5, minmax(0, 1fr));
}

/* Premium dark mission home */
body[data-route="dashboard"] {
  --mission-bg: #070b16;
  --mission-bg-soft: #0d1322;
  --mission-panel: #111a2a;
  --mission-panel-2: #151f32;
  --mission-text: #f4f7ff;
  --mission-muted: #a7b2c6;
  --mission-line: rgba(148, 163, 184, 0.18);
  --mission-purple: var(--accent);
  --mission-purple-soft: color-mix(in srgb, var(--accent) 18%, #111a2a);
  --mission-glow: color-mix(in srgb, var(--accent) 36%, transparent);
  --home-bg: var(--mission-bg);
  --home-surface: var(--mission-panel);
  --home-surface-soft: var(--mission-panel-2);
  --home-text: var(--mission-text);
  --home-muted: var(--mission-muted);
  --home-line: var(--mission-line);
  --home-primary: var(--accent);
  --home-primary-soft: var(--mission-purple-soft);
  background:
    radial-gradient(circle at 74% -8%, color-mix(in srgb, var(--accent) 28%, transparent), transparent 34%),
    radial-gradient(circle at 6% 20%, rgba(37, 99, 235, 0.12), transparent 30%),
    linear-gradient(180deg, #080d18 0%, var(--mission-bg) 58%, #050914 100%);
  color: var(--mission-text);
}

body[data-route="dashboard"] .app-shell {
  background: transparent;
}

body[data-route="dashboard"] .main-content {
  max-width: 480px;
  padding: 20px 20px 128px;
}

.mission-home {
  color: var(--mission-text);
  gap: 18px;
  max-width: 440px;
}

.mission-home .mission-home-header {
  margin: 0 0 8px;
}

.mission-home .home-brand {
  color: var(--mission-text);
  font-size: 1.02rem;
  font-weight: 900;
}

.mission-home .home-brand img {
  background: #05070d;
  border-radius: 14px;
  box-shadow: 0 12px 28px rgba(0, 0, 0, 0.34);
  height: 42px;
  width: 42px;
}

.mission-home .home-header-actions {
  gap: 10px;
}

.mission-home .home-streak-pill,
.mission-home .home-header-icon {
  background: rgba(17, 26, 42, 0.9);
  border: 1px solid var(--mission-line);
  box-shadow: 0 12px 28px rgba(0, 0, 0, 0.24);
  color: var(--mission-text);
  min-height: 44px;
}

.mission-home .home-streak-pill {
  border-color: rgba(249, 115, 22, 0.38);
  color: #ffb86b;
  gap: 7px;
  padding: 0 13px;
}

.mission-home .home-streak-pill strong {
  color: #fff6ed;
}

.mission-home .home-header-icon {
  border-radius: 50%;
  height: 44px;
  width: 44px;
}

.mission-home .home-notification-button b {
  border-color: var(--mission-panel);
}

.mission-greeting {
  display: block;
  margin: 0;
}

.home-page.focus-home .mission-greeting h1 {
  color: var(--mission-text);
  font-size: clamp(2.15rem, 10vw, 3.25rem);
  font-weight: 940;
  letter-spacing: 0;
  line-height: 1.02;
  text-align: left;
}

.mission-greeting p {
  color: var(--mission-muted);
  font-size: 0.98rem;
  margin: 8px 0 0;
}

.mission-home .important-reminder {
  background: rgba(17, 26, 42, 0.78);
  border: 1px solid var(--mission-line) !important;
  border-radius: 24px;
  box-shadow: 0 20px 44px rgba(0, 0, 0, 0.18);
  min-height: 78px;
}

.mission-home .reminder-icon {
  background: rgba(217, 154, 30, 0.14);
  color: #f5b84c;
}

.mission-home .reminder-copy h2,
.mission-home .reminder-action {
  color: var(--mission-text);
}

.mission-home .reminder-copy p,
.mission-home .reminder-copy > span {
  color: var(--mission-muted);
}

.mission-home .mission-card {
  align-items: stretch;
  background:
    radial-gradient(circle at 86% 10%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 34%),
    linear-gradient(145deg, rgba(27, 34, 57, 0.98), rgba(18, 27, 44, 0.96));
  border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--mission-line));
  border-radius: 32px;
  box-shadow: 0 30px 70px rgba(0, 0, 0, 0.36), 0 0 0 1px rgba(255, 255, 255, 0.02) inset;
  grid-template-columns: minmax(0, 1fr) 86px;
  min-height: 348px;
  padding: 24px;
}

.mission-home .mission-card::after {
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  right: -54px;
  top: -56px;
}

.mission-home .today-focus-head {
  align-items: center;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.mission-home .today-focus-head > span {
  background: var(--mission-purple-soft);
  color: color-mix(in srgb, var(--accent) 42%, #ffffff);
  font-weight: 950;
}

.mission-home .today-focus-head em {
  color: var(--mission-muted);
  font-size: 0.72rem;
  font-style: normal;
  font-weight: 850;
}

.mission-home .today-focus-card h2 {
  color: var(--mission-text);
  font-size: clamp(2rem, 9.5vw, 2.75rem);
  font-weight: 950;
  line-height: 1.03;
  margin: 22px 0 12px;
}

.mission-home .today-focus-card .mission-copy > p,
.mission-home .today-focus-reason {
  color: var(--mission-muted) !important;
}

.mission-home .today-focus-meta span {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #cbd5e1;
}

.mission-home .today-focus-progress {
  background: rgba(255, 255, 255, 0.08);
  height: 7px;
}

.mission-home .today-focus-progress i {
  background: linear-gradient(90deg, var(--mission-purple), color-mix(in srgb, var(--mission-purple) 58%, #ffffff));
}

.mission-home .today-focus-footer .primary-button,
.mission-home .today-focus-footer .secondary-button {
  background: linear-gradient(135deg, var(--mission-purple), color-mix(in srgb, var(--mission-purple) 74%, #9f7aea));
  border: 0;
  border-radius: 16px;
  box-shadow: 0 18px 36px var(--mission-glow);
  color: #fff;
  min-height: 56px;
  width: 100%;
}

.mission-mastery {
  align-items: center;
  align-self: center;
  display: grid;
  gap: 10px;
  justify-items: center;
  position: relative;
  z-index: 1;
}

.mission-mastery span {
  color: var(--mission-muted);
  font-size: 0.7rem;
  font-weight: 900;
}

.mastery-ring {
  align-items: center;
  aspect-ratio: 1;
  background:
    radial-gradient(circle, var(--mission-panel) 0 55%, transparent 57%),
    conic-gradient(var(--mission-purple) calc(var(--mission-mastery) * 1%), rgba(255, 255, 255, 0.1) 0);
  border-radius: 50%;
  display: grid;
  place-items: center;
  width: 78px;
}

.mastery-ring strong {
  color: var(--mission-text);
  font-size: 1.05rem;
  font-weight: 950;
}

.mission-stat-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.mission-stat-card,
.mission-panel {
  background: rgba(17, 26, 42, 0.86);
  border: 1px solid var(--mission-line);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.2);
}

.mission-stat-card {
  border-radius: 22px;
  display: grid;
  gap: 9px;
  min-height: 122px;
  padding: 15px;
}

.mission-stat-card span {
  align-items: center;
  background: var(--mission-purple-soft);
  border-radius: 13px;
  color: color-mix(in srgb, var(--accent) 44%, #ffffff);
  display: inline-flex;
  height: 38px;
  justify-content: center;
  width: 38px;
}

.mission-stat-card .icon {
  height: 19px;
  width: 19px;
}

.mission-stat-card strong {
  color: var(--mission-text);
  font-size: 1.55rem;
  font-weight: 950;
  line-height: 1;
}

.mission-stat-card small {
  color: var(--mission-muted);
  font-size: 0.72rem;
  font-weight: 850;
}

.mission-grade-card {
  background:
    radial-gradient(circle at 0% 0%, color-mix(in srgb, var(--accent) 18%, transparent), transparent 36%),
    linear-gradient(145deg, rgba(20, 27, 45, 0.96), rgba(13, 19, 32, 0.92));
  border: 1px solid var(--mission-line);
  border-radius: 22px;
  box-shadow: 0 18px 42px rgba(0, 0, 0, 0.22);
  color: var(--mission-text);
  display: grid;
  gap: 16px;
  padding: 18px;
  text-decoration: none;
}

.mission-grade-card header {
  align-items: center;
  display: flex;
  gap: 12px;
  justify-content: space-between;
}

.mission-grade-card header > div {
  align-items: center;
  display: flex;
  gap: 11px;
  min-width: 0;
}

.mission-grade-card h2 {
  color: var(--mission-text);
  font-size: 1.12rem;
  line-height: 1;
  margin: 0;
}

.mission-grade-card header > .icon {
  color: var(--mission-muted);
  height: 19px;
  width: 19px;
}

.mission-grade-icon {
  align-items: center;
  background: color-mix(in srgb, var(--accent) 18%, transparent);
  border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
  border-radius: 14px;
  color: color-mix(in srgb, var(--accent) 44%, #ffffff);
  display: inline-flex;
  flex: 0 0 auto;
  height: 38px;
  justify-content: center;
  width: 38px;
}

.mission-grade-icon .icon {
  height: 19px;
  width: 19px;
}

.mission-grade-values {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  min-height: 94px;
}

.mission-grade-window {
  align-content: center;
  background: color-mix(in srgb, var(--mission-panel) 76%, transparent);
  border: 1px solid color-mix(in srgb, var(--mission-line) 86%, transparent);
  border-radius: 18px;
  display: grid;
  gap: 6px;
  min-width: 0;
  padding: 16px 18px;
}

.mission-grade-values article + article {
  border-left: 0;
  padding-left: 18px;
}

.mission-grade-values span {
  color: color-mix(in srgb, var(--mission-muted) 88%, #ffffff);
  font-size: 0.72rem;
  font-weight: 900;
}

.mission-grade-values strong {
  color: var(--mission-text);
  font-size: clamp(1.62rem, 7vw, 2.12rem);
  font-weight: 980;
  letter-spacing: 0;
  line-height: 1.02;
  overflow-wrap: anywhere;
}

.mission-grade-secondary.positive strong {
  color: color-mix(in srgb, var(--accent) 54%, #ffffff);
}

.mission-grade-secondary.negative strong {
  color: var(--danger);
}

.mission-grade-secondary.grade-low {
  background: color-mix(in srgb, var(--bad) 18%, var(--mission-panel));
  border-color: color-mix(in srgb, var(--bad) 44%, var(--mission-line));
}

.mission-grade-secondary.grade-warning {
  background: color-mix(in srgb, #f97316 18%, var(--mission-panel));
  border-color: color-mix(in srgb, #f97316 44%, var(--mission-line));
}

.mission-grade-secondary.grade-ok {
  background: color-mix(in srgb, #facc15 20%, var(--mission-panel));
  border-color: color-mix(in srgb, #eab308 42%, var(--mission-line));
}

.mission-grade-secondary.grade-light-good {
  background: color-mix(in srgb, #84cc16 18%, var(--mission-panel));
  border-color: color-mix(in srgb, #65a30d 42%, var(--mission-line));
}

.mission-grade-secondary.grade-high {
  background: color-mix(in srgb, var(--good) 22%, var(--mission-panel));
  border-color: color-mix(in srgb, var(--good) 52%, var(--mission-line));
}

.mission-grade-secondary.grade-low strong {
  color: color-mix(in srgb, var(--bad) 82%, var(--mission-text));
}

.mission-grade-secondary.grade-warning strong {
  color: color-mix(in srgb, #f97316 82%, var(--mission-text));
}

.mission-grade-secondary.grade-ok strong {
  color: color-mix(in srgb, #ca8a04 76%, var(--mission-text));
}

.mission-grade-secondary.grade-light-good strong {
  color: color-mix(in srgb, #65a30d 78%, var(--mission-text));
}

.mission-grade-secondary.grade-high strong {
  color: color-mix(in srgb, var(--good) 78%, var(--mission-text));
}

.mission-grade-values small {
  color: var(--mission-muted);
  font-size: 0.76rem;
  font-weight: 790;
}

.mission-grade-card:hover,
.mission-grade-card:focus-visible {
  border-color: color-mix(in srgb, var(--accent) 38%, var(--mission-line));
  transform: translateY(-1px);
}

.mission-secondary-grid {
  display: grid;
  gap: 14px;
}

.mission-panel {
  border-radius: 26px;
  padding: 18px;
}

.mission-panel > span {
  color: color-mix(in srgb, var(--accent) 42%, #ffffff);
  display: block;
  font-size: 0.72rem;
  font-weight: 950;
  margin-bottom: 8px;
  text-transform: uppercase;
}

.mission-panel h2 {
  color: var(--mission-text);
  font-size: 1.15rem;
  line-height: 1.22;
  margin: 0;
}

.mission-panel p {
  color: var(--mission-muted);
  line-height: 1.45;
  margin: 8px 0 0;
}

.mission-text-link {
  align-items: center;
  color: color-mix(in srgb, var(--accent) 42%, #ffffff);
  display: inline-flex;
  font-size: 0.86rem;
  font-weight: 920;
  gap: 5px;
  margin-top: 14px;
  min-height: 44px;
}

body[data-route="dashboard"] .bottom-nav {
  background: rgba(17, 26, 42, 0.92);
  border: 1px solid rgba(148, 163, 184, 0.18);
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.38);
}

body[data-route="dashboard"] .bottom-nav a {
  color: #93a0b5;
}

body[data-route="dashboard"] .bottom-nav a.active {
  color: color-mix(in srgb, var(--accent) 40%, #ffffff);
}

body[data-route="dashboard"] .bottom-nav a.active .nav-icon {
  color: color-mix(in srgb, var(--accent) 40%, #ffffff);
}

@media (max-width: 390px) {
  body[data-route="dashboard"] .main-content {
    padding-inline: 14px;
  }

  .mission-home .mission-card {
    grid-template-columns: minmax(0, 1fr);
    min-height: auto;
  }

  .mission-mastery {
    align-items: center;
    display: flex;
    justify-content: space-between;
  }

  .mastery-ring {
    width: 64px;
  }

  .mission-stat-grid {
    gap: 8px;
  }

  .mission-stat-card {
    border-radius: 18px;
    padding: 12px;
  }
}

html[data-theme="light"] .study-hub-card,
html[data-theme="light"] .ai-study-builder,
html[data-theme="light"] .planner-coach-card,
html[data-theme="light"] .mistake-coach-panel {
  background: linear-gradient(145deg, #ffffff, color-mix(in srgb, var(--accent) 5%, #ffffff));
  border-color: color-mix(in srgb, var(--accent) 16%, var(--home-line));
  box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
}

html[data-theme="light"] .study-hub-card h2,
html[data-theme="light"] .ai-builder-head h2,
html[data-theme="light"] .planner-coach-card h2,
html[data-theme="light"] .mistake-coach-panel h2,
html[data-theme="light"] .learning-metric-grid strong,
html[data-theme="light"] .mistake-explanation-panel strong {
  color: var(--home-text);
}

html[data-theme="light"] .study-hub-card p,
html[data-theme="light"] .ai-builder-head p,
html[data-theme="light"] .planner-coach-card p,
html[data-theme="light"] .mistake-coach-panel p,
html[data-theme="light"] .learning-metric-grid span,
html[data-theme="light"] .learning-metric-grid small,
html[data-theme="light"] .mistake-explanation-panel p {
  color: var(--home-muted);
}

@media (max-width: 520px) {
  .study-hub-card,
  .planner-coach-card,
  .mistake-coach-panel {
    grid-template-columns: 1fr;
  }

  .study-hub-actions,
  .mistake-coach-actions {
    justify-content: stretch;
    max-width: none;
  }

  .study-hub-actions > *,
  .mistake-coach-actions > *,
  .planner-coach-card .primary-button {
    width: 100%;
  }
}

@media (max-width: 360px) {
  .mission-insight-grid,
  .learning-metric-grid,
  .mistake-action-grid {
    grid-template-columns: 1fr;
  }
}

@media (prefers-reduced-motion: reduce) {
  .study-flashcard {
    transition: none;
  }

  .study-flashcard.swipe-left,
  .study-flashcard.swipe-right,
  .study-flashcard.swipe-up,
  .study-flashcard.swipe-down {
    transform: none;
  }
}

/* Keep the Home screen aligned with the selected accent color. */
body[data-route="dashboard"] {
  --mission-purple: var(--accent);
  --mission-purple-soft: color-mix(in srgb, var(--accent) 18%, var(--mission-panel));
  --mission-glow: color-mix(in srgb, var(--accent) 34%, transparent);
  --home-primary: var(--accent);
  --home-primary-soft: color-mix(in srgb, var(--accent) 16%, var(--mission-panel));
}

html[data-theme="light"] body[data-route="dashboard"] {
  --mission-bg: color-mix(in srgb, var(--accent) 7%, #fafafd);
  --mission-bg-soft: color-mix(in srgb, var(--accent) 10%, #ffffff);
  --mission-panel: color-mix(in srgb, var(--accent) 3%, #ffffff);
  --mission-panel-2: color-mix(in srgb, var(--accent) 8%, #ffffff);
  --mission-text: #10162f;
  --mission-muted: #657184;
  --mission-line: color-mix(in srgb, var(--accent) 14%, #e8eaf2);
  --mission-purple-soft: color-mix(in srgb, var(--accent) 14%, #ffffff);
  --home-bg: var(--mission-bg);
  --home-surface: var(--mission-panel);
  --home-surface-soft: var(--mission-panel-2);
  --home-text: var(--mission-text);
  --home-muted: var(--mission-muted);
  --home-line: var(--mission-line);
  background:
    radial-gradient(circle at 82% -10%, color-mix(in srgb, var(--accent) 18%, transparent), transparent 34%),
    radial-gradient(circle at 4% 20%, color-mix(in srgb, var(--accent) 9%, transparent), transparent 30%),
    linear-gradient(180deg, var(--mission-bg) 0%, color-mix(in srgb, var(--accent) 4%, #ffffff) 60%, var(--mission-bg) 100%);
  color: var(--mission-text);
}

html[data-theme="dark"] body[data-route="dashboard"] {
  --mission-bg: color-mix(in srgb, var(--accent) 10%, #050914);
  --mission-bg-soft: color-mix(in srgb, var(--accent) 14%, #090f1c);
  --mission-panel: color-mix(in srgb, var(--accent) 9%, #101827);
  --mission-panel-2: color-mix(in srgb, var(--accent) 12%, #121c2d);
  --mission-text: #f4f7ff;
  --mission-muted: #a7b2c6;
  --mission-line: color-mix(in srgb, var(--accent) 20%, rgba(148, 163, 184, 0.18));
  --mission-purple-soft: color-mix(in srgb, var(--accent) 22%, #121b2a);
  --home-bg: var(--mission-bg);
  --home-surface: var(--mission-panel);
  --home-surface-soft: var(--mission-panel-2);
  --home-text: var(--mission-text);
  --home-muted: var(--mission-muted);
  --home-line: var(--mission-line);
  background:
    radial-gradient(circle at 74% -8%, color-mix(in srgb, var(--accent) 30%, transparent), transparent 34%),
    radial-gradient(circle at 6% 20%, color-mix(in srgb, var(--accent) 15%, transparent), transparent 30%),
    linear-gradient(180deg, var(--mission-bg-soft) 0%, var(--mission-bg) 58%, color-mix(in srgb, var(--accent) 7%, #050914) 100%);
  color: var(--mission-text);
}

html[data-theme="light"] .mission-home .home-streak-pill,
html[data-theme="light"] .mission-home .home-header-icon,
html[data-theme="light"] .mission-home .important-reminder,
html[data-theme="light"] .mission-stat-card,
html[data-theme="light"] .mission-panel,
html[data-theme="light"] .mission-grade-card {
  background: color-mix(in srgb, var(--mission-panel) 94%, transparent);
  border-color: var(--mission-line);
  box-shadow: 0 18px 45px color-mix(in srgb, var(--accent) 10%, rgba(15, 23, 42, 0.08));
}

html[data-theme="light"] .mission-home .mission-card {
  background:
    radial-gradient(circle at 86% 10%, color-mix(in srgb, var(--accent) 15%, transparent), transparent 34%),
    linear-gradient(145deg, color-mix(in srgb, var(--accent) 8%, #ffffff), color-mix(in srgb, var(--accent) 13%, #f8f6ff));
  border-color: color-mix(in srgb, var(--accent) 18%, #e8eaf2);
  box-shadow: 0 24px 58px color-mix(in srgb, var(--accent) 12%, rgba(15, 23, 42, 0.08));
}

html[data-theme="light"] .mission-home .mission-card::after {
  background: color-mix(in srgb, var(--accent) 13%, transparent);
}

html[data-theme="light"] .mission-home .today-focus-meta span {
  background: color-mix(in srgb, var(--accent) 7%, #ffffff);
  border-color: color-mix(in srgb, var(--accent) 14%, #e8eaf2);
  color: var(--mission-muted);
}

html[data-theme="light"] .mission-home .today-focus-progress {
  background: color-mix(in srgb, var(--accent) 13%, #ffffff);
}

html[data-theme="light"] .mission-home .home-streak-pill strong,
html[data-theme="light"] .mission-home .today-focus-card h2,
html[data-theme="light"] .mission-grade-card h2,
html[data-theme="light"] .mission-grade-values strong,
html[data-theme="light"] .mission-panel h2,
html[data-theme="light"] .mission-stat-card strong,
html[data-theme="light"] .mastery-ring strong {
  color: var(--mission-text);
}

html[data-theme="light"] .mission-grade-secondary.positive strong {
  color: var(--accent);
}

html[data-theme="light"] .mastery-ring {
  background:
    radial-gradient(circle, var(--mission-panel) 0 55%, transparent 57%),
    conic-gradient(var(--accent) calc(var(--mission-mastery) * 1%), color-mix(in srgb, var(--accent) 13%, #ffffff) 0);
}

html[data-theme="dark"] .mission-home .mission-card,
html[data-theme="dark"] .mission-stat-card,
html[data-theme="dark"] .mission-panel,
html[data-theme="dark"] .mission-grade-card,
html[data-theme="dark"] body[data-route="dashboard"] .bottom-nav {
  border-color: var(--mission-line);
}

/* Final theme pass: every authenticated screen follows the selected accent. */
html[data-theme="light"] body:not(.is-locked) {
  --premium-bg: color-mix(in srgb, var(--accent) 7%, #fafafd);
  --premium-surface: color-mix(in srgb, var(--accent) 3%, #ffffff);
  --premium-surface-soft: color-mix(in srgb, var(--accent) 8%, #ffffff);
  --premium-text: #10162f;
  --premium-muted: #5f6d80;
  --premium-line: color-mix(in srgb, var(--accent) 15%, #e8eaf2);
  --premium-shadow: 0 18px 44px color-mix(in srgb, var(--accent) 10%, rgba(15, 23, 42, 0.08));
  --ink: var(--premium-text);
  --muted: var(--premium-muted);
  --line: var(--premium-line);
  --soft: var(--premium-bg);
  --panel: var(--premium-surface);
  --panel-2: var(--premium-surface-soft);
  --sleek-bg: var(--premium-bg);
  --sleek-ink: var(--premium-text);
  --sleek-muted: var(--premium-muted);
  --shadow: var(--premium-shadow);
  --shadow-soft: 0 12px 30px color-mix(in srgb, var(--accent) 8%, rgba(15, 23, 42, 0.08));
  background:
    radial-gradient(circle at 82% -10%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 34rem),
    radial-gradient(circle at 0% 28%, color-mix(in srgb, var(--accent) 8%, transparent), transparent 24rem),
    linear-gradient(180deg, var(--premium-bg), color-mix(in srgb, var(--accent) 4%, #ffffff) 72%, var(--premium-bg));
  color: var(--premium-text);
}

html[data-theme="dark"] body:not(.is-locked) {
  --premium-bg: color-mix(in srgb, var(--accent) 10%, #050914);
  --premium-surface: color-mix(in srgb, var(--accent) 9%, #101827);
  --premium-surface-soft: color-mix(in srgb, var(--accent) 12%, #121c2d);
  --premium-text: #f8fafc;
  --premium-muted: #a8b3c7;
  --premium-line: color-mix(in srgb, var(--accent) 22%, rgba(148, 163, 184, 0.18));
  --premium-shadow: 0 22px 58px rgba(0, 0, 0, 0.34);
  --ink: var(--premium-text);
  --muted: var(--premium-muted);
  --line: var(--premium-line);
  --soft: var(--premium-bg);
  --panel: var(--premium-surface);
  --panel-2: var(--premium-surface-soft);
  --sleek-bg: var(--premium-bg);
  --sleek-ink: var(--premium-text);
  --sleek-muted: var(--premium-muted);
  --shadow: var(--premium-shadow);
  --shadow-soft: 0 16px 38px rgba(0, 0, 0, 0.24);
  background:
    radial-gradient(circle at 82% -10%, color-mix(in srgb, var(--accent) 28%, transparent), transparent 34rem),
    radial-gradient(circle at 0% 28%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 24rem),
    linear-gradient(180deg, color-mix(in srgb, var(--accent) 13%, #090e1b), var(--premium-bg) 70%, color-mix(in srgb, var(--accent) 8%, #050914));
  color: var(--premium-text);
}

html[data-theme="light"] body:not(.is-locked) .app-shell,
html[data-theme="dark"] body:not(.is-locked) .app-shell {
  background: transparent;
  color: var(--premium-text);
}

html[data-theme="light"] body:not(.is-locked) :where(.main-content, .sleek-screen, .grade-page, .planner-page, .cards-page, .settings-page, .mistake-page, .session-page, .bot-page),
html[data-theme="dark"] body:not(.is-locked) :where(.main-content, .sleek-screen, .grade-page, .planner-page, .cards-page, .settings-page, .mistake-page, .session-page, .bot-page) {
  color: var(--premium-text);
}

html[data-theme="light"] body:not(.is-locked) :where(.panel, .focus-card, .stat-card, .price-card, .item-card, .subject-card, .goal-card, .mini-card, .grade-overview-card, .grade-row, .study-hub-card, .ai-study-builder, .planner-coach-card, .mistake-coach-panel, .learning-metric-grid article, .level-card, .challenge-card, .team-goal-card, .class-league-hero, .notification-center, .cards-search-shell, .recent-deck-row, .search-deck-row, .deck-session-choice, .learning-mode-card, .grade-summary-card, .grade-folder, .calendar-only-panel, .agenda-card, .test-setup-panel, .test-list-question, .mode-question-card, .session-mini-status, .ai-window, .empty-state, .first-study-path, .weak-topic-review, .library-pack, .subject-deck) {
  background: color-mix(in srgb, var(--premium-surface) 94%, var(--accent) 6%);
  border-color: var(--premium-line);
  color: var(--premium-text);
  box-shadow: var(--shadow-soft);
}

html[data-theme="dark"] body:not(.is-locked) :where(.panel, .focus-card, .stat-card, .price-card, .item-card, .subject-card, .goal-card, .mini-card, .grade-overview-card, .grade-row, .study-hub-card, .ai-study-builder, .planner-coach-card, .mistake-coach-panel, .learning-metric-grid article, .level-card, .challenge-card, .team-goal-card, .class-league-hero, .notification-center, .cards-search-shell, .recent-deck-row, .search-deck-row, .deck-session-choice, .learning-mode-card, .grade-summary-card, .grade-folder, .calendar-only-panel, .agenda-card, .test-setup-panel, .test-list-question, .mode-question-card, .session-mini-status, .ai-window, .empty-state, .first-study-path, .weak-topic-review, .library-pack, .subject-deck) {
  background: color-mix(in srgb, var(--premium-surface) 94%, var(--accent) 6%);
  border-color: var(--premium-line);
  color: var(--premium-text);
}

html[data-theme="light"] body:not(.is-locked) :where(h1, h2, h3, h4, strong, label, .grade-page-header h1, .planner-page-header h1, .sleek-page-header h1, .cards-page-header h1, .study-hub-card h2, .recent-deck-row strong, .search-deck-row strong, .learning-mode-card strong, .grade-folder strong, .grade-folder em),
html[data-theme="light"] body:not(.is-locked) :where(input, select, textarea, button:not(.primary-button), .bottom-nav a) {
  color: var(--premium-text);
}

html[data-theme="dark"] body:not(.is-locked) :where(h1, h2, h3, h4, strong, label, .grade-page-header h1, .planner-page-header h1, .sleek-page-header h1, .cards-page-header h1, .study-hub-card h2, .recent-deck-row strong, .search-deck-row strong, .learning-mode-card strong, .grade-folder strong, .grade-folder em),
html[data-theme="dark"] body:not(.is-locked) :where(input, select, textarea, button:not(.primary-button), .bottom-nav a) {
  color: var(--premium-text);
}

html[data-theme="light"] body:not(.is-locked) :where(p, small, em, .panel-note, .study-hub-card p, .recent-deck-row small, .search-deck-row small, .search-deck-row em, .learning-mode-card small, .grade-folder small) {
  color: var(--premium-muted);
}

html[data-theme="dark"] body:not(.is-locked) :where(p, small, em, .panel-note, .study-hub-card p, .recent-deck-row small, .search-deck-row small, .search-deck-row em, .learning-mode-card small, .grade-folder small) {
  color: var(--premium-muted);
}

html[data-theme="light"] body:not(.is-locked) :where(input, select, textarea),
html[data-theme="dark"] body:not(.is-locked) :where(input, select, textarea) {
  background: color-mix(in srgb, var(--premium-surface-soft) 86%, transparent);
  border-color: var(--premium-line);
}

html[data-theme="light"] body:not(.is-locked) input::placeholder,
html[data-theme="light"] body:not(.is-locked) textarea::placeholder {
  color: color-mix(in srgb, var(--premium-muted) 82%, #ffffff);
}

html[data-theme="dark"] body:not(.is-locked) input::placeholder,
html[data-theme="dark"] body:not(.is-locked) textarea::placeholder {
  color: color-mix(in srgb, var(--premium-muted) 78%, #0b1220);
}

html[data-theme="light"] body:not(.is-locked) :where(.secondary-button, .icon-button, .header-icon-button, .theme-icon-button) {
  background: color-mix(in srgb, var(--accent) 5%, #ffffff);
  border-color: var(--premium-line);
  color: var(--premium-text);
}

html[data-theme="dark"] body:not(.is-locked) :where(.secondary-button, .icon-button, .header-icon-button, .theme-icon-button) {
  background: color-mix(in srgb, var(--accent) 10%, #101827);
  border-color: var(--premium-line);
  color: var(--premium-text);
}

html[data-theme="light"] body:not(.is-locked) .bottom-nav {
  background: color-mix(in srgb, var(--accent) 5%, #ffffff);
  border-color: var(--premium-line);
  box-shadow: 0 18px 42px color-mix(in srgb, var(--accent) 11%, rgba(15, 23, 42, 0.11));
}

html[data-theme="dark"] body:not(.is-locked) .bottom-nav {
  background: color-mix(in srgb, var(--accent) 12%, #101827);
  border-color: var(--premium-line);
}

html[data-theme="light"] body:not(.is-locked) .bottom-nav a.active,
html[data-theme="light"] body:not(.is-locked) .bottom-nav a.active .nav-icon,
html[data-theme="dark"] body:not(.is-locked) .bottom-nav a.active,
html[data-theme="dark"] body:not(.is-locked) .bottom-nav a.active .nav-icon {
  color: var(--accent);
}

html[data-theme="light"] body:not(.is-locked) .primary-button,
html[data-theme="dark"] body:not(.is-locked) .primary-button {
  background: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 76%, #ffffff));
  color: #ffffff;
}

/* ChatGPT-style send button for Lynxly AI. Kept last so theme text rules do not wash it out. */
body:not(.is-locked) .ai-send-button,
html[data-theme="light"] body:not(.is-locked) .ai-send-button,
html[data-theme="dark"] body:not(.is-locked) .ai-send-button {
  background: #050716;
  border: 1px solid color-mix(in srgb, #ffffff 82%, transparent);
  border-radius: 999px;
  box-shadow: 0 10px 24px rgba(5, 7, 22, 0.2);
  color: #ffffff;
  height: 42px;
  min-height: 42px;
  width: 42px;
}

body:not(.is-locked) .ai-send-button:hover,
body:not(.is-locked) .ai-send-button:focus-visible {
  background: #000000;
  color: #ffffff;
  transform: translateY(-1px) scale(1.02);
}

.ai-send-arrow {
  align-items: center;
  color: inherit;
  display: inline-flex;
  justify-content: center;
  line-height: 0;
}

.ai-send-arrow .icon {
  height: 19px;
  stroke-width: 2.8;
  width: 19px;
}

/* Grades as a connected progress feature. */
.grade-progress-card {
  display: grid;
  gap: 18px;
  overflow: hidden;
  position: relative;
}

.grade-progress-card::after {
  background: radial-gradient(circle at 70% 5%, color-mix(in srgb, var(--primary, #7c3aed) 18%, transparent), transparent 42%);
  content: "";
  height: 220px;
  pointer-events: none;
  position: absolute;
  right: -90px;
  top: -120px;
  width: 220px;
}

.grade-progress-card > * {
  position: relative;
  z-index: 1;
}

.grade-progress-card p {
  font-size: 0.98rem;
  line-height: 1.55;
  margin: 0;
}

.grade-progress-grid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.grade-progress-grid article,
.grade-next-action {
  background: color-mix(in srgb, var(--surface, #fff) 86%, var(--primary-soft, #eee7ff));
  border: 1px solid color-mix(in srgb, var(--line, #e8eaf2) 82%, transparent);
  border-radius: 20px;
  padding: 14px;
}

.grade-progress-grid span,
.grade-next-action span,
.grade-study-recommendation span {
  color: var(--muted);
  display: block;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0;
  text-transform: uppercase;
}

.grade-progress-grid strong {
  display: block;
  font-size: 1.45rem;
  line-height: 1.1;
  margin-top: 8px;
}

.grade-progress-grid small,
.grade-next-action small,
.grade-next-action em {
  color: var(--muted);
  display: block;
  font-size: 0.82rem;
  line-height: 1.45;
  margin-top: 5px;
}

.grade-next-action {
  align-items: center;
  display: grid;
  gap: 14px;
  grid-template-columns: minmax(0, 1fr) auto;
}

.grade-next-action strong {
  display: block;
  font-size: 1.18rem;
  margin-top: 6px;
}

.grade-study-recommendation {
  align-items: center;
  background: linear-gradient(145deg, color-mix(in srgb, var(--primary-soft, #eee7ff) 68%, var(--surface, #fff)), var(--surface, #fff));
  border: 1px solid color-mix(in srgb, var(--primary, #7c3aed) 18%, var(--line, #e8eaf2));
  border-radius: 24px;
  box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
  display: grid;
  gap: 16px;
  grid-template-columns: minmax(0, 1fr) auto;
  margin: 12px 0;
  padding: 18px;
}

.grade-study-recommendation h2 {
  font-size: clamp(1.25rem, 7vw, 1.75rem);
  line-height: 1.08;
  margin: 6px 0 8px;
}

.grade-study-recommendation p {
  line-height: 1.55;
  margin: 0 0 8px;
}

.grade-study-recommendation small {
  color: var(--muted);
  line-height: 1.45;
}

.grade-ai-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin: 8px 0 14px;
}

.grade-ai-actions .secondary-button,
.grade-next-action .secondary-button,
.grade-study-recommendation .primary-button {
  min-height: 44px;
}

html[data-theme="dark"] .grade-progress-grid article,
html[data-theme="dark"] .grade-next-action {
  background: color-mix(in srgb, var(--surface, #111827) 84%, var(--primary, #7c3aed));
}

html[data-theme="dark"] .grade-study-recommendation {
  background: linear-gradient(145deg, color-mix(in srgb, var(--primary, #7c3aed) 18%, var(--surface, #111827)), var(--surface, #111827));
  box-shadow: 0 18px 45px rgba(0, 0, 0, 0.25);
}

@media (max-width: 520px) {
  .grade-progress-grid {
    grid-template-columns: 1fr;
  }

  .grade-next-action,
  .grade-study-recommendation {
    grid-template-columns: 1fr;
  }

  .grade-next-action .secondary-button,
  .grade-study-recommendation .primary-button {
    width: 100%;
  }
}

/* Complete generated league photos in progress widgets. */
.league-image-symbol {
  background: transparent;
  border: 0;
  box-shadow: none;
  overflow: visible;
  padding: 0;
}

.league-image-symbol img {
  background: transparent;
  border-radius: 12px;
  display: block;
  height: 42px;
  object-fit: contain;
  object-position: center;
  width: 42px;
}

.league-title-row .league-image-symbol {
  align-items: center;
  background: color-mix(in srgb, var(--panel) 82%, #020617);
  border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line));
  border-radius: 999px;
  box-shadow: 0 12px 26px rgba(15, 23, 42, 0.18);
  display: inline-flex;
  gap: 10px;
  min-height: 48px;
  padding: 5px 14px 5px 5px;
}

.league-title-row .league-image-symbol img {
  border-radius: 14px;
  height: 42px;
  width: 42px;
}

.league-title-row .league-image-symbol small {
  color: var(--ink);
  display: block;
  font-size: 0.8rem;
  font-weight: 950;
  line-height: 1.1;
}

.level-card-league-photo {
  align-items: center;
  display: grid;
  flex: 0 0 auto;
  justify-items: center;
}

.level-card-league-photo .league-symbol {
  background: transparent;
  border: 0;
  box-shadow: none;
  min-height: 72px;
  min-width: 72px;
  padding: 0;
}

.level-card-league-photo .league-image-symbol img {
  border-radius: 20px;
  height: 72px;
  width: 72px;
}

.xp-meta .league-image-symbol {
  display: inline-flex;
  min-height: 28px;
  min-width: 28px;
  vertical-align: middle;
}

.xp-meta .league-image-symbol img {
  border-radius: 9px;
  height: 28px;
  width: 28px;
}

.league-badge .league-image-symbol img {
  border-radius: 22px;
  height: 100%;
  object-fit: contain;
  width: 100%;
}

/* Lynxly v203 focused academic home and Material sheet. */
:root {
  --lynxly-home-bg: #07101f;
  --lynxly-home-panel: #101a2b;
  --lynxly-home-panel-2: #132137;
  --lynxly-home-text: #f7fbff;
  --lynxly-home-muted: #9fb0c7;
  --lynxly-home-line: rgba(148, 163, 184, 0.2);
  --lynxly-home-blue: #3b82f6;
  --lynxly-home-cyan: #22d3ee;
  --lynxly-home-success: #34d399;
  --lynxly-home-shadow: 0 22px 58px rgba(0, 0, 0, 0.32);
}

body[data-route="dashboard"] {
  background:
    radial-gradient(circle at 84% -6%, color-mix(in srgb, var(--accent) 18%, transparent), transparent 30%),
    radial-gradient(circle at 12% 22%, rgba(34, 211, 238, 0.12), transparent 34%),
    linear-gradient(180deg, #081426 0%, var(--lynxly-home-bg) 64%, #050914 100%) !important;
  color: var(--lynxly-home-text);
}

body[data-route="dashboard"] .main-content {
  max-width: 480px;
  padding: 18px 18px calc(104px + env(safe-area-inset-bottom, 0px)) !important;
}

.lynxly-home-v3 {
  color: var(--lynxly-home-text);
  display: grid;
  gap: 14px;
  margin: 0 auto;
  max-width: 440px;
}

.lynxly-home-v3 .mission-home-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin: 0;
}

.lynxly-home-v3 .home-brand {
  align-items: center;
  color: var(--lynxly-home-text);
  display: inline-flex;
  gap: 10px;
  min-height: 44px;
  text-decoration: none;
}

.lynxly-home-v3 .home-brand img {
  background: #030712;
  border-radius: 10px;
  box-shadow: 0 12px 28px rgba(0, 0, 0, 0.3);
  height: 38px;
  width: 38px;
}

.lynxly-home-v3 .home-brand strong {
  font-size: 1.08rem;
  font-weight: 950;
}

.lynxly-home-v3 .home-header-actions {
  align-items: center;
  display: flex;
  gap: 8px;
}

.lynxly-home-v3 .home-streak-pill,
.lynxly-home-v3 .home-header-icon,
.lynxly-home-v3 .home-profile-link {
  align-items: center;
  background: rgba(16, 26, 43, 0.92);
  border: 1px solid var(--lynxly-home-line);
  border-radius: 14px;
  color: var(--lynxly-home-text);
  display: inline-flex;
  justify-content: center;
  min-height: 44px;
  min-width: 44px;
  text-decoration: none;
}

.lynxly-home-v3 .home-streak-pill {
  border-color: rgba(251, 146, 60, 0.34);
  color: #ffbd7a;
  gap: 6px;
  padding: 0 12px;
}

.lynxly-home-v3 .home-streak-pill strong {
  color: var(--lynxly-home-text);
}

.lynxly-home-v3 .home-profile-link .mascot {
  height: 34px;
  width: 34px;
}

.lynxly-home-v3 .home-notification-button {
  position: relative;
}

.lynxly-home-v3 .home-notification-button b {
  align-items: center;
  background: #ef4444;
  border: 2px solid var(--lynxly-home-panel);
  border-radius: 999px;
  color: #fff;
  display: flex;
  font-size: 0.66rem;
  font-weight: 950;
  height: 18px;
  justify-content: center;
  line-height: 1;
  min-width: 18px;
  position: absolute;
  right: -3px;
  top: -5px;
}

.lynxly-home-v3 .mission-greeting h1 {
  color: var(--lynxly-home-text) !important;
  font-size: clamp(2.15rem, 10vw, 3.05rem) !important;
  line-height: 1.03;
  margin: 4px 0 0;
}

.lynxly-home-v3 .mission-greeting p {
  color: var(--lynxly-home-muted);
  font-size: 1rem;
  line-height: 1.45;
  margin-top: 6px;
}

.daily-mission-card {
  background:
    radial-gradient(circle at 94% 4%, rgba(34, 211, 238, 0.16), transparent 32%),
    linear-gradient(145deg, #111d32, #0d1728 62%, #0a1424);
  border: 1px solid color-mix(in srgb, var(--lynxly-home-blue) 32%, var(--lynxly-home-line));
  border-radius: 24px;
  box-shadow: var(--lynxly-home-shadow);
  display: grid;
  gap: 14px;
  grid-template-columns: minmax(0, 1fr) 72px;
  min-height: 292px;
  overflow: hidden;
  padding: 22px;
  position: relative;
}

.daily-mission-copy {
  display: grid;
  gap: 12px;
  min-width: 0;
  position: relative;
  z-index: 1;
}

.daily-mission-kicker {
  align-items: center;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.daily-mission-kicker span,
.daily-mission-kicker em {
  border-radius: 999px;
  font-size: 0.78rem;
  font-style: normal;
  font-weight: 950;
  line-height: 1;
  padding: 8px 11px;
}

.daily-mission-kicker span {
  background: rgba(59, 130, 246, 0.16);
  color: #bfdbfe;
  letter-spacing: 0;
  text-transform: uppercase;
}

.daily-mission-kicker em {
  background: rgba(34, 211, 238, 0.11);
  color: #a5f3fc;
}

.daily-mission-card h2 {
  color: var(--lynxly-home-text);
  font-size: clamp(2rem, 9vw, 2.75rem);
  font-weight: 960;
  letter-spacing: 0;
  line-height: 1.04;
  margin: 4px 0 0;
  overflow-wrap: anywhere;
}

.daily-mission-meta,
.daily-mission-reason {
  color: var(--lynxly-home-muted);
  font-size: 1rem;
  line-height: 1.48;
  margin: 0;
}

.daily-mission-meta {
  color: #dbeafe;
  font-weight: 850;
}

.daily-mission-progress {
  background: rgba(148, 163, 184, 0.16);
  border-radius: 999px;
  height: 7px;
  overflow: hidden;
}

.daily-mission-progress i,
.weekly-progress-mini i {
  background: linear-gradient(90deg, var(--lynxly-home-blue), var(--lynxly-home-cyan));
  border-radius: inherit;
  display: block;
  height: 100%;
  transition: width 220ms ease;
}

.daily-mission-card .mission-continue-button {
  align-items: center;
  background: linear-gradient(135deg, var(--lynxly-home-blue), #2563eb) !important;
  border: 0;
  border-radius: 10px;
  box-shadow: 0 18px 38px rgba(37, 99, 235, 0.34);
  color: #fff;
  display: inline-flex;
  font-size: 1rem;
  font-weight: 950;
  gap: 8px;
  justify-content: center;
  min-height: 56px;
  width: 100%;
}

.daily-mission-mascot {
  align-items: center;
  align-self: start;
  background: rgba(255, 255, 255, 0.045);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 18px;
  display: grid;
  gap: 8px;
  justify-items: center;
  padding: 12px 8px;
}

.daily-mission-mascot .mascot {
  height: 46px;
  width: 46px;
}

.daily-mission-mascot > span:last-child {
  color: var(--lynxly-home-cyan);
}

.home-support-grid {
  display: grid;
  gap: 10px;
  grid-template-columns: 1fr;
}

.home-support-card {
  align-items: center;
  background: rgba(16, 26, 43, 0.86);
  border: 1px solid var(--lynxly-home-line);
  border-radius: 16px;
  color: var(--lynxly-home-text);
  display: grid;
  gap: 12px;
  grid-template-columns: 44px minmax(0, 1fr) auto;
  min-height: 82px;
  padding: 14px;
}

.home-support-card .support-icon {
  align-items: center;
  background: rgba(59, 130, 246, 0.14);
  border-radius: 12px;
  color: #93c5fd;
  display: inline-flex;
  height: 44px;
  justify-content: center;
  width: 44px;
}

.home-support-card small {
  color: var(--lynxly-home-cyan);
  display: block;
  font-size: 0.82rem;
  font-weight: 950;
  letter-spacing: 0;
  text-transform: uppercase;
}

.home-support-card h2 {
  color: var(--lynxly-home-text);
  font-size: 1rem;
  line-height: 1.25;
  margin: 2px 0;
}

.home-support-card p {
  color: var(--lynxly-home-muted);
  font-size: 0.9rem;
  line-height: 1.4;
  margin: 0;
}

.home-support-card > a {
  align-items: center;
  color: var(--lynxly-home-muted);
  display: inline-flex;
  min-height: 44px;
  min-width: 44px;
  justify-content: center;
}

.weekly-progress-card {
  grid-template-columns: 44px minmax(0, 1fr);
}

.weekly-progress-mini {
  background: rgba(148, 163, 184, 0.16);
  border-radius: 999px;
  height: 6px;
  margin-top: 9px;
  overflow: hidden;
}

.weekly-progress-mini i {
  background: linear-gradient(90deg, var(--lynxly-home-success), var(--lynxly-home-cyan));
}

.home-more-overview {
  display: grid;
  gap: 12px;
  margin-top: 2px;
}

.home-more-overview summary {
  align-items: center;
  background: rgba(16, 26, 43, 0.72);
  border: 1px solid var(--lynxly-home-line);
  border-radius: 16px;
  color: var(--lynxly-home-muted);
  cursor: pointer;
  display: flex;
  font-size: 0.95rem;
  font-weight: 900;
  min-height: 44px;
  padding: 0 14px;
}

.home-more-overview[open] summary {
  margin-bottom: 12px;
}

.home-more-overview .mission-stat-grid {
  margin-bottom: 12px;
}

.home-more-overview .mission-stat-card {
  border-radius: 16px;
  min-height: 96px;
}

.material-sheet-backdrop {
  align-items: end;
  background: rgba(2, 6, 23, 0.52);
  display: flex;
  inset: 0;
  padding: 16px;
  position: fixed;
  z-index: 120;
}

.material-sheet {
  background: #0f1a2b;
  border: 1px solid var(--lynxly-home-line);
  border-radius: 24px 24px 18px 18px;
  box-shadow: 0 28px 72px rgba(0, 0, 0, 0.46);
  color: var(--lynxly-home-text);
  margin: 0 auto calc(84px + env(safe-area-inset-bottom, 0px));
  max-width: 440px;
  padding: 18px;
  width: 100%;
}

.material-sheet header {
  align-items: start;
  display: flex;
  gap: 12px;
  justify-content: space-between;
  margin-bottom: 14px;
}

.material-sheet header span {
  color: var(--lynxly-home-cyan);
  font-size: 0.82rem;
  font-weight: 950;
  text-transform: uppercase;
}

.material-sheet h2 {
  color: var(--lynxly-home-text);
  font-size: 1.35rem;
  line-height: 1.18;
  margin: 4px 0 0;
}

.material-action-grid {
  display: grid;
  gap: 10px;
}

.material-action-grid button {
  align-items: center;
  background: rgba(255, 255, 255, 0.045);
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 16px;
  color: var(--lynxly-home-text);
  display: grid;
  gap: 2px 12px;
  grid-template-columns: 44px minmax(0, 1fr);
  min-height: 68px;
  padding: 11px;
  text-align: left;
}

.material-action-grid button .icon {
  align-self: center;
  background: rgba(59, 130, 246, 0.14);
  border-radius: 12px;
  color: #93c5fd;
  grid-row: span 2;
  height: 44px;
  padding: 11px;
  width: 44px;
}

.material-action-grid button span {
  font-size: 1rem;
  font-weight: 950;
}

.material-action-grid button small {
  color: var(--lynxly-home-muted);
  font-size: 0.84rem;
}

.bottom-nav :where(a, button) {
  -webkit-tap-highlight-color: transparent;
  align-items: center;
  appearance: none;
  background: transparent;
  border: 0;
  border-radius: 10px;
  color: var(--muted);
  cursor: pointer;
  display: grid;
  font: inherit;
  font-size: 0.78rem;
  font-weight: 900;
  gap: 3px;
  justify-items: center;
  min-height: 58px;
  min-width: 44px;
  padding: 4px 2px;
  text-decoration: none;
}

.bottom-nav {
  grid-template-columns: repeat(5, minmax(0, 1fr)) !important;
}

.bottom-nav :where(a.active, button.active) {
  color: var(--accent);
}

.bottom-nav :where(a.active, button.active) .nav-icon {
  color: var(--accent);
}

body[data-route="dashboard"] .bottom-nav {
  background: rgba(14, 23, 38, 0.94) !important;
  border: 1px solid rgba(148, 163, 184, 0.2) !important;
  border-radius: 18px !important;
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.38) !important;
  grid-template-columns: repeat(5, minmax(0, 1fr)) !important;
}

body[data-route="dashboard"] .bottom-nav :where(a, button) {
  color: #94a3b8;
}

body[data-route="dashboard"] .bottom-nav :where(a.active, button.active) {
  color: #60a5fa;
}

body[data-route="dashboard"] .bottom-nav :where(a.active, button.active) .nav-icon::after {
  background: #60a5fa;
}

:where(.daily-mission-card, .home-support-card, .material-sheet, .bottom-nav) :where(a, button):focus-visible,
.home-more-overview summary:focus-visible {
  outline: 3px solid rgba(34, 211, 238, 0.55);
  outline-offset: 3px;
}

@media (min-width: 760px) {
  body[data-route="dashboard"] .main-content {
    max-width: 760px;
  }

  .lynxly-home-v3 {
    max-width: 720px;
  }

  .daily-mission-card {
    grid-template-columns: minmax(0, 1fr) 118px;
  }

  .daily-mission-mascot .mascot {
    height: 64px;
    width: 64px;
  }

  .home-support-grid {
    grid-template-columns: 1.2fr 1fr;
  }
}

@media (max-width: 480px) {
  body[data-route="dashboard"] .main-content {
    padding: 16px 18px calc(96px + env(safe-area-inset-bottom, 0px)) !important;
  }

  .lynxly-home-v3 {
    gap: 10px;
  }

  .lynxly-home-v3 .mission-greeting h1 {
    font-size: clamp(2rem, 9vw, 2.55rem) !important;
    margin-top: 0;
  }

  .lynxly-home-v3 .mission-greeting p {
    font-size: 0.94rem;
    margin-top: 4px;
  }

  .daily-mission-card {
    gap: 10px;
    grid-template-columns: minmax(0, 1fr) 64px;
    min-height: 0;
    padding: 20px 22px;
  }

  .daily-mission-copy {
    gap: 9px;
  }

  .daily-mission-kicker span,
  .daily-mission-kicker em {
    font-size: 0.72rem;
    padding: 7px 10px;
  }

  .daily-mission-card h2 {
    font-size: clamp(2rem, 8.5vw, 2.3rem);
  }

  .daily-mission-meta {
    font-size: 0.95rem;
  }

  .daily-mission-reason {
    display: -webkit-box;
    font-size: 0.93rem;
    line-height: 1.38;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }

  .daily-mission-card .mission-continue-button {
    min-height: 48px;
  }

  .daily-mission-mascot {
    border-radius: 16px;
    padding: 9px 6px;
  }

  .daily-mission-mascot .mascot {
    height: 40px;
    width: 40px;
  }

  .home-support-grid {
    gap: 9px;
  }

  .home-support-card {
    gap: 10px;
    grid-template-columns: 42px minmax(0, 1fr) auto;
    min-height: 76px;
    padding: 12px 14px;
  }

  .home-support-card .support-icon {
    height: 42px;
    width: 42px;
  }

  .home-support-card h2 {
    font-size: 0.96rem;
    line-height: 1.2;
  }

  .home-support-card p {
    font-size: 0.84rem;
    line-height: 1.32;
  }
}

@media (max-width: 380px) {
  .daily-mission-card {
    grid-template-columns: 1fr;
    min-height: 0;
    padding: 18px;
  }

  .daily-mission-mascot {
    display: none;
  }

  .lynxly-home-v3 .home-profile-link {
    display: none;
  }
}

@media (prefers-reduced-motion: reduce) {
  .daily-mission-progress i,
  .weekly-progress-mini i {
    transition: none;
  }
}

/* Study session result: keep the first result view calm and scannable. */
.session-result-clean {
  background: color-mix(in srgb, var(--panel) 94%, var(--accent) 6%);
  border: 1px solid color-mix(in srgb, var(--line) 82%, transparent);
  border-radius: 24px;
  display: grid;
  gap: 18px;
  padding: 20px;
}

.session-result-hero {
  align-items: center;
  display: flex;
  gap: 14px;
}

.session-result-hero span,
.session-result-metrics span,
.progress-section > span,
.readiness-card > span {
  color: var(--accent);
  font-size: 0.78rem;
  font-weight: 950;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

.session-result-hero h2 {
  font-size: clamp(2rem, 9vw, 3rem);
  line-height: 1;
  margin: 4px 0;
}

.session-result-hero p {
  color: var(--muted);
  font-size: 1rem;
  margin: 0;
}

.session-result-metrics {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.session-result-metrics article {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 18px;
  min-height: 112px;
  padding: 16px;
}

.session-result-metrics strong {
  display: block;
  font-size: clamp(1.55rem, 7vw, 2.25rem);
  line-height: 1.05;
  margin: 8px 0;
}

.session-result-metrics small,
.session-summary-line span {
  color: var(--muted);
  line-height: 1.35;
}

.session-details {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 20px;
  padding: 4px;
}

.session-details summary {
  border-radius: 16px;
  cursor: pointer;
  font-weight: 950;
  list-style: none;
  min-height: 48px;
  padding: 15px 16px;
}

.session-details summary::-webkit-details-marker {
  display: none;
}

.session-details summary::after {
  content: "+";
  float: right;
}

.session-details[open] summary::after {
  content: "−";
}

.session-details > :not(summary) {
  margin: 12px;
}

.trial-bottom-sheet {
  background: var(--panel);
  border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
  border-radius: 24px;
  box-shadow: 0 18px 52px rgba(15, 23, 42, 0.18);
  display: grid;
  gap: 16px;
  max-width: 520px;
  padding: 22px;
  width: 100%;
}

.trial-bottom-sheet span {
  color: var(--accent);
  font-size: 0.78rem;
  font-weight: 950;
  text-transform: uppercase;
}

.trial-bottom-sheet h2 {
  font-size: 1.35rem;
  margin: 4px 0 6px;
}

.trial-bottom-sheet p {
  color: var(--muted);
  line-height: 1.5;
  margin: 0;
}

/* Academic progress should lead; gamification stays available but quieter. */
.progress-page .mistake-header h1 {
  font-size: clamp(2.2rem, 9vw, 4rem);
  line-height: 0.98;
}

.academic-progress {
  display: grid;
  gap: 18px;
}

.progress-section {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 22px;
  box-shadow: 0 14px 38px rgba(15, 23, 42, 0.08);
  display: grid;
  gap: 14px;
  padding: 18px;
}

.progress-section h2,
.readiness-card h2 {
  font-size: clamp(1.35rem, 5.8vw, 2rem);
  line-height: 1.1;
  margin: 0;
}

.progress-section p {
  color: var(--muted);
  line-height: 1.55;
  margin: 0;
}

.readiness-main {
  align-items: center;
  display: flex;
  gap: 14px;
  justify-content: space-between;
}

.readiness-main strong {
  display: block;
  font-size: clamp(2rem, 10vw, 3.3rem);
  line-height: 1;
}

.readiness-main small {
  color: var(--muted);
  display: block;
  font-size: 0.95rem;
  margin-top: 6px;
}

.readiness-mini-grid,
.progress-stat-grid.compact,
.grade-progress-grid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.readiness-mini-grid article,
.progress-stat-grid.compact article,
.grade-progress-grid article {
  background: color-mix(in srgb, var(--panel) 86%, var(--accent) 14%);
  border: 1px solid color-mix(in srgb, var(--line) 80%, transparent);
  border-radius: 16px;
  min-height: 92px;
  padding: 13px;
}

.readiness-mini-grid span,
.progress-stat-grid.compact span,
.grade-progress-grid span {
  color: var(--muted);
  display: block;
  font-size: 0.78rem;
  font-weight: 900;
  margin-bottom: 6px;
  text-transform: uppercase;
}

.readiness-mini-grid strong,
.progress-stat-grid.compact strong,
.grade-progress-grid strong {
  display: block;
  font-size: 1.35rem;
  line-height: 1.1;
  overflow-wrap: anywhere;
}

.readiness-mini-grid small,
.progress-stat-grid.compact small,
.grade-progress-grid small {
  color: var(--muted);
  display: block;
  margin-top: 6px;
}

.progress-topic-list {
  display: grid;
  gap: 10px;
}

.progress-topic-list article,
.progress-topic-list button {
  appearance: none;
  background: color-mix(in srgb, var(--panel) 92%, var(--accent) 8%);
  border: 1px solid var(--line);
  border-radius: 16px;
  color: var(--text);
  cursor: pointer;
  display: grid;
  font: inherit;
  gap: 4px;
  min-height: 64px;
  padding: 14px;
  text-align: left;
}

.progress-topic-list small,
.record-list span {
  color: var(--muted);
}

.grade-progress-card.panel {
  box-shadow: none;
  margin: 0;
}

.grade-next-action {
  align-items: center;
  background: color-mix(in srgb, var(--panel) 86%, var(--accent) 14%);
  border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
  border-radius: 18px;
  display: flex;
  gap: 12px;
  justify-content: space-between;
  padding: 14px;
}

.grade-next-action span,
.grade-next-action small,
.grade-next-action em {
  color: var(--muted);
  display: block;
}

.grade-next-action em {
  font-style: normal;
  margin-top: 6px;
}

.gamification-details summary {
  cursor: pointer;
  font-size: 1.05rem;
  font-weight: 950;
  min-height: 52px;
  padding: 4px 0;
}

.progress-mascot-card {
  box-shadow: none;
}

/* Planner agenda: default mobile view, with month kept as a secondary tab. */
.planner-view-tabs {
  background: color-mix(in srgb, var(--panel) 92%, var(--accent) 8%);
  border: 1px solid var(--line);
  border-radius: 18px;
  display: grid;
  gap: 6px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-bottom: 14px;
  padding: 6px;
}

.planner-view-tab {
  appearance: none;
  background: transparent;
  border: 0;
  border-radius: 13px;
  color: var(--muted);
  cursor: pointer;
  font: inherit;
  font-weight: 950;
  min-height: 46px;
}

.planner-view-tab.active {
  background: var(--accent);
  color: #fff;
}

.mobile-agenda-view {
  display: grid;
  gap: 18px;
}

.agenda-day-group {
  display: grid;
  gap: 10px;
}

.agenda-day-group h2 {
  color: var(--muted);
  font-size: 0.86rem;
  font-weight: 950;
  letter-spacing: 0.05em;
  margin: 0;
  text-transform: uppercase;
}

.agenda-day-list {
  display: grid;
  gap: 10px;
}

.planner-agenda-item {
  align-items: start;
  background: var(--panel);
  border: 1px solid var(--line);
  border-left: 5px solid var(--accent);
  border-radius: 18px;
  display: grid;
  gap: 10px;
  grid-template-columns: 76px minmax(0, 1fr);
  padding: 14px;
}

.planner-agenda-item.exam {
  border-left-color: var(--accent);
}

.planner-agenda-item.homework {
  border-left-color: #0284c7;
}

.planner-agenda-item.completed {
  opacity: 0.65;
}

.planner-agenda-item time {
  color: var(--accent);
  font-size: 0.92rem;
  font-weight: 950;
  line-height: 1.2;
  min-width: 0;
}

.planner-item-body strong {
  display: block;
  font-size: 1.04rem;
  line-height: 1.22;
}

.planner-item-body small {
  color: var(--muted);
  display: block;
  line-height: 1.35;
  margin-top: 4px;
}

.planner-item-actions {
  display: grid;
  gap: 8px;
  grid-column: 1 / -1;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.planner-item-actions button {
  appearance: none;
  background: color-mix(in srgb, var(--panel) 88%, var(--accent) 12%);
  border: 1px solid var(--line);
  border-radius: 12px;
  color: var(--text);
  cursor: pointer;
  font: inherit;
  font-size: 0.9rem;
  font-weight: 950;
  min-height: 44px;
  padding: 8px 10px;
}

.planner-item-actions button.danger {
  background: color-mix(in srgb, var(--bad, #ef4444) 12%, var(--panel));
  color: var(--bad, #ef4444);
}

.planner-item-actions button:disabled {
  cursor: default;
  opacity: 0.55;
}

.planner-empty-state {
  align-items: start;
  display: grid;
  gap: 10px;
  padding: 18px;
}

@media (max-width: 460px) {
  .session-result-metrics,
  .readiness-mini-grid,
  .progress-stat-grid.compact,
  .grade-progress-grid {
    grid-template-columns: 1fr;
  }

  .grade-next-action,
  .readiness-main {
    align-items: stretch;
    flex-direction: column;
  }

  .planner-agenda-item {
    grid-template-columns: 66px minmax(0, 1fr);
  }

  .planner-item-actions {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

/* Lynxly v205 bottom navigation: dark, quiet, icon-led mobile bar. */
body:not(.is-locked) .bottom-nav,
html[data-theme="light"] body:not(.is-locked) .bottom-nav,
html[data-theme="dark"] body:not(.is-locked) .bottom-nav,
body[data-route="dashboard"] .bottom-nav {
  align-items: stretch;
  background: #071426 !important;
  border: 0 !important;
  border-top: 1px solid rgba(148, 163, 184, 0.12) !important;
  border-radius: 0 !important;
  bottom: 0;
  box-shadow: 0 -18px 42px rgba(2, 6, 23, 0.32) !important;
  display: grid;
  gap: 0;
  grid-template-columns: repeat(5, minmax(0, 1fr)) !important;
  left: 50%;
  max-width: 520px;
  padding: 8px 12px calc(8px + env(safe-area-inset-bottom, 0px));
  right: auto;
  transform: translateX(-50%);
  width: min(100%, 520px);
  z-index: 80;
}

body:not(.is-locked) .bottom-nav :where(a, button),
html[data-theme="light"] body:not(.is-locked) .bottom-nav :where(a, button),
html[data-theme="dark"] body:not(.is-locked) .bottom-nav :where(a, button),
body[data-route="dashboard"] .bottom-nav :where(a, button) {
  align-items: center;
  appearance: none;
  background: transparent !important;
  border: 0 !important;
  border-radius: 0;
  box-shadow: none !important;
  color: #94a3b8;
  cursor: pointer;
  display: grid;
  font: inherit;
  font-size: 0.82rem;
  font-weight: 850;
  gap: 4px;
  justify-items: center;
  line-height: 1.1;
  min-height: 58px;
  min-width: 0;
  padding: 2px 0;
  text-decoration: none;
  width: 100%;
}

body:not(.is-locked) .bottom-nav .nav-icon {
  align-items: center;
  display: inline-flex;
  height: 31px;
  justify-content: center;
  width: 31px;
}

body:not(.is-locked) .bottom-nav .nav-icon svg {
  fill: none;
  height: 30px;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 2.15;
  width: 30px;
}

body:not(.is-locked) .bottom-nav :where(a.active, button.active),
html[data-theme="light"] body:not(.is-locked) .bottom-nav :where(a.active, button.active),
html[data-theme="dark"] body:not(.is-locked) .bottom-nav :where(a.active, button.active),
body[data-route="dashboard"] .bottom-nav :where(a.active, button.active) {
  color: #2296f3 !important;
}

body:not(.is-locked) .bottom-nav :where(a.active, button.active) .nav-icon svg {
  fill: color-mix(in srgb, currentColor 20%, transparent);
  stroke-width: 2.35;
}

body:not(.is-locked) .bottom-nav :where(a.active, button.active) .nav-icon::after,
body[data-route="dashboard"] .bottom-nav :where(a.active, button.active) .nav-icon::after {
  display: none !important;
}

body:not(.is-locked) .bottom-nav :where(a, button):focus-visible {
  border-radius: 12px;
  outline: 3px solid rgba(34, 150, 243, 0.45);
  outline-offset: 2px;
}

@media (min-width: 560px) {
  body:not(.is-locked) .bottom-nav,
  html[data-theme="light"] body:not(.is-locked) .bottom-nav,
  html[data-theme="dark"] body:not(.is-locked) .bottom-nav,
  body[data-route="dashboard"] .bottom-nav {
    border-left: 1px solid rgba(148, 163, 184, 0.12) !important;
    border-right: 1px solid rgba(148, 163, 184, 0.12) !important;
    border-top-left-radius: 20px !important;
    border-top-right-radius: 20px !important;
    width: min(100% - 24px, 520px);
  }
}

